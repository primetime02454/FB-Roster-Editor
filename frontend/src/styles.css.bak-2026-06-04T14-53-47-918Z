:root {
  --bg: #050505;
  --bg-elevated: #0b0b0c;
  --panel: #101113;
  --panel-2: #141518;
  --panel-3: #1a1c20;
  --text: #f3f4f6;
  --muted: #9a9ca3;
  --border: #26292f;
  --border-strong: #343942;
  --accent: #8f959e;
  --accent-2: #b0b6bf;
  --accent-soft: rgba(176,182,191,.10);
  --danger: #f97316;
  --cell: #111317;
  --cell-alt: #14171b;
  --shadow: 0 24px 60px rgba(0,0,0,.38);
  --scratch-panel: linear-gradient(rgba(8,9,10,.55), rgba(8,9,10,.68)), url("data:image/webp;base64,") center / cover no-repeat;
  --scratch-panel-soft: linear-gradient(rgba(12,13,15,.58), rgba(12,13,15,.72)), url("data:image/webp;base64,") center / cover no-repeat;
}
* { box-sizing: border-box; }
html, body, #root { height: 100%; margin: 0; }
body {
  background: #040404;
  color: var(--text);
  font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
}
body::before {
  content: "";
  position: fixed;
  inset: 0;
  z-index: -2;
  background:
    linear-gradient(rgba(0,0,0,.24), rgba(0,0,0,.36)),
    url("/CFB27_Background.png") center / cover no-repeat;
  opacity: .8;
  pointer-events: none;
}
body::after {
  content: "";
  position: fixed;
  inset: 0;
  z-index: -1;
  background: rgba(0,0,0,.42);
  pointer-events: none;
}
button, input, select, textarea { font: inherit; }
.file-input {
  position: fixed;
  left: -10000px;
  top: 0;
  width: 1px;
  height: 1px;
  opacity: 0;
  pointer-events: none;
}
button {
  background: #181a1e;
  color: var(--text);
  border: 1px solid var(--border);
  padding: 8px 10px;
  border-radius: 0;
  cursor: pointer;
  transition: background .16s ease, border-color .16s ease, transform .16s ease;
}
button:hover:not(:disabled) { border-color: #4b515a; background: #20242a; }
button:disabled { opacity: .45; cursor: not-allowed; }
input, select, textarea {
  background: #0c0e11;
  color: var(--text);
  border: 1px solid var(--border);
  border-radius: 0;
  padding: 9px 10px;
  outline: none;
}
input:focus, textarea:focus, select:focus { border-color: #666d77; box-shadow: 0 0 0 2px rgba(176,182,191,.12); }
select { background: #0d1014; color: #f8fafc; }
select option { background: #101317; color: #f8fafc; }
.app { height: 100%; display: flex; flex-direction: column; background: var(--scratch-panel); }
.logo {
  display: grid;
  place-items: center;
  width: 34px;
  height: 34px;
  border-radius: 0;
  background: linear-gradient(135deg, #4b5563, #1f2937);
  color: #f8fafc;
  font-weight: 900;
  letter-spacing: -.04em;
  box-shadow: inset 0 1px 0 rgba(255,255,255,.15);
}
h1 { font-size: 20px; margin: 0; }
p { margin: 0; color: var(--muted); font-size: 12px; }
.menubar {
  display: grid;
  grid-template-columns: minmax(300px, auto) minmax(0, 1fr) auto;
  align-items: center;
  gap: 10px;
  padding: 8px 10px;
  border-bottom: 1px solid var(--border);
  background: rgba(7,7,8,.94);
  position: sticky;
  top: 0;
  z-index: 15;
  backdrop-filter: blur(14px);
}
.nav-left, .nav-center, .nav-right { display: flex; align-items: center; min-width: 0; }
.nav-left { gap: 10px; }
.nav-left .menu-strip { margin-left: 6px; }
.nav-center {
  justify-content: center;
  gap: 10px;
  color: #cbd2db;
  font-size: 12px;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}
.nav-center strong { color: #f5f7fa; font-size: 14px; font-weight: 800; }
.nav-divider { color: #6f7680; }
.nav-right { justify-content: flex-end; }
.window-brand { display: none; }
.window-brand-copy { display: none; }
.window-brand-copy strong { font-size: 13px; font-weight: 800; }
.mobile-nav-toggle { display: none; min-height: 34px; min-width: 42px; padding: 6px 10px; margin-left: auto; }
.menu-strip, .mode-strip { display: flex; align-items: center; gap: 4px; min-width: 0; }
.mode-strip { justify-content: flex-end; overflow-x: auto; padding-left: 10px; }
.top-file-status {
  max-width: min(36vw, 420px);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  color: #aeb6c2;
  font-size: 12px;
  text-align: center;
}
.mode-strip button {
  flex: 0 0 auto;
  min-height: 34px;
  padding: 6px 12px;
  background: #14161a;
}
.mode-strip button.active {
  background: #252930;
  border-color: #575f69;
  font-weight: 700;
}
.mobile-nav-panel { display: none; }
.menu { position: relative; }
.menu-trigger { padding: 7px 12px; border-radius: 0; cursor: pointer; color: var(--text); user-select: none; background: transparent; border: 1px solid transparent; }
.menu.open .menu-trigger, .menu-trigger:hover { background: #1a1d22; border-color: transparent; }
.menu-dropdown {
  position: absolute;
  top: calc(100% + 6px);
  left: 0;
  min-width: 220px;
  padding: 6px;
  display: grid;
  gap: 4px;
  background: #111317;
  border: 1px solid var(--border-strong);
  border-radius: 0;
  box-shadow: var(--shadow);
  z-index: 20;
}
.menu-dropdown button { text-align: left; border-radius: 0; background: transparent; border-color: transparent; }
.menu-dropdown button:hover:not(:disabled) { background: #1a1d22; border-color: transparent; }
.menu-separator { height: 1px; margin: 4px 2px; background: var(--border); }
.workspace { flex: 1; min-height: 0; display: grid; grid-template-columns: 300px minmax(0, 1fr); background: var(--scratch-panel); }
.workspace-editor { grid-template-columns: minmax(0, 1fr); }
.sidebar { min-height: 0; border-right: 1px solid var(--border); background: var(--scratch-panel-soft); display: flex; flex-direction: column; }
.sidebar-title { padding: 14px; font-weight: 700; border-bottom: 1px solid var(--border); background: var(--scratch-panel-soft); }
.table-list { overflow: auto; padding: 8px; display: flex; flex-direction: column; gap: 7px; }
.table-list button { text-align: left; display: grid; gap: 2px; padding: 10px; min-height: 72px; align-content: center; }
.table-list button.active { border-color: #4b515a; background: #1b1e23; }
.table-list b { font-size: 14px; }
.table-list span, .table-list small { color: var(--muted); font-size: 11px; overflow: hidden; white-space: nowrap; text-overflow: ellipsis; }
.main { min-width: 0; min-height: 0; display: flex; flex-direction: column; }
.mobile-table-strip {
  display: none;
  gap: 8px;
  padding: 0 12px 12px;
  overflow-x: auto;
  border-bottom: 1px solid var(--border);
  background: var(--scratch-panel-soft);
}
.mobile-table-strip button {
  flex: 0 0 auto;
  min-height: 40px;
  padding-inline: 14px;
  border-radius: 0;
  background: #17191d;
}
.mobile-table-strip button.active { border-color: #4b515a; background: #23262b; }
.panel { margin: 0; background: var(--scratch-panel-soft); border: 1px solid var(--border); border-radius: 0; overflow: hidden; box-shadow: 0 10px 28px rgba(0,0,0,.18); }
.fullheight { flex: 1; min-height: 0; display: flex; flex-direction: column; }
.panel-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12px;
  padding: 10px 12px;
  border-bottom: 1px solid var(--border);
  background: var(--scratch-panel-soft);
}
.panel-head h2 { margin: 0; font-size: 14px; }
.search-tools { display: flex; align-items: center; gap: 8px; flex-wrap: wrap; }
.search-tools input { width: min(240px, 100%); min-height: 34px; padding: 7px 10px; }
.compact-tools button, .compact-tools input { min-height: 34px; }
.table-toolbar {
  display: grid;
  grid-template-columns: 150px 140px 180px minmax(180px, 1fr) minmax(180px, 1fr) auto auto auto auto auto;
  gap: 8px;
  padding: 8px 12px;
  border-bottom: 1px solid var(--border);
  background: var(--scratch-panel-soft);
  align-items: end;
}
.table-toolbar label { display: grid; gap: 4px; font-size: 11px; color: var(--muted); }
.table-toolbar span { color: var(--muted); }
.table-toolbar input, .table-toolbar select { min-height: 34px; padding: 7px 9px; }
.toolbar-grow { min-width: 0; }
.table-range { align-self: center; justify-self: end; white-space: nowrap; }
.muted { color: var(--muted); font-size: 12px; }
.grid-wrap { flex: 1; min-height: 0; overflow: auto; background: var(--scratch-panel); }
.data-grid { border-collapse: separate; border-spacing: 0; width: max-content; min-width: 100%; font-size: 12px; }
.data-grid th {
  position: sticky;
  top: 0;
  z-index: 2;
  background: #181b20;
  color: #e5e7eb;
  border-bottom: 1px solid var(--border-strong);
  border-right: 1px solid var(--border);
  text-align: left;
  padding: 9px 10px;
  white-space: nowrap;
  cursor: pointer;
}
.data-grid th.sorted { color: #ffffff; background: #1b1e23; }
.data-grid th small { margin-left: 6px; color: var(--accent-2); font-size: 10px; }
.data-grid th .sort-indicator {
  color: #f3f4f6;
  font-size: 11px;
  display: inline-block;
  width: 12px;
  text-align: center;
}
.data-grid td {
  max-width: 360px;
  min-width: 92px;
  height: 31px;
  overflow: hidden;
  white-space: nowrap;
  text-overflow: ellipsis;
  border-bottom: 1px solid #1a2332;
  border-right: 1px solid #1a2332;
  padding: 6px 9px;
  background: var(--cell);
}
.data-grid tr:nth-child(even) td { background: var(--cell-alt); }
.data-grid td:focus, .data-grid td.selected { outline: 2px solid #6b7280; outline-offset: -2px; background: #1d2128; }
.data-grid td.readonly { color: #e5e7eb; background: #16191d; font-weight: 700; }
.modal-backdrop { position: fixed; inset: 0; background: rgba(0,0,0,.55); display: grid; place-items: center; z-index: 100; }
.modal { width: min(460px, calc(100% - 24px)); background: var(--scratch-panel-soft); border: 1px solid var(--border-strong); border-radius: 0; padding: 18px; box-shadow: var(--shadow); }
.modal h2 { margin-top: 0; }
.modal label { display: grid; gap: 6px; margin: 10px 0; color: var(--muted); font-size: 12px; }
.row { display: flex; gap: 8px; }
.right { justify-content: flex-end; }
.editor-page { overflow: hidden; min-height: 0; }
.editor-page.fullheight { min-height: 0; }
.editor-search-inline { display: flex; align-items: center; justify-content: flex-end; gap: 6px; min-width: min(100%, 320px); margin-left: auto; }
.editor-search-inline input { width: min(220px, 100%); min-height: 30px; padding: 6px 8px; }
.editor-search-inline button { min-width: 74px; min-height: 30px; padding: 5px 9px; }
.editor-grid { display: grid; grid-template-rows: auto auto 1fr; gap: 14px; padding: 14px; overflow: auto; }
.editor-shell { flex: 1 1 auto; display: grid; grid-template-columns: 220px minmax(0, 1fr); gap: 0; padding: 0; min-height: 0; height: 100%; overflow: hidden; align-items: stretch; }
.editor-nav { display: flex; flex-direction: column; gap: 4px; min-height: 0; height: 100%; max-height: none; overflow: hidden; padding: 4px; border: 1px solid var(--border); border-radius: 0; background: var(--scratch-panel-soft); min-width: 0; }
.nav-controls { display: grid; gap: 5px; padding: 3px; border-bottom: 1px solid var(--border); }
.nav-controls label { display: grid; gap: 3px; color: var(--muted); font-size: 10px; }
.nav-controls select { width: 100%; min-height: 30px; padding: 5px 7px; font-size: 11px; font-weight: 700; }
.record-count { color: #dbeafe; font-weight: 800; font-size: 12px; text-align: center; padding: 2px 0 4px; }
.editor-nav-list { overflow: auto; display: flex; flex-direction: column; gap: 3px; padding-right: 6px; min-height: 0; flex: 1 1 auto; min-width: 0; scrollbar-gutter: stable; }
.editor-nav-list button { text-align: left; display: block; padding: 6px 8px; border-radius: 0; min-height: 42px; min-width: 0; border-color: rgba(255,255,255,.18); }
.nav-controls select,
.editor-nav-list button {
  background-blend-mode: normal;
}
.editor-nav-list button:hover:not(:disabled), .editor-nav-list button.active { border-color: #d7dde7; filter: brightness(1.12); }
.record-card-row { display: grid; grid-template-columns: auto minmax(0, 1fr); align-items: center; gap: 7px; min-width: 0; }
.record-card-logo {
  width: 24px;
  height: 24px;
  object-fit: contain;
  filter:
    drop-shadow(0 1px 0 rgba(255,255,255,.35))
    drop-shadow(0 -1px 0 rgba(255,255,255,.20))
    drop-shadow(1px 0 0 rgba(255,255,255,.18))
    drop-shadow(-1px 0 0 rgba(255,255,255,.18))
    drop-shadow(0 2px 2px rgba(0,0,0,.95))
    drop-shadow(0 0 5px rgba(255,255,255,.32));
}
.record-card-body { min-width: 0; display: grid; gap: 1px; }
.record-card-head { display: grid; grid-template-columns: minmax(0, 1fr) auto; align-items: baseline; gap: 8px; min-width: 0; }
.editor-nav-list b { font-size: 12px; line-height: 1.18; min-width: 0; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.record-card-head small { color: #ffffff; font-size: 10px; white-space: nowrap; text-align: right; font-weight: 800; }
.editor-nav-list span {
  color: rgba(255,255,255,.82);
  font-size: 10px;
  line-height: 1.2;
  white-space: normal;
  overflow-wrap: anywhere;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
  max-width: 100%;
}
.editor-content { display: flex; flex-direction: column; gap: 0; min-width: 0; min-height: 0; height: 100%; overflow-y: auto; overflow-x: hidden; }
.editor-content > *, .editor-section, .identity-main > *, .form-grid > *, .form-grid-priority > *, .subtabs { min-width: 0; }
.record-picker { display: grid; grid-template-columns: 1fr auto 1fr; align-items: center; gap: 5px; }
.record-picker button { min-height: 34px; padding: 5px 8px; }
.record-picker button:last-child { justify-self: end; }
.identity-card {
  border: 1px solid var(--border);
  background-blend-mode: normal;
  border-radius: 0;
  padding: 16px 18px;
  color: #fff;
  text-shadow: 0 1px 2px rgba(0,0,0,.75);
}
.identity-card h3 { margin: 0; font-size: clamp(22px, 2.8vw, 31px); line-height: 1.04; letter-spacing: -.01em; }
.identity-card p { margin-top: 4px; font-size: 13px; }
.compact-identity { padding: 14px 16px; }
.identity-main { display: flex; align-items: center; justify-content: space-between; gap: 22px; min-height: 72px; width: 100%; }
.identity-title-group { display: flex; align-items: center; min-width: 0; flex: 1 1 auto; }
.identity-title-row { display: flex; align-items: center; gap: 20px; flex-wrap: nowrap; min-height: 66px; min-width: 0; }
.identity-title-row h3 { font-size: clamp(21px, 2.5vw, 30px); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
.identity-logo {
  width: 66px;
  height: 66px;
  min-width: 66px;
  flex: 0 0 66px;
  object-fit: contain;
  align-self: center;
  filter:
    drop-shadow(0 1px 0 rgba(255,255,255,.42))
    drop-shadow(0 -1px 0 rgba(255,255,255,.24))
    drop-shadow(1px 0 0 rgba(255,255,255,.22))
    drop-shadow(-1px 0 0 rgba(255,255,255,.22))
    drop-shadow(0 3px 3px rgba(0,0,0,.95))
    drop-shadow(0 0 10px rgba(255,255,255,.38));
}
.team-logo { order: -1; }
.player-logo { margin-left: 0; order: -1; }
.editor-tabs-row { display: flex; align-items: center; justify-content: space-between; gap: 0; flex-wrap: wrap; border-top: 1px solid var(--border); border-bottom: 1px solid var(--border); background: var(--scratch-panel-soft); }
.subtabs { display: flex; gap: 0; flex-wrap: wrap; padding-bottom: 0; }
.subtabs button { min-height: 30px; padding: 5px 9px; background: #15181c; font-size: 12px; }
.subtabs button.active { background: #23272d; border-color: #5a626d; font-weight: 700; }
.editor-section { border: 1px solid var(--border); border-top: 0; background: var(--scratch-panel-soft); border-radius: 0; padding: 8px; }
.editor-section-head { display: flex; justify-content: space-between; align-items: baseline; gap: 12px; margin-bottom: 10px; }
.editor-section-head h3 { margin: 0; font-size: 13px; letter-spacing: .08em; text-transform: uppercase; color: #e5e7eb; }
.editor-section-head p { font-size: 12px; }
.chips { display: flex; gap: 8px; flex-wrap: wrap; margin-top: 0; justify-content: flex-end; align-items: center; align-self: center; flex: 0 1 auto; }
.chips span { padding: 6px 9px; background: rgba(8,10,14,.45); border: 1px solid rgba(255,255,255,.22); color: #fff; border-radius: 0; font-size: 12px; font-weight: 800; }
.team-swatches { display: flex; gap: 16px; margin-top: 0; flex-wrap: wrap; align-items: center; justify-content: center; }
.team-swatches-panel { margin: 8px 0 12px; justify-content: flex-start; }
.swatch-block { display: grid; grid-template-columns: 26px auto; gap: 8px; align-items: center; min-width: 96px; }
.swatch-block strong { display: block; font-size: 12px; color: #fff; text-align: center; }
.swatch-block small { color: var(--muted); font-size: 10px; }
.color-swatch { width: 26px; height: 26px; border: 1px solid var(--border-strong); display: inline-block; }
.swatch-input { position: relative; display: inline-grid; cursor: pointer; }
.swatch-input input[type="color"] { position: absolute; inset: 0; opacity: 0; cursor: pointer; }
.form-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(150px, 240px)); gap: 8px 10px; align-items: start; }
.form-grid label { display: grid; gap: 5px; color: var(--muted); font-size: 11px; }
.form-grid-priority { grid-template-columns: repeat(auto-fit, minmax(160px, 260px)); }
.form-grid label span { color: #e5e7eb; font-size: 12px; font-weight: 600; }
.form-grid small { color: #7d8188; font-size: 10px; letter-spacing: .03em; }
.form-grid input, .form-grid select { width: 100%; min-height: 30px; padding: 6px 8px; }
.form-grid input { font-size: 13px; }
.spinner-field { display: grid; grid-template-columns: 1fr 28px; }
.spinner-field input { min-width: 0; }
.spinner-buttons { display: grid; grid-template-rows: 1fr 1fr; }
.spinner-buttons button { padding: 0; min-height: 21px; font-size: 12px; }
.empty { padding: 24px; color: var(--muted); }
.pager { display: flex; justify-content: center; align-items: center; gap: 10px; padding: 10px; border-top: 1px solid var(--border); }
.node-editor-body { flex: 1; min-height: 0; display: grid; grid-template-columns: minmax(280px, 420px) 1fr; }
.node-tree { overflow: auto; border-right: 1px solid var(--border); background: var(--scratch-panel-soft); padding: 10px 0; }
.json-node summary, .json-leaf { display: flex; align-items: center; gap: 8px; min-height: 28px; padding-right: 12px; }
.json-node summary { cursor: pointer; }
.json-key { color: #d1d5db; font-weight: 600; }
.json-meta { color: var(--muted); font-size: 11px; }
.json-value { color: #e2e8f0; word-break: break-all; }
.node-editor textarea { flex: 1; min-height: 0; width: 100%; border: 0; border-radius: 0; resize: none; font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, "Liberation Mono", monospace; font-size: 12px; line-height: 1.45; padding: 14px; background: #0d0f12; color: #e5e7eb; }
.node-status { min-height: 32px; padding: 8px 12px; color: var(--muted); border-top: 1px solid var(--border); font-size: 12px; }
@media (max-width: 1280px) {
  .workspace { grid-template-columns: 260px minmax(0, 1fr); }
  .form-grid { grid-template-columns: repeat(3, minmax(0, 1fr)); }
  .form-grid-priority { grid-template-columns: repeat(3, minmax(0, 1fr)); }
}
@media (max-width: 1360px) {
  .workspace { grid-template-columns: 1fr; }
  .sidebar { display: none; }
  .mobile-table-strip { display: flex; }
  .menubar { grid-template-columns: auto minmax(0, 1fr) auto; overflow: visible; row-gap: 6px; }
  .window-brand { min-width: 0; }
  .nav-left { min-width: 0; }
  .nav-center { grid-column: 1 / -1; max-width: 100%; justify-content: center; }
  .top-file-status { max-width: 100%; }
  .mobile-nav-toggle { display: inline-flex; align-items: center; justify-content: center; }
  .menu-strip, .mode-strip { display: none; }
  .mobile-nav-panel {
    display: grid;
    gap: 8px;
    padding: 10px;
    border-bottom: 1px solid var(--border);
    background: #0f1012;
  }
  .mobile-nav-menus, .mobile-nav-modes { display: flex; gap: 8px; flex-wrap: wrap; }
  .mobile-nav-modes button { min-height: 36px; }
  .menu-dropdown { position: fixed; top: 86px; left: 10px; right: 10px; width: auto; max-height: min(70vh, 420px); overflow: auto; }
  .panel-head { align-items: flex-start; flex-direction: column; }
  .search-tools { width: 100%; }
  .search-tools input { width: 100%; }
  .table-toolbar { grid-template-columns: repeat(2, minmax(0, 1fr)); }
  .node-editor-body { grid-template-columns: 1fr; }
  .node-tree { max-height: 240px; border-right: 0; border-bottom: 1px solid var(--border); }
  .editor-shell { grid-template-columns: minmax(190px, 250px) minmax(0, 1fr); overflow-x: hidden; }
  .editor-nav { order: 1; max-height: none; height: 100%; position: sticky; top: 0; }
  .editor-content { order: 2; overflow: hidden; }
  .editor-nav-list { max-height: none; min-height: 0; }
  .identity-main { align-items: center; gap: 12px; flex-wrap: wrap; }
  .chips, .team-swatches { justify-content: flex-start; }
  .editor-search-inline { margin-left: auto; min-width: min(100%, 300px); padding: 4px; }
  .editor-search-inline label { min-width: 0; }
  .form-grid, .form-grid-priority { grid-template-columns: repeat(2, minmax(0, 1fr)); }
  .identity-title-row { gap: 10px; }
}
@media (max-width: 640px) {
  html, body, #root { min-width: 0; overflow-x: hidden; }
  .app { min-width: 0; overflow-x: hidden; }
  .menubar, .mobile-table-strip { padding-inline: 8px; }
  .nav-center { font-size: 11px; gap: 6px; }
  .nav-center strong { font-size: 12px; }
  .window-brand-copy strong { font-size: 12px; }
  .panel { margin: 0; border-radius: 0; width: 100%; }
  .main { overflow-x: hidden; }
  .editor-shell { grid-template-columns: 1fr; padding: 0; gap: 0; overflow-x: hidden; }
  .editor-nav { position: static; max-height: none; padding: 8px; border-left: 0; border-right: 0; }
  .editor-nav-list { max-height: 210px; }
  .editor-content { width: 100%; overflow: hidden; }
  .editor-section, .identity-card { padding: 10px; border-left: 0; border-right: 0; }
  .editor-tabs-row { align-items: stretch; }
  .subtabs { flex: 1 1 100%; }
  .subtabs button { flex: 1 1 auto; }
  .editor-search-inline { flex: 1 1 100%; padding: 8px; }
  .editor-search-inline input { width: 100%; }
  .form-grid, .form-grid-priority { grid-template-columns: 1fr; }
  .data-grid th, .data-grid td { padding: 8px 9px; }
  .table-toolbar { grid-template-columns: 1fr; }
  .editor-nav-list button { min-height: 52px; }
  .identity-main { display: flex; flex-direction: column; align-items: stretch; gap: 8px; }
  .identity-title-group { width: 100%; }
  .identity-title-row { flex-direction: row; gap: 10px; align-items: center; min-height: 0; width: 100%; }
  .identity-title-row h3 { font-size: 20px; min-width: 0; }
  .identity-logo { width: 56px; height: 56px; flex: 0 0 auto; }
  .identity-title-row .identity-logo { order: -1; }
  .chips, .team-swatches { justify-content: flex-start; }
}
