def visual_slot_types_map(pmap: Dict[str, Any]) -> Dict[str, List[str]]:
    slot_types: Dict[str, set[str]] = {}
    for player in pmap.values():
        for loadout in player.get("loadouts") or []:
            for element in loadout.get("loadoutElements") or []:
                slot_type = element.get("slotType")
                if slot_type is None:
                    continue
                props = slot_types.setdefault(str(slot_type), set())
                props.add("itemAssetName")
                for blend in element.get("blends") or []:
                    for key in blend.keys():
                        props.add(f"blend_{key}")
    ordered: Dict[str, List[str]] = {}
    for slot_type in sorted(slot_types, key=visual_slot_sort_key):
        props = slot_types[slot_type]
        ordered[slot_type] = ["itemAssetName", *sorted(prop for prop in props if prop != "itemAssetName")]
    return ordered


def build_visuals_table(data: Dict[str, Any], search: str = "") -> Dict[str, Any]:
    pmap = data.get("characterVisualsPlayerMap", {})
    slot_types = visual_slot_types_map(pmap)
    columns = [label for label, _ in VISUAL_PLAYER_FIELDS]
    for slot_type, props in slot_types.items():
        for prop in props:
            columns.append(f"slotType: {slot_type}" if prop == "itemAssetName" else f"slotType: {slot_type} {prop.replace('blend_', '')}")

    needle = search.lower().strip()
    rows: List[Dict[str, Any]] = []
    for player_id, player in pmap.items():
        row = {label: 0 for label, _ in VISUAL_PLAYER_FIELDS}
        row["Player ID"] = player_id
        for label, key in VISUAL_PLAYER_FIELDS[1:]:
            row[label] = player.get(key, 0)
        for slot_type, props in slot_types.items():
            values: Dict[str, Any] = {}
            for loadout in player.get("loadouts") or []:
                element = next((item for item in (loadout.get("loadoutElements") or []) if str(item.get("slotType")) == slot_type), None)
                if not element:
                    continue
                values["itemAssetName"] = element.get("itemAssetName", 0)
                for blend in element.get("blends") or []:
                    for key, value in blend.items():
                        values[f"blend_{key}"] = value
            for prop in props:
                column = f"slotType: {slot_type}" if prop == "itemAssetName" else f"slotType: {slot_type} {prop.replace('blend_', '')}"
                row[column] = values.get(prop, 0)
        if needle:
            hay = json.dumps(row, ensure_ascii=False).lower()
            if needle not in hay:
                continue
        rows.append(row)
    return {"columns": columns, "rows": rows}


def ensure_visual_player_loadouts(player: Dict[str, Any]) -> None:
    if player.get("loadouts"):
        return
    player["loadouts"] = [
        {"loadoutType": 0, "loadoutCategory": 5, "loadoutElements": []},
        {"loadoutType": 1, "loadoutCategory": 0, "loadoutElements": []},
    ]


def set_visuals_cell(player: Dict[str, Any], column: str, value: Any) -> None:
    if column in VISUAL_PLAYER_COLUMN_KEYS:
        if column != "Player ID":
            player[VISUAL_PLAYER_COLUMN_KEYS[column]] = value
        return
    match = VISUAL_SLOT_RE.match(column)
    if not match:
        raise HTTPException(400, f"Unknown visuals column: {column}")
    slot_key = match.group(1)
    detail = match.group(2)
    ensure_visual_player_loadouts(player)
    slot_type = int(slot_key) if slot_key.isdigit() else slot_key
    loadout_type = 0 if slot_key.isdigit() and 43 <= int(slot_key) <= 49 else 1
    loadout = next((item for item in player["loadouts"] if item.get("loadoutType") == loadout_type), None)
    if loadout is None:
        loadout = {"loadoutType": loadout_type, "loadoutCategory": 5 if loadout_type == 0 else 0, "loadoutElements": []}
        player["loadouts"].append(loadout)
    element = next((item for item in loadout.get("loadoutElements") or [] if str(item.get("slotType")) == slot_key), None)
    if element is None:
        element = {"slotType": slot_type}
        loadout.setdefault("loadoutElements", []).append(element)
    if detail:
        blends = element.setdefault("blends", [{"barycentricBlend": 0, "baseBlend": 0}])
        blends[0][detail] = 0 if value in (None, "") else value
    else:
        element["itemAssetName"] = value
    loadout["loadoutElements"].sort(key=lambda item: visual_slot_sort_key(str(item.get("slotType", ""))))


def export_visuals_csv(json_path: Path, outdir: Path) -> None:
    data = read_json(json_path)
    pmap = data.get("characterVisualsPlayerMap", {})
    rows_players, rows_loadouts, rows_elements, rows_blends = [], [], [], []
    for player_id, player in pmap.items():
        loadouts = player.get("loadouts") or []
        scalar = {k: v for k, v in player.items() if k != "loadouts"}
        rows_players.append({"visualPlayerId": player_id, **scalar, "loadoutCount": len(loadouts), "loadouts_json": json.dumps(loadouts, ensure_ascii=False)})
        for li, loadout in enumerate(loadouts):
            elements = loadout.get("loadoutElements") or []
            rows_loadouts.append({
                "visualPlayerId": player_id,
                "assetName": player.get("assetName"),
                "loadoutIndex": li,
                "loadoutCategory": loadout.get("loadoutCategory"),
                "loadoutType": loadout.get("loadoutType"),
                "loadoutElementCount": len(elements),
                "loadout_json": json.dumps(loadout, ensure_ascii=False),
            })
            for ei, element in enumerate(elements):
                blends = element.get("blends") or []
                rows_elements.append({
                    "visualPlayerId": player_id,
                    "assetName": player.get("assetName"),
                    "loadoutIndex": li,
                    "elementIndex": ei,
                    "slotType": element.get("slotType"),
                    "itemAssetName": element.get("itemAssetName"),
                    "blendCount": len(blends),
                    "blends_json": json.dumps(blends, ensure_ascii=False),
                    "element_json": json.dumps(element, ensure_ascii=False),
                })
                for bi, blend in enumerate(blends):
                    rows_blends.append({
                        "visualPlayerId": player_id,
                        "assetName": player.get("assetName"),
                        "loadoutIndex": li,
                        "elementIndex": ei,
                        "blendIndex": bi,
                        "baseBlend": blend.get("baseBlend"),
                        "barycentricBlend": blend.get("barycentricBlend"),
                        "blend_json": json.dumps(blend, ensure_ascii=False),
                    })
    csv_specs = {
        "character_visuals_players.csv": rows_players,
        "character_visuals_loadouts.csv": rows_loadouts,
        "character_visuals_loadout_elements.csv": rows_elements,
        "character_visuals_blends.csv": rows_blends,
    }
    for name, rows in csv_specs.items():
        write_csv(outdir / name, rows)


def write_csv(path: Path, rows: List[Dict[str, Any]]) -> None:
    path.parent.mkdir(parents=True, exist_ok=True)
    cols = collect_columns(rows) if rows else []
    with path.open("w", encoding="utf-8", newline="") as f:
        if not cols:
            f.write("")
            return
        w = csv.DictWriter(f, fieldnames=cols, extrasaction="ignore")
        w.writeheader()
        for r in rows:
            w.writerow({k: flatten_for_csv(r.get(k)) for k in cols})


def zip_dir(source: Path, zip_path: Path) -> None:
    if zip_path.exists():
        zip_path.unlink()
    with zipfile.ZipFile(zip_path, "w", zipfile.ZIP_DEFLATED) as z:
        for p in sorted(source.rglob("*")):
            if p.is_file() and p != zip_path:
                z.write(p, p.relative_to(source))


