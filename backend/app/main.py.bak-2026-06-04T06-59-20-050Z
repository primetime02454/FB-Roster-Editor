@app.get("/api/session/{session_id}/save-project.json")
def save_project_json(session_id: str):
    base = sdir(session_id)
    project_path = base / "madden_roster_editor_project.json"
    out = {
        "session": session_metadata(session_id),
        "summary": summary(session_id),
        "tables": {},
        "characterVisuals": None,
    }
    for t in summary(session_id).get("tables", []):
        out["tables"][t["path"]] = read_json(base / "parse" / t["json_file"])
    vpath = base / "visuals" / "character_visuals_nested.json"
