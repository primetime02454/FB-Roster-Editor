def detect_input_format(data: bytes) -> Dict[str, str]:
    if data.startswith(b"FBCHUNKS"):
        return {"container": "fbchunks", "label": "FBCHUNKS wrapped save"}
    return {"container": "tdb2", "label": "Raw roster database"}


def modern_roster_data_start(year: int) -> int:
    return 0x4A if year >= 2021 else 0x3E


def crc32_be(data: bytes) -> int:
    crc_poly_be = 0x04C11DB7
    crc = 0x80000000
    crc_table = [0]
    i = 1
    while i < (1 << 4):
        crc = ((crc << 1) & 0xFFFFFFFF) ^ (crc_poly_be if (crc & 0x80000000) else 0)
        for j in range(i):
            crc_table.append(crc ^ crc_table[j])
        i <<= 1
    crc = 0 ^ 0xFFFFFFFF
    for byte in data:
        crc = (crc ^ (byte << 24)) & 0xFFFFFFFF
        crc = (((crc << 4) & 0xFFFFFFFF) ^ crc_table[(crc >> 28) & 0xF]) & 0xFFFFFFFF
        crc = (((crc << 4) & 0xFFFFFFFF) ^ crc_table[(crc >> 28) & 0xF]) & 0xFFFFFFFF
    return (crc ^ 0xFFFFFFFF) & 0xFFFFFFFF


def extract_roster_payload(input_path: Path, fmt: Dict[str, str], output_path: Path) -> Dict[str, Any]:
    data = input_path.read_bytes()
    if fmt["container"] == "fbchunks":
        if len(data) < 0x18:
            raise HTTPException(400, "FBCHUNKS file is too short.")
        year = int.from_bytes(data[0x16:0x18], "little")
        data_start = modern_roster_data_start(year)
        header = data[:data_start]
        payload = zlib.decompress(data[data_start:])
        output_path.write_bytes(payload)
        return {"year": year, "data_start": data_start, "payload_size": len(payload), "header_path": str((output_path.parent / "wrapper_header.bin").name)}
    output_path.write_bytes(data)
    return {"payload_size": len(data)}


def build_wrapped_roster(raw_data: bytes, header: bytes) -> bytes:
    wrapped_header = bytearray(header)
    compressed = zlib.compress(raw_data, level=9)
    wrapped_header[0x12:0x16] = len(raw_data).to_bytes(4, "little")
    wrapped_header[0x1A:0x1E] = crc32_be(raw_data).to_bytes(4, "little")
    return bytes(wrapped_header) + compressed


