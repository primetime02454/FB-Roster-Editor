@app.post("/api/session/{session_id}/paste")
def paste_grid(session_id: str, req: BulkPasteRequest):
    obj = load_table_obj(session_id, req.table_path)
    records = obj.get("records", [])
    cols = table_columns(session_id, req.table_path, obj)
    if req.start_column not in cols:
        raise HTTPException(400, f"Unknown start_column: {req.start_column}")
    c0 = cols.index(req.start_column)
    changes = []
    for ri, row in enumerate(req.rows):
        target_row = req.start_row_index + ri
        if target_row >= len(records):
            break
        for ci, value in enumerate(row):
            target_col_i = c0 + ci
            if target_col_i >= len(cols):
                break
            col = cols[target_col_i]
            if col.startswith("__") or col in ("TeamName", "Position"):
                continue
            before = records[target_row].get(col)
            records[target_row][col] = value
            changes.append({"row": target_row, "column": col, "before": before, "after": value})
    save_table_obj(session_id, req.table_path, obj)
    return {"ok": True, "changes": len(changes)}


@app.post("/api/session/{session_id}/replace")
def find_replace(session_id: str, req: ReplaceRequest):
    obj = load_table_obj(session_id, req.table_path)
    records = obj.get("records", [])
    columns = req.columns or collect_columns(records)
    replaced = 0
    find = req.find if req.match_case else req.find.lower()
    for rec in records:
        for col in columns:
            if col.startswith("__"):
                continue
            val = rec.get(col)
            if val is None:
                continue
            s = str(val)
            hay = s if req.match_case else s.lower()
            if find in hay:
                rec[col] = s.replace(req.find, req.replace) if req.match_case else replace_case_insensitive(s, req.find, req.replace)
                replaced += 1
    save_table_obj(session_id, req.table_path, obj)
    return {"ok": True, "replacements": replaced}


def replace_case_insensitive(text: str, find: str, repl: str) -> str:
    import re
    return re.sub(re.escape(find), repl, text, flags=re.IGNORECASE)


def sortable_value(value: Any):
    if value is None:
        return (2, "")
    if isinstance(value, (int, float)):
        return (0, value)
    text = str(value).strip()
    if text == "":
        return (2, "")
    try:
        return (0, float(text))
    except Exception:
        return (1, text.lower())


