def sanitize_table_obj(obj: Dict[str, Any]) -> Dict[str, Any]:
    allowed_record_keys = {"_index", "_subRecord", "_compressed_header", "_subrecord_header", "_parent_header", "_main_header"}
    for field in obj.get("field_definitions", []):
        name = field.get("name")
        if name:
            allowed_record_keys.add(str(name))

    sanitized_records = []
    for record in obj.get("records", []):
        sanitized = {}
        for key, value in record.items():
            if key in allowed_record_keys:
                sanitized[key] = value
        sanitized_records.append(sanitized)

    out = dict(obj)
    out["records"] = sanitized_records
    return out


def save_table_obj(session_id: str, table_path: str, obj: Dict[str, Any]) -> None:
    obj = sanitize_table_obj(obj)
    write_json(table_json_path(session_id, table_path), obj)
    get_team_lookup.cache_clear()


def collect_columns(records: Iterable[Dict[str, Any]]) -> List[str]:
    columns: List[str] = []
    seen = set()
    preferred = ["_parent_table_path", "_parent_table_name", "_parent_record_index", "_index", "TeamName", "Position"]
    for col in preferred:
        for rec in records:
            if col in rec and col not in seen:
                columns.append(col); seen.add(col)
                break
    for rec in records:
        for k in rec.keys():
            if k not in seen:
                columns.append(k); seen.add(k)
    return columns


