        "loadouts.csv": ("character_visuals_loadouts.csv", "text/csv"),
        "elements.csv": ("character_visuals_loadout_elements.csv", "text/csv"),
        "blends.csv": ("character_visuals_blends.csv", "text/csv"),
    }
    if name not in allowed:
        raise HTTPException(400, f"Unknown visuals export: {name}")
    fname, media = allowed[name]
    path = sdir(session_id) / "visuals" / fname
    return FileResponse(path, media_type=media, filename=fname)


