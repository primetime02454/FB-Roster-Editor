def enrich_record(session_id: str, table_path: str, rec: Dict[str, Any]) -> Dict[str, Any]:
    out = dict(rec)
    table_name = table_path.split(".")[-1].upper()
    tgid = out.get("TGID")
    if tgid is not None:
        team = get_team_lookup(session_id).get(tgid)
        if team:
            # Add only friendly TeamName by default to keep tables manageable; details are available in TEAM table.
            out.setdefault("TeamName", team.get("TeamName"))
    if table_name == "PLAY" and out.get("PPOS") is None:
        out.setdefault("Position", POSITION_MAP[0])
    elif "PPOS" in out:
        try:
            position_id = int(out["PPOS"])
            out.setdefault("Position", POSITION_MAP.get(position_id, f"Unknown({out['PPOS']})"))
        except Exception:
            out.setdefault("Position", f"Unknown({out.get('PPOS')})")
    return out


def stable_table_columns(session_id: str, table_path: str, obj: Dict[str, Any]) -> List[str]:
    records = obj.get("records", [])
    cols: List[str] = []
    seen = set()
    preferred = ["_parent_table_path", "_parent_table_name", "_parent_record_index", "_index"]
    for col in preferred:
        if any(col in rec for rec in records):
            cols.append(col)
            seen.add(col)

    for field in obj.get("field_definitions", []):
        name = field.get("name")
        if name and name not in seen:
            cols.append(str(name))
            seen.add(str(name))

    for rec in records:
        for key in rec.keys():
            if key not in seen:
                cols.append(key)
                seen.add(key)
    return cols


def table_columns(session_id: str, table_path: str, obj: Dict[str, Any]) -> List[str]:
    cols = stable_table_columns(session_id, table_path, obj)
      # Put team and position next to the IDs when present.
    def insert_after(cols: List[str], target: str, after: str) -> List[str]:
        cols = [c for c in cols if c != target]
        idx = cols.index(after) + 1 if after in cols else len(cols)
        cols.insert(idx, target)
        return cols

    sample_records = obj.get("records", [])[:100]
    enriched = [enrich_record(session_id, table_path, r) for r in sample_records]
    if any("TeamName" in rec for rec in enriched):
        cols = insert_after(cols, "TeamName", "TGID")
    if any("Position" in rec for rec in enriched):
        cols = insert_after(cols, "Position", "PPOS")
    return cols


