def _titleize_constant(name: str) -> str:
    words = str(name).replace("_", " ").lower().split()
    return " ".join(word.upper() if len(word) <= 3 else word.capitalize() for word in words)


@lru_cache(maxsize=1)
def get_amp_define_labels() -> Dict[str, str]:
    if not AMP_DEFINE.exists():
        return {}
    rows = list(csv.reader(AMP_DEFINE.read_text(encoding="utf-8", errors="ignore").splitlines()))
    if len(rows) < 3:
        return {}
    codes = rows[1]
    labels = rows[2]
    out: Dict[str, str] = {}
    for code, label in zip(codes, labels):
        code = (code or "").strip()
        label = (label or "").strip()
        if code and label:
            out[code] = label
    return out


@lru_cache(maxsize=4)
def get_amp_constant_labels(record_file: str) -> Dict[str, str]:
    path = Path(record_file)
    if not path.exists():
        return {}
    pattern = re.compile(r'public const string\s+([A-Z0-9_]+)\s*=\s*"([A-Z0-9a-z]+)";')
    out: Dict[str, str] = {}
    for match in pattern.finditer(path.read_text(encoding="utf-8", errors="ignore")):
        const_name, code = match.groups()
        out[code] = _titleize_constant(const_name)
    return out


