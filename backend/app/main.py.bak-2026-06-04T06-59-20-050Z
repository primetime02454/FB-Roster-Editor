class JsonUpdate(BaseModel):
    value: Any

@app.put("/api/session/{session_id}/table-json/{table_path:path}")
def put_table_json(session_id: str, table_path: str, req: JsonUpdate):
    value = req.value
    if not isinstance(value, dict) or "records" not in value:
        raise HTTPException(400, "Table JSON must be an object with a records array.")
    save_table_obj(session_id, table_path, value)
    return {"ok": True, "records": len(value.get("records", []))}

@app.put("/api/session/{session_id}/visuals-json")
def put_visuals_json(session_id: str, req: JsonUpdate):
    value = req.value
    if not isinstance(value, dict) or "characterVisualsPlayerMap" not in value:
        raise HTTPException(400, "Visuals JSON must contain characterVisualsPlayerMap.")
    save_visuals_obj(session_id, value)
    return {"ok": True, "players": len(value.get("characterVisualsPlayerMap", {}))}


@app.get("/", response_class=HTMLResponse)
def serve_frontend_root():
    if not can_serve_frontend():
        return HTMLResponse(
            "<h1>FB Roster Editor API</h1><p>Frontend build not found. Run <code>npm.cmd --prefix frontend run build</code>.</p>",
            status_code=200,
        )
    return FileResponse(FRONTEND_DIST / "index.html")


@app.get("/{full_path:path}")
def serve_frontend_spa(full_path: str):
    if full_path.startswith("api/"):
        raise HTTPException(404, "Not found")
    if not can_serve_frontend():
        raise HTTPException(404, "Frontend build not found.")
    asset = frontend_asset_path(full_path)
    if asset.exists() and asset.is_file() and str(asset).startswith(str(FRONTEND_DIST.resolve())):
        return FileResponse(asset)
    return FileResponse(FRONTEND_DIST / "index.html")
