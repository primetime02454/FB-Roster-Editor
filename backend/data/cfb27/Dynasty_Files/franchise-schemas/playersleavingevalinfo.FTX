			<attribute name="PercentageAppt4Spline" idx="10" type="Spline" />
			<attribute name="PercentageAppt5Spline" idx="11" type="Spline" />
			<attribute name="ReturnChanceLegacySpline" idx="12" type="Spline" />
			<attribute name="SuperBowlSpline" idx="13" type="Spline" />
			<attribute name="YearsProModSpline" idx="14" type="Spline" />
		</schema>
	</schemas>
</FranTkData>