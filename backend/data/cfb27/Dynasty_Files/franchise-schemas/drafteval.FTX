			<attribute name="SelectPlayerOnDraftBoard" idx="32" type="DraftEval_SelectPlayerOnDraftBoard" guid="6708560-1941642" final="true" default="DraftPlayer draftPlayer = new DraftPlayer;&#xD;&#xA;&#xD;&#xA;// Get current pick info&#xD;&#xA;DraftInfo draftInfo = DraftManager.DraftInfo;&#xD;&#xA;&#xD;&#xA;int MAX_ROUND = 7;&#xD;&#xA;&#xD;&#xA;// During the last Y rounds we choose the player at the top of the Draft Board.&#xD;&#xA;if (draftInfo.CurrentRoundIndex + 1 &gt; MAX_ROUND - LastRoundsCount)&#xD;&#xA;{&#xD;&#xA;   draftPlayer = GetTopOfTheDraftBoardPlayer(team);&#xD;&#xA;}&#xD;&#xA;else&#xD;&#xA;{&#xD;&#xA;  draftPlayer = GetUndraftedPlayer(team, true);&#xD;&#xA;&#xD;&#xA;  if (draftPlayer == null)&#xD;&#xA;  {&#xD;&#xA;    draftPlayer = GetOldestDraftedPlayer(team);&#xD;&#xA;  }&#xD;&#xA;&#xD;&#xA;  if (draftPlayer == null)&#xD;&#xA;  {&#xD;&#xA;    draftPlayer = GetUndraftedPlayer(team, false);&#xD;&#xA;  }&#xD;&#xA;        &#xD;&#xA;  if (draftPlayer == null)&#xD;&#xA;  {&#xD;&#xA;    draftPlayer = GetPlayerPerUnreachedMaxPosition(team, false);&#xD;&#xA;  }&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;draftPlayer;" />
