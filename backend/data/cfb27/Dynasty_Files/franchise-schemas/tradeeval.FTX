			<attribute name="GetTradeFeedbackText" idx="38" type="TradeEval_GetTradeFeedbackText" guid="6495411-1923408" final="true" default="&#xD;&#xA;if (value &gt; 80 &amp;&amp; isPlayer == true)&#xD;&#xA;{&#xD;&#xA;    if (developmentValue &gt;= 86)&#xD;&#xA;    {&#xD;&#xA;      TradeFeedbackText.Response1 = TradeFeedbackGoodDev;&#xD;&#xA;      TradeFeedbackText.Response2 = TradeFeedbackGoodDev;&#xD;&#xA;    }&#xD;&#xA;   else if (developmentValue &lt;= 49)&#xD;&#xA;    {&#xD;&#xA;      TradeFeedbackText.Response1 = TradeFeedbackBadDev;&#xD;&#xA;      TradeFeedbackText.Response2 = TradeFeedbackBadDev;&#xD;&#xA;    }&#xD;&#xA;    else if (teamOverallValue &gt;= 85)&#xD;&#xA;    {&#xD;&#xA;      TradeFeedbackText.Response1 = TradeFeedbackGoodOVR;&#xD;&#xA;      TradeFeedbackText.Response2 = TradeFeedbackGoodOVR;&#xD;&#xA;    }&#xD;&#xA;   else if (teamOverallValue &lt;= 70)&#xD;&#xA;   {&#xD;&#xA;      TradeFeedbackText.Response1 = TradeFeedbackBadOVR;&#xD;&#xA;      TradeFeedbackText.Response2 = TradeFeedbackBadOVR;&#xD;&#xA;   }&#xD;&#xA;   else if (tradePhilosophyValue &gt;= 115)&#xD;&#xA;   {&#xD;&#xA;      TradeFeedbackText.Response1 = TradeFeedbackPhilPass;&#xD;&#xA;      TradeFeedbackText.Response2 = TradeFeedbackPhilPass;&#xD;&#xA;   }&#xD;&#xA;   else if (tradePhilosophyValue &lt; 90)&#xD;&#xA;   {&#xD;&#xA;      TradeFeedbackText.Response1 = TradeFeedbackPhilFail;&#xD;&#xA;      TradeFeedbackText.Response2 = TradeFeedbackPhilFail;&#xD;&#xA;   }&#xD;&#xA;   else if (premiumValue &gt; 199)&#xD;&#xA;   {&#xD;&#xA;      TradeFeedbackText.Response1 = TradeFeedbackGreatPremium;&#xD;&#xA;      TradeFeedbackText.Response2 = TradeFeedbackGreatPremium;&#xD;&#xA;   }&#xD;&#xA;   else if (premiumValue &lt; 149)&#xD;&#xA;   {&#xD;&#xA;      TradeFeedbackText.Response1 = TradeFeedbackDecentPremium;&#xD;&#xA;      TradeFeedbackText.Response2 = TradeFeedbackDecentPremium;&#xD;&#xA;    }&#xD;&#xA;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;else if (value &lt; 80 &amp;&amp; isPlayer == true)&#xD;&#xA;    {&#xD;&#xA;      TradeFeedbackText.Response1 = TradeFeedbackBadValue;&#xD;&#xA;    }&#xD;&#xA;&#xD;&#xA;else if ( value &gt; 599 &amp;&amp; isPlayer == false)&#xD;&#xA;    {&#xD;&#xA;      TradeFeedbackText.Response1 = TradeFeedbackGoodDraftPick;&#xD;&#xA;    }&#xD;&#xA;else if (value &gt; 229 &amp;&amp; isPlayer == false)&#xD;&#xA;    {&#xD;&#xA;      TradeFeedbackText.Response1 = TradeFeedbackDecentDraftPick;&#xD;&#xA;    }&#xD;&#xA;else if (value &lt; 49 &amp;&amp; isPlayer == false)&#xD;&#xA;    {&#xD;&#xA;      TradeFeedbackText.Response1 = TradeFeedbackBadDraftPick;&#xD;&#xA;    }&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;TradeFeedbackText;" />
