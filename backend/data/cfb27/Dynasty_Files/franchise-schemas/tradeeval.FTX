			<attribute name="CreateTradeAcceptOfferRequest" idx="25" type="TradeEval_CreateTradeAcceptOfferRequest" guid="6495411-1923325" final="true" default="TradeAcceptOfferRequest request = CreateTradeAcceptOfferRecord();&#xD;&#xA;&#xD;&#xA;// Set the request settings.&#xD;&#xA;request.IsResponseRequired = true;&#xD;&#xA;request.IsConnectionRequired = false;&#xD;&#xA;request.IsBlocking = false;&#xD;&#xA;&#xD;&#xA;// Set the request data.&#xD;&#xA;request.TradeNegotiationManagerRef = TradeNegotiationManagerRef;&#xD;&#xA;request.Negotiation = negotiation;&#xD;&#xA;request.RequestData = negotiation;&#xD;&#xA;&#xD;&#xA;// Set the response array.&#xD;&#xA;request.ResponseForms = new ResponseForm[3];&#xD;&#xA;request.ResponseForms.Append(TradeAcceptRequest_AcceptResponse);&#xD;&#xA;request.ResponseForms.Append(TradeAcceptRequest_DeclineResponse);&#xD;&#xA;if (IsDelegateResponseAvailable) {&#xD;&#xA;    request.ResponseForms.Append(TradeAcceptRequest_DelegateResponse);&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;// Set the response records.&#xD;&#xA;request.AcceptResponse = TradeAcceptRequest_AcceptResponse;&#xD;&#xA;request.DeclineResponse = TradeAcceptRequest_DeclineResponse;&#xD;&#xA;request.DelegateResponse = TradeAcceptRequest_DelegateResponse;&#xD;&#xA;request.DefaultResponse = TradeAcceptRequest_DelegateResponse;&#xD;&#xA;&#xD;&#xA;request;&#xD;&#xA;" />
