			<attribute name="CreateMakeOfferRequest" idx="20" type="TradeEval_CreateMakeOfferRequest" guid="6495411-1923303" final="true" default="TradeMakeOfferRequest request = CreateTradeMakeOfferRecord();&#xD;&#xA;&#xD;&#xA;// Append this team to the pending team list.&#xD;&#xA;negotiation.PendingTeamListB.Append(teamB);&#xD;&#xA;&#xD;&#xA;// Set the request settings.&#xD;&#xA;request.IsResponseRequired = false;&#xD;&#xA;request.IsConnectionRequired = false;&#xD;&#xA;request.IsBlocking = false;&#xD;&#xA;&#xD;&#xA;// Set the request data.&#xD;&#xA;request.TeamB = teamB;&#xD;&#xA;request.PackageB = null;&#xD;&#xA;request.Negotiation = negotiation;&#xD;&#xA;request.TradeNegotiationManagerRef = TradeNegotiationManagerRef;&#xD;&#xA;request.RequestData = negotiation;&#xD;&#xA;&#xD;&#xA;// Set the response forms.&#xD;&#xA;request.ResponseForms = new ResponseForm[3];&#xD;&#xA;request.ResponseForms.Append(TradeRequest_OfferResponse);&#xD;&#xA;request.ResponseForms.Append(TradeRequest_IgnoreResponse);&#xD;&#xA;if (IsDelegateResponseAvailable)&#xD;&#xA;{&#xD;&#xA;    request.ResponseForms.Append(TradeRequest_DelegateResponse);&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;request.OfferResponse = TradeRequest_OfferResponse;&#xD;&#xA;request.DelegateResponse = TradeRequest_DelegateResponse;&#xD;&#xA;request.DefaultResponse = TradeRequest_DelegateResponse;&#xD;&#xA;&#xD;&#xA;// Add the request to the negotiation.&#xD;&#xA;if (negotiation.PendingTeamRequestListB != null)&#xD;&#xA;{&#xD;&#xA;    negotiation.PendingTeamRequestListB.Append(request);&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;request;&#xD;&#xA;" />
