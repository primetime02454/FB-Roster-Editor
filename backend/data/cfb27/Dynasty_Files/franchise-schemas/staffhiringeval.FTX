			<attribute name="IssueCreateOffersRequest" idx="65" type="StaffHiringEval_IssueCreateOffersRequest" guid="6495417-1924035" final="true" default="if (Franchise.SeasonInfo.CurrentYear &lt; (Franchise.SeasonInfo.MaxYears - 1))&#xD;&#xA;{&#xD;&#xA;//Build and Issue Request&#xD;&#xA;CreateCoachContractOffersRequest request = CreateCoachContractOfferRequest();&#xD;&#xA;&#xD;&#xA;request.Team = team;&#xD;&#xA;request.RequestData = team;&#xD;&#xA;request.StaffHiringEval = this;&#xD;&#xA;request.IsResponseRequired = false;&#xD;&#xA;&#xD;&#xA;request.ResponseForms = new ResponseForm[2];&#xD;&#xA;request.ResponseForms.Append( CreateCoachOffers_MakeOffersResponse );&#xD;&#xA;if (IsDelegateResponseAvailable)&#xD;&#xA;{&#xD;&#xA;    request.ResponseForms.Append( CreateCoachOffers_DelegateResponse );&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;request.DefaultResponse     = CreateCoachOffers_DelegateResponse;&#xD;&#xA;&#xD;&#xA;TeamRequestManager.IssueToOwner(team, request);&#xD;&#xA;}" />
			<attribute name="IssueCreateResignOffersRequest" idx="66" type="StaffHiringEval_IssueCreateResignOffersRequest" guid="6495417-1924059" final="true" default="if (Franchise.SeasonInfo.CurrentYear &lt; (Franchise.SeasonInfo.MaxYears - 1))&#xD;&#xA;{&#xD;&#xA;//Build and Issue Request&#xD;&#xA;CreateCoachResignContractOffersRequest request = CreateCoachResignContractOfferRequest();&#xD;&#xA;&#xD;&#xA;request.Team = team;&#xD;&#xA;request.Coach = coach;&#xD;&#xA;request.ContractViewType = ContractViewType.Renew;&#xD;&#xA;request.CoachPosition = coach.Position;&#xD;&#xA;request.RequestData = coach;&#xD;&#xA;request.StaffHiringEvalRef = this;&#xD;&#xA;request.IsResponseRequired = false;&#xD;&#xA;request.IsPersistent = true;&#xD;&#xA;request.ResponseForms = new ResponseForm[1];&#xD;&#xA;request.ResponseForms.Append( CreateCoachResignOffers_MakeOffersResponse );&#xD;&#xA;request.DefaultResponse     = CreateCoachResignOffers_MakeOffersResponse;&#xD;&#xA;&#xD;&#xA;team.IsReSigning = true;&#xD;&#xA;&#xD;&#xA;request.Issue(coach);&#xD;&#xA;}" />
			<attribute name="IssueEnterCoachCarouselRequest" idx="67" type="StaffHiringEval_IssueEnterCoachCarouselRequest" guid="6495417-2079340" final="true" default="OfferManagementRequest request = new OfferManagementRequest;&#xD;&#xA;request.IsResponseRequired = false;&#xD;&#xA;request.IsConnectionRequired = false;&#xD;&#xA;request.IsBlocking = false;&#xD;&#xA;request.IsPersistent = true;&#xD;&#xA;request.Priority = 3;&#xD;&#xA;&#xD;&#xA;// Create the response forms.&#xD;&#xA;request.ResponseForms = new ResponseForm[1];&#xD;&#xA;{&#xD;&#xA;    request.ResponseForms.Append(EnterCoachCarouselResponse);&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;request.Issue(userEntity);" />
			<attribute name="IssueEvaluateCoachOffersRequest" idx="68" type="StaffHiringEval_IssueEvaluateCoachOffersRequest" guid="6495417-1923950" final="true" default="//Build and Issue Request&#xD;&#xA;EvaluateCoachOffersRequest request = CreateEvaluateCoachOffersRequest();&#xD;&#xA;&#xD;&#xA;request.OfferList = offerList;&#xD;&#xA;request.RequestData = offerList;&#xD;&#xA;request.coach = staffPerson;&#xD;&#xA;request.StaffHiringEvalRef = this;&#xD;&#xA;request.IsResponseRequired = true;&#xD;&#xA;request.isReSigning = isReSigning;&#xD;&#xA;request.reSigningTeam = reSigningTeam;&#xD;&#xA;&#xD;&#xA;request.ResponseForms = new ResponseForm[2];&#xD;&#xA;request.ResponseForms.Append( EvaluateOffers_SelectOfferCommand );&#xD;&#xA;request.ResponseForms.Append( EvaluateOffers_IgnoreResponse );&#xD;&#xA;&#xD;&#xA;request.SelectOfferResponse = EvaluateOffers_SelectOfferCommand;&#xD;&#xA;request.IgnoreResponse      = EvaluateOffers_IgnoreResponse;&#xD;&#xA;request.DefaultResponse     = EvaluateOffers_DelegateResponse;&#xD;&#xA;request.DelegateResponse    = EvaluateOffers_DelegateResponse;&#xD;&#xA;&#xD;&#xA;request.Issue(staffPerson);" />
