			<attribute name="IssueImmediateEvaluateOffer" idx="70" type="StaffHiringEval_IssueImmediateEvaluateOffer" guid="6495417-1924086" final="true" default="StaffHiring_FilterOffersForCoach FilterOffersForStaffPersonView = new StaffHiring_FilterOffersForCoach;&#xD;&#xA;StaffPersonContractOffer[] staffPersonOfferList = null;&#xD;&#xA;&#xD;&#xA;if(OutstandingStaffPersonOffersList != null)&#xD;&#xA;{&#xD;&#xA;  FilterOffersForStaffPersonView.CoachRef = staffPerson;&#xD;&#xA;  FilterOffersForStaffPersonView.Subjects = OutstandingStaffPersonOffersList;&#xD;&#xA;  FilterOffersForStaffPersonView.Update();&#xD;&#xA;  staffPersonOfferList = FilterOffersForStaffPersonView.Results;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;//Build and Issue Request&#xD;&#xA;if(staffPersonOfferList!= null)&#xD;&#xA;{&#xD;&#xA;  if(staffPersonOfferList.Population() &gt; 0)&#xD;&#xA;  {&#xD;&#xA;    IssueEvaluateCoachOffersRequest(staffPerson, staffPersonOfferList, isResigning, reSigningTeam);&#xD;&#xA;  }&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;FilterOffersForStaffPersonView.Clear();&#xD;&#xA;FilterOffersForStaffPersonView= null;" />
