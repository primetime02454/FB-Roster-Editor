			<attribute name="GetCoachContractOfferLength" idx="38" type="StaffHiringEval_GetCoachContractOfferLength" guid="6495417-1923924" final="true" default="int length = 3;&#xD;&#xA;length;&#xD;&#xA;" />
			<attribute name="GetCoachContractOfferSalary" idx="39" type="StaffHiringEval_GetCoachContractOfferSalary" guid="6495417-1923919" final="true" default="StaffHiringPhilosophy philosophy = team.Philosophy.StaffHiringPhilosophyRef;&#xD;&#xA;&#xD;&#xA;int levelMod = philosophy.OfferedSalaryLevelSpline.CalculateY(coach.Level);&#xD;&#xA;&#xD;&#xA;int expectedsalary = ( GetExpectedCoachSalary(coach) * levelMod )/ 100;&#xD;&#xA;&#xD;&#xA;expectedsalary;&#xD;&#xA;" />
			<attribute name="GetCoachInterest" idx="40" type="StaffHiringEval_GetCoachInterest" guid="6495417-1923929" final="true" default="// setup the rating point scale&#xD;&#xA;int great = 100;&#xD;&#xA;int good  = 80;&#xD;&#xA;int ok    = 60;&#xD;&#xA;int poor  = 40;&#xD;&#xA;&#xD;&#xA;// set the xpMod&#xD;&#xA;int salaryMod = 0;&#xD;&#xA;if (expectedSalary &gt; 0)&#xD;&#xA;{&#xD;&#xA;    int salaryOfferRatio = 0;&#xD;&#xA;    salaryMod = SalaryOfferRatioToCoachInterestSpline.CalculateY(salaryOfferRatio);&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;// set the schemeMod&#xD;&#xA;int schemeMod = ok;&#xD;&#xA;Coach coach = contractOffer.StaffPerson;&#xD;&#xA;Team team   = contractOffer.Team;&#xD;&#xA;&#xD;&#xA;if(coach.DefensiveScheme != null &amp;&amp; coach.OffensiveScheme != null)&#xD;&#xA;{&#xD;&#xA;  if ((coach.DefensiveScheme.Value == team.DefaultDefensiveScheme) || (coach.OffensiveScheme.Value == team.DefaultOffensiveScheme))&#xD;&#xA;  {&#xD;&#xA;        schemeMod = great;&#xD;&#xA;  }&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;// set the popularityMod&#xD;&#xA;int popularityMod = 0;&#xD;&#xA;int popularity = contractOffer.Team.OverallPopularity;&#xD;&#xA;if (popularity &gt; 80)&#xD;&#xA;{&#xD;&#xA;    popularityMod = great;&#xD;&#xA;}&#xD;&#xA;else if (popularity &gt; 60)&#xD;&#xA;{&#xD;&#xA;    popularityMod = good;&#xD;&#xA;}&#xD;&#xA;else if (popularity &gt; 40)&#xD;&#xA;{&#xD;&#xA;    popularityMod = ok;&#xD;&#xA;}&#xD;&#xA;else&#xD;&#xA;{&#xD;&#xA;    popularityMod = poor;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;// set the historyMod&#xD;&#xA;int historyMod = 0;&#xD;&#xA;int history = contractOffer.Team.TeamHistory;&#xD;&#xA;if (history &gt; 90)&#xD;&#xA;{&#xD;&#xA;    historyMod = great;&#xD;&#xA;}&#xD;&#xA;else if (history &gt; 80)&#xD;&#xA;{&#xD;&#xA;    historyMod = good;&#xD;&#xA;}&#xD;&#xA;else if (history &gt; 60)&#xD;&#xA;{&#xD;&#xA;    historyMod = ok;&#xD;&#xA;}&#xD;&#xA;else&#xD;&#xA;{&#xD;&#xA;    historyMod = poor;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;// set the successMod&#xD;&#xA;int successMod = 0;&#xD;&#xA;int success = contractOffer.Team.CurSeasonLeagStanding;&#xD;&#xA;if (success &lt;= 10)&#xD;&#xA;{&#xD;&#xA;    successMod = great;&#xD;&#xA;}&#xD;&#xA;else if (success &lt;= 16)&#xD;&#xA;{&#xD;&#xA;    successMod = good;&#xD;&#xA;}&#xD;&#xA;else if (success &lt;= 24)&#xD;&#xA;{&#xD;&#xA;    successMod = ok;&#xD;&#xA;}&#xD;&#xA;else&#xD;&#xA;{&#xD;&#xA;    successMod = poor;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;// set the talentMod&#xD;&#xA;int talentMod = 0;&#xD;&#xA;int talent = contractOffer.Team.TEAM_RATINGOVR;&#xD;&#xA;if (talent &gt; 80)&#xD;&#xA;{&#xD;&#xA;    talentMod = great;&#xD;&#xA;}&#xD;&#xA;else if (talent &gt; 75)&#xD;&#xA;{&#xD;&#xA;    talentMod = good;&#xD;&#xA;}&#xD;&#xA;else if (talent &gt; 70)&#xD;&#xA;{&#xD;&#xA;    talentMod = ok;&#xD;&#xA;}&#xD;&#xA;else&#xD;&#xA;{&#xD;&#xA;    talentMod = poor;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;// set the philosophyMod&#xD;&#xA;int  philosophyMod = ok;&#xD;&#xA;&#xD;&#xA;if (coach.TeamBuilding == team.TeamBuilding)&#xD;&#xA;{&#xD;&#xA;     philosophyMod = great;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;int interest = (15 * salaryMod + 5 * schemeMod + 3 * philosophyMod + 5 * historyMod + 5 * popularityMod + 5 * successMod + 10 * talentMod) / 48;&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;interest;" />
			<attribute name="GetCoachRating" idx="41" type="StaffHiringEval_GetCoachRating" guid="6495417-1923888" final="true" />
			<attribute name="GetExpectedCoachSalary" idx="42" type="StaffHiringEval_GetExpectedCoachSalary" guid="6495417-1923894" final="true" default="int legacyScoreMod = ExpectedSalaryLegacySpline.CalculateY(coach.LegacyScore);&#xD;&#xA;int levelMod       = ExpectedCoachSalaryLevelSpline.CalculateY(coach.Level);&#xD;&#xA;&#xD;&#xA;int expectedSalary = (levelMod * legacyScoreMod) / 100;&#xD;&#xA;&#xD;&#xA;expectedSalary;" />
			<attribute name="GetExpectedScoutSalary" idx="43" type="StaffHiringEval_GetExpectedScoutSalary" guid="6495417-1923974" final="true" default="int expectedSalary = ExpectedScoutSalaryLevelSpline.CalculateY(scout.Level);&#xD;&#xA;&#xD;&#xA;expectedSalary;" />
			<attribute name="GetExpectedTrainerSalary" idx="44" type="StaffHiringEval_GetExpectedTrainerSalary" guid="6495417-1923978" final="true" default="int expectedSalary = ExpectedTrainerSalaryLevelSpline.CalculateY(trainer.Level);&#xD;&#xA;&#xD;&#xA;expectedSalary;" />
			<attribute name="GetIsCoachToBeRehired" idx="45" type="StaffHiringEval_GetIsCoachToBeRehired" guid="6495417-1924112" />
			<attribute name="GetScoutContractOfferLength" idx="46" type="StaffHiringEval_GetScoutContractOfferLength" guid="6495417-1923992" final="true" default="int length = 3;&#xD;&#xA;length;&#xD;&#xA;" />
			<attribute name="GetScoutContractOfferSalary" idx="47" type="StaffHiringEval_GetScoutContractOfferSalary" guid="6495417-1923982" final="true" default="StaffHiringPhilosophy philosophy = team.Philosophy.StaffHiringPhilosophyRef;&#xD;&#xA;&#xD;&#xA;int levelMod = philosophy.OfferedSalaryLevelSpline.CalculateY(scout.Level);&#xD;&#xA;&#xD;&#xA;int expectedsalary = ( GetExpectedScoutSalary(scout) * levelMod )/ 100;&#xD;&#xA;&#xD;&#xA;expectedsalary;&#xD;&#xA;" />
			<attribute name="GetScoutInterest" idx="48" type="StaffHiringEval_GetScoutInterest" guid="6495417-1924003" final="true" default="// setup the rating point scale&#xD;&#xA;int great = 100;&#xD;&#xA;int good  = 80;&#xD;&#xA;int ok    = 60;&#xD;&#xA;int poor  = 40;&#xD;&#xA;&#xD;&#xA;Team team = contractOffer.Team;&#xD;&#xA;&#xD;&#xA;// set the offerMod    &#xD;&#xA;int offerMod = 0;&#xD;&#xA;if (expectedXP &gt; 0)&#xD;&#xA;{&#xD;&#xA;    int xpOfferRatio = contractOffer.ExperiencePoints * 100 / expectedXP;&#xD;&#xA;    if (xpOfferRatio &gt;= 110)&#xD;&#xA;    {&#xD;&#xA;        offerMod = great;&#xD;&#xA;    }&#xD;&#xA;    else if (xpOfferRatio &lt; 100)&#xD;&#xA;    {&#xD;&#xA;        offerMod = ok;&#xD;&#xA;    }&#xD;&#xA;    else&#xD;&#xA;    {&#xD;&#xA;        offerMod = good;&#xD;&#xA;    }&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;// set the popularityMod&#xD;&#xA;int popularityMod = 0;&#xD;&#xA;int popularity = contractOffer.Team.OverallPopularity;&#xD;&#xA;if (popularity &gt; 80)&#xD;&#xA;{&#xD;&#xA;    popularityMod = great;&#xD;&#xA;}&#xD;&#xA;else if (popularity &gt; 60)&#xD;&#xA;{&#xD;&#xA;    popularityMod = good;&#xD;&#xA;}&#xD;&#xA;else if (popularity &gt; 40)&#xD;&#xA;{&#xD;&#xA;    popularityMod = ok;&#xD;&#xA;}&#xD;&#xA;else&#xD;&#xA;{&#xD;&#xA;    popularityMod = poor;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;// set the historyMod&#xD;&#xA;int historyMod = 0;&#xD;&#xA;int history = contractOffer.Team.TeamHistory;&#xD;&#xA;if (history &gt; 90)&#xD;&#xA;{&#xD;&#xA;    historyMod = great;&#xD;&#xA;}&#xD;&#xA;else if (history &gt; 80)&#xD;&#xA;{&#xD;&#xA;    historyMod = good;&#xD;&#xA;}&#xD;&#xA;else if (history &gt; 60)&#xD;&#xA;{&#xD;&#xA;    historyMod = ok;&#xD;&#xA;}&#xD;&#xA;else&#xD;&#xA;{&#xD;&#xA;    historyMod = poor;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;// set the successMod&#xD;&#xA;int successMod = 0;&#xD;&#xA;int success = contractOffer.Team.CurSeasonLeagStanding;&#xD;&#xA;if (success &lt;= 10)&#xD;&#xA;{&#xD;&#xA;    successMod = great;&#xD;&#xA;}&#xD;&#xA;else if (success &lt;= 16)&#xD;&#xA;{&#xD;&#xA;    successMod = good;&#xD;&#xA;}&#xD;&#xA;else if (success &lt;= 24)&#xD;&#xA;{&#xD;&#xA;    successMod = ok;&#xD;&#xA;}&#xD;&#xA;else&#xD;&#xA;{&#xD;&#xA;    successMod = poor;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;// set the talentMod&#xD;&#xA;int talentMod = 0;&#xD;&#xA;int talent = contractOffer.Team.TEAM_RATINGOVR;&#xD;&#xA;if (talent &gt; 80)&#xD;&#xA;{&#xD;&#xA;    talentMod = great;&#xD;&#xA;}&#xD;&#xA;else if (talent &gt; 75)&#xD;&#xA;{&#xD;&#xA;    talentMod = good;&#xD;&#xA;}&#xD;&#xA;else if (talent &gt; 70)&#xD;&#xA;{&#xD;&#xA;    talentMod = ok;&#xD;&#xA;}&#xD;&#xA;else&#xD;&#xA;{&#xD;&#xA;    talentMod = poor;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;int interest = ((20 * offerMod) + (5 * historyMod) + (5 * popularityMod) + (5 * successMod) + (10 * talentMod)) / 45;&#xD;&#xA;&#xD;&#xA;interest;" />
			<attribute name="GetScoutRating" idx="49" type="StaffHiringEval_GetScoutRating" guid="6495417-1923963" final="true" default="StaffHiringPhilosophy philosophy = team.Philosophy.StaffHiringPhilosophyRef;&#xD;&#xA;&#xD;&#xA;int levelMod = philosophy.RateCoachLevelSpline.CalculateY(scout.Level);&#xD;&#xA;int positionMatchMod = 0;&#xD;&#xA;&#xD;&#xA;if(positionMatch == ScoutPositionMatch.NoMatch)&#xD;&#xA;{&#xD;&#xA; positionMatchMod = philosophy.ScoutNoMatchBoost;&#xD;&#xA;}&#xD;&#xA;else if(positionMatch == ScoutPositionMatch.Position)&#xD;&#xA;{&#xD;&#xA; positionMatchMod = philosophy.ScoutPositionBoost;&#xD;&#xA;}&#xD;&#xA;else if(positionMatch == ScoutPositionMatch.PositionGroup)&#xD;&#xA;{&#xD;&#xA; positionMatchMod = philosophy.ScoutPositionGroupBoost;&#xD;&#xA;}&#xD;&#xA;else if(positionMatch == ScoutPositionMatch.TeamSide)&#xD;&#xA;{&#xD;&#xA; positionMatchMod = philosophy.ScoutTeamSideBoost;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;int rating = (levelMod * positionMatchMod) / 2;&#xD;&#xA;&#xD;&#xA;rating;" />
			<attribute name="GetTrainerContractOfferLength" idx="50" type="StaffHiringEval_GetTrainerContractOfferLength" guid="6495417-1923997" final="true" default="int length = 3;&#xD;&#xA;length;&#xD;&#xA;" />
			<attribute name="GetTrainerContractOfferSalary" idx="51" type="StaffHiringEval_GetTrainerContractOfferSalary" guid="6495417-1923987" final="true" default="StaffHiringPhilosophy philosophy = team.Philosophy.StaffHiringPhilosophyRef;&#xD;&#xA;&#xD;&#xA;int levelMod = philosophy.OfferedSalaryLevelSpline.CalculateY(trainer.Level);&#xD;&#xA;&#xD;&#xA;int expectedsalary = ( GetExpectedTrainerSalary(trainer) * levelMod )/ 100;&#xD;&#xA;&#xD;&#xA;expectedsalary;&#xD;&#xA;" />
			<attribute name="GetTrainerInterest" idx="52" type="StaffHiringEval_GetTrainerInterest" guid="6495417-1924008" final="true" default="// setup the rating point scale&#xD;&#xA;int great = 100;&#xD;&#xA;int good  = 80;&#xD;&#xA;int ok    = 60;&#xD;&#xA;int poor  = 40;&#xD;&#xA;&#xD;&#xA;Team team = contractOffer.Team;&#xD;&#xA;&#xD;&#xA;// set the offerMod    &#xD;&#xA;int offerMod = 0;&#xD;&#xA;if (expectedXP &gt; 0)&#xD;&#xA;{&#xD;&#xA;    int xpOfferRatio = contractOffer.ExperiencePoints * 100 / expectedXP;&#xD;&#xA;    if (xpOfferRatio &gt;= 110)&#xD;&#xA;    {&#xD;&#xA;        offerMod = great;&#xD;&#xA;    }&#xD;&#xA;    else if (xpOfferRatio &lt; 100)&#xD;&#xA;    {&#xD;&#xA;        offerMod = ok;&#xD;&#xA;    }&#xD;&#xA;    else&#xD;&#xA;    {&#xD;&#xA;        offerMod = good;&#xD;&#xA;    }&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;// set the popularityMod&#xD;&#xA;int popularityMod = 0;&#xD;&#xA;int popularity = contractOffer.Team.OverallPopularity;&#xD;&#xA;if (popularity &gt; 80)&#xD;&#xA;{&#xD;&#xA;    popularityMod = great;&#xD;&#xA;}&#xD;&#xA;else if (popularity &gt; 60)&#xD;&#xA;{&#xD;&#xA;    popularityMod = good;&#xD;&#xA;}&#xD;&#xA;else if (popularity &gt; 40)&#xD;&#xA;{&#xD;&#xA;    popularityMod = ok;&#xD;&#xA;}&#xD;&#xA;else&#xD;&#xA;{&#xD;&#xA;    popularityMod = poor;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;// set the historyMod&#xD;&#xA;int historyMod = 0;&#xD;&#xA;int history = contractOffer.Team.TeamHistory;&#xD;&#xA;if (history &gt; 90)&#xD;&#xA;{&#xD;&#xA;    historyMod = great;&#xD;&#xA;}&#xD;&#xA;else if (history &gt; 80)&#xD;&#xA;{&#xD;&#xA;    historyMod = good;&#xD;&#xA;}&#xD;&#xA;else if (history &gt; 60)&#xD;&#xA;{&#xD;&#xA;    historyMod = ok;&#xD;&#xA;}&#xD;&#xA;else&#xD;&#xA;{&#xD;&#xA;    historyMod = poor;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;// set the successMod&#xD;&#xA;int successMod = 0;&#xD;&#xA;int success = contractOffer.Team.CurSeasonLeagStanding;&#xD;&#xA;if (success &lt;= 10)&#xD;&#xA;{&#xD;&#xA;    successMod = great;&#xD;&#xA;}&#xD;&#xA;else if (success &lt;= 16)&#xD;&#xA;{&#xD;&#xA;    successMod = good;&#xD;&#xA;}&#xD;&#xA;else if (success &lt;= 24)&#xD;&#xA;{&#xD;&#xA;    successMod = ok;&#xD;&#xA;}&#xD;&#xA;else&#xD;&#xA;{&#xD;&#xA;    successMod = poor;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;// set the talentMod&#xD;&#xA;int talentMod = 0;&#xD;&#xA;int talent = contractOffer.Team.TEAM_RATINGOVR;&#xD;&#xA;if (talent &gt; 80)&#xD;&#xA;{&#xD;&#xA;    talentMod = great;&#xD;&#xA;}&#xD;&#xA;else if (talent &gt; 75)&#xD;&#xA;{&#xD;&#xA;    talentMod = good;&#xD;&#xA;}&#xD;&#xA;else if (talent &gt; 70)&#xD;&#xA;{&#xD;&#xA;    talentMod = ok;&#xD;&#xA;}&#xD;&#xA;else&#xD;&#xA;{&#xD;&#xA;    talentMod = poor;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;int interest = ((20 * offerMod) + (5 * historyMod) + (5 * popularityMod) + (5 * successMod) + (10 * talentMod)) / 45;&#xD;&#xA;&#xD;&#xA;interest;" />
			<attribute name="GetTrainerRating" idx="53" type="StaffHiringEval_GetTrainerRating" guid="6495417-1923969" final="true" default="StaffHiringPhilosophy philosophy = team.Philosophy.StaffHiringPhilosophyRef;&#xD;&#xA;&#xD;&#xA;int levelMod = philosophy.RateCoachLevelSpline.CalculateY(trainer.Level);&#xD;&#xA;int ageMod = philosophy.CoachAgeSpline.CalculateY(trainer.Age); &#xD;&#xA;&#xD;&#xA;int rating = (levelMod + ageMod) / 2;&#xD;&#xA;&#xD;&#xA;rating;&#xD;&#xA;" />
