			<attribute name="PreferCurrentStaffToHighestRatedStaff" idx="81" type="StaffHiringEval_PreferCurrentStaffToHighestRatedStaff" guid="6495417-1924075" final="true" default="StaffHiringPhilosophy philosophy = team.Philosophy.StaffHiringPhilosophyRef;&#xD;&#xA;&#xD;&#xA;int highestRatingToCurrentRatingPercentage = (highestRatedStaffRating * 100) / currentStaffRating;&#xD;&#xA;&#xD;&#xA;bool prefercurrentstaff = false;&#xD;&#xA;&#xD;&#xA;if(highestRatingToCurrentRatingPercentage &gt;= philosophy.HighestStaffRatingComparedToCurrentStaffRatingPercentage)&#xD;&#xA;{&#xD;&#xA;prefercurrentstaff = false;&#xD;&#xA;}&#xD;&#xA;else&#xD;&#xA;{&#xD;&#xA;prefercurrentstaff = true;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;prefercurrentstaff;" />
			<attribute name="ProcessCreateCoachContractOffersRequest" idx="82" type="StaffHiringEval_ProcessCreateCoachContractOffersRequest" guid="6495417-1924021" final="true" default="// If the &quot;Delegate&quot; response was chosen, update offers for the selected team.&#xD;&#xA;if (request.Response == CreateCoachOffers_DelegateResponse &amp;&amp; Franchise.SeasonInfo.IsStaffHiringPeriodActive)&#xD;&#xA;{&#xD;&#xA;    Team team = request.Team;&#xD;&#xA;&#xD;&#xA;    CreateContractOffer(team, CoachPosition.HeadCoach);&#xD;&#xA;    CreateContractOffer(team, CoachPosition.Scout);&#xD;&#xA;    CreateContractOffer(team, CoachPosition.Trainer);&#xD;&#xA;}" />
			<attribute name="ProcessCreateCoachResignContractOffersRequest" idx="83" type="StaffHiringEval_ProcessCreateCoachResignContractOffersRequest" guid="6495417-1924052" final="true" default="Team team = request.Team;&#xD;&#xA;&#xD;&#xA;// If the &quot;Delegate&quot; response was chosen, update offers for the selected team.&#xD;&#xA;if (request.Response == CreateCoachResignOffers_DelegateResponse &amp;&amp; Franchise.SeasonInfo.IsStaffHiringPeriodActive)&#xD;&#xA;{&#xD;&#xA;    CreateResignContractOffer(team, CoachPosition.HeadCoach);&#xD;&#xA;    CreateResignContractOffer(team, CoachPosition.Scout);&#xD;&#xA;    CreateResignContractOffer(team, CoachPosition.Trainer);&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;ReleaseStaffWithNoOutstandingOffers(team);" />
