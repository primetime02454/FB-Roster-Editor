			<attribute name="HandleStaffHiringEvaluateOffersStart" idx="60" type="StaffHiringEval_HandleStaffHiringEvaluateOffersStart" guid="6495417-1924040" final="true" default="// Issue coach offer requests.&#xD;&#xA;StaffHiring_IssueStaffPersonOfferRequests IssueRequestsView = new StaffHiring_IssueStaffPersonOfferRequests;&#xD;&#xA;IssueRequestsView.StaffHiringEvalRef = this;&#xD;&#xA;IssueRequestsView.Subjects = Franchise.FreeAgentCoaches;&#xD;&#xA;IssueRequestsView.Update();&#xD;&#xA;&#xD;&#xA;StaffHiring_IssueStaffPersonOfferRequests scoutIssueRequestsView = new StaffHiring_IssueStaffPersonOfferRequests;&#xD;&#xA;scoutIssueRequestsView.StaffHiringEvalRef = this;&#xD;&#xA;scoutIssueRequestsView.Subjects = Franchise.FreeAgentScouts;&#xD;&#xA;scoutIssueRequestsView.Update();&#xD;&#xA;&#xD;&#xA;StaffHiring_IssueStaffPersonOfferRequests trainerIssueRequestsView = new StaffHiring_IssueStaffPersonOfferRequests;&#xD;&#xA;trainerIssueRequestsView.StaffHiringEvalRef = this;&#xD;&#xA;trainerIssueRequestsView.Subjects = Franchise.FreeAgentTrainers;&#xD;&#xA;trainerIssueRequestsView.Update();" />
