			<attribute name="IssueAdvanceStageRequest" idx="98" type="FranchiseServer_CareerFlow_IssueAdvanceStageRequest" guid="6708691-1948521" final="true" default="AdvanceStageRequest request = new AdvanceStageRequest;&#xD;&#xA;&#xD;&#xA;// Set the request settings.&#xD;&#xA;request.Priority = 254;&#xD;&#xA;request.IsResponseRequired = true;&#xD;&#xA;request.IsConnectionRequired = false;&#xD;&#xA;request.IsBlocking = false;&#xD;&#xA;request.IsPersistent = true;&#xD;&#xA;&#xD;&#xA;// Set the available responses.&#xD;&#xA;request.ReadyResponse = AdvanceRequestReadyResponse;&#xD;&#xA;request.AdvanceResponse = AdvanceRequestAdvanceResponse;&#xD;&#xA;request.DefaultResponse = AdvanceRequestReadyResponse;&#xD;&#xA;&#xD;&#xA;request.RequestData = SeasonInfo;&#xD;&#xA;&#xD;&#xA;// Create the response forms array.&#xD;&#xA;request.ResponseForms = new ResponseForm[30];&#xD;&#xA;request.ResponseForms.Append(AdvanceRequestReadyResponse);&#xD;&#xA;&#xD;&#xA;// If this is the league commissioner, give him the option to advance without&#xD;&#xA;// waiting on the other users.&#xD;&#xA;if (isForcible)&#xD;&#xA;{&#xD;&#xA;    request.CanUpdateResponse = true;&#xD;&#xA;    request.ResponseForms.Append(AdvanceRequestAdvanceResponse);&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;if(isAdmin)&#xD;&#xA;{ &#xD;&#xA;    FillAdvanceResponseForm(request.ResponseForms);&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;// Issue the request to the team's user character.&#xD;&#xA;request.Issue(userEntity);&#xD;&#xA;&#xD;&#xA;request;" />
			<attribute name="IssueNewCareerWaitRequest" idx="99" type="FranchiseServer_CareerFlow_IssueNewCareerWaitRequest" guid="6708691-1948624" final="true" default="NewCareerWaitRequest request = new NewCareerWaitRequest;&#xD;&#xA;&#xD;&#xA;// Set the request settings.&#xD;&#xA;request.IsCommissioner = isCommissioner;&#xD;&#xA;request.IsFantasyDraftOnly = SkipNewCareerStage;&#xD;&#xA;request.IsBlocking = false;&#xD;&#xA;request.IsPersistent = true;&#xD;&#xA;request.IsConnectionRequired = false;&#xD;&#xA;request.IsResponseRequired = true;&#xD;&#xA;request.IsSubmittable = true;&#xD;&#xA;request.RequestData = Franchise.SeasonInfo;&#xD;&#xA;&#xD;&#xA;request.ResponseForms = new ResponseForm[2];&#xD;&#xA;&#xD;&#xA;// Create the response forms.&#xD;&#xA;if (SkipNewCareerStage)&#xD;&#xA;{&#xD;&#xA;    if (isCommissioner)&#xD;&#xA;    {&#xD;&#xA;        // Commissioner should not see &quot;Start Regular Career&quot; response&#xD;&#xA;        request.ResponseForms.Append(StartDraftResponse);&#xD;&#xA;        request.DefaultResponse = NewCareerWaitResponse;&#xD;&#xA;    }&#xD;&#xA;    else&#xD;&#xA;    {&#xD;&#xA;        request.DefaultResponse = NewCareerWaitResponse;&#xD;&#xA;    }&#xD;&#xA;}&#xD;&#xA;else&#xD;&#xA;{&#xD;&#xA;    request.ResponseForms.Append(NewCareerWaitResponse);&#xD;&#xA;&#xD;&#xA;    // If this is the commissioner, add the Fantasy Draft option.&#xD;&#xA;    if (isCommissioner)&#xD;&#xA;    {&#xD;&#xA;        request.ResponseForms.Append(StartDraftResponse);&#xD;&#xA;    }&#xD;&#xA;    &#xD;&#xA;    // Set the default response.&#xD;&#xA;    request.DefaultResponse = NewCareerWaitResponse;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;// Issue the request.&#xD;&#xA;request.Issue(userEntity);&#xD;&#xA;&#xD;&#xA;request;&#xD;&#xA;" />
			<attribute name="IssueStartDraftRequest" idx="100" type="FranchiseServer_CareerFlow_IssueStartDraftRequest" guid="6708691-1948609" final="true" default="Draft_StartDraftRequest request = new Draft_StartDraftRequest;&#xD;&#xA;&#xD;&#xA;request.IsBlocking = false;&#xD;&#xA;request.IsConnectionRequired = false;&#xD;&#xA;request.IsPersistent = true;&#xD;&#xA;request.IsSubmittable = true;&#xD;&#xA;&#xD;&#xA;if( isCommissioner )&#xD;&#xA;{&#xD;&#xA;  if(removeStartDraft)&#xD;&#xA;  {&#xD;&#xA;    request.ResponseForms = new ResponseForm[1];&#xD;&#xA;      {&#xD;&#xA;          request.ResponseForms.Append( SimDraftResponse );&#xD;&#xA;      }&#xD;&#xA;      request.DefaultResponse = SimDraftResponse;&#xD;&#xA;      request.IsCommissioner = true;&#xD;&#xA;      request.IsResponseRequired = true;&#xD;&#xA;  }&#xD;&#xA;  else&#xD;&#xA;  {&#xD;&#xA;    request.ResponseForms = new ResponseForm[2];&#xD;&#xA;      {&#xD;&#xA;          request.ResponseForms.Append( StartDraftResponse );&#xD;&#xA;          request.ResponseForms.Append( SimDraftResponse );&#xD;&#xA;      }&#xD;&#xA;      request.DefaultResponse = SimDraftResponse;&#xD;&#xA;      request.IsCommissioner = true;&#xD;&#xA;      request.IsResponseRequired = true;&#xD;&#xA;  }&#xD;&#xA;}&#xD;&#xA;else&#xD;&#xA;{&#xD;&#xA;  request.ResponseForms = new ResponseForm[1];&#xD;&#xA;  {&#xD;&#xA;    request.ResponseForms.Append( DraftReadyResponse );&#xD;&#xA;  }&#xD;&#xA;  request.DefaultResponse = DraftReadyResponse ;&#xD;&#xA;  request.IsCommissioner = false;&#xD;&#xA;  request.IsResponseRequired = false;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;request.SimResponse = SimDraftResponse;&#xD;&#xA;request.StartResponse = StartDraftResponse;&#xD;&#xA;request.ReadyResponse = DraftReadyResponse;&#xD;&#xA;request.Franchise = Franchise;&#xD;&#xA;request.DraftTransaction = DraftTransaction;&#xD;&#xA;&#xD;&#xA;request.RequestData = Franchise.SeasonInfo;&#xD;&#xA;&#xD;&#xA;request.Issue( userEntity );&#xD;&#xA;&#xD;&#xA;request;" />
