			<attribute name="RefreshAdvanceStageRequest" idx="131" type="FranchiseServer_CareerFlow_RefreshAdvanceStageRequest" guid="6708691-1948603" final="true" default="// Create the response forms array.&#xD;&#xA;request.ResponseForms.EraseAll();&#xD;&#xA;request.ResponseForms.Append(AdvanceRequestReadyResponse);&#xD;&#xA;&#xD;&#xA;// If this is the league commissioner, give him the option to advance without&#xD;&#xA;// waiting on the other users.&#xD;&#xA;if (canForceAdvance)&#xD;&#xA;{&#xD;&#xA;    request.CanUpdateResponse = true;&#xD;&#xA;    request.ResponseForms.Append(AdvanceRequestAdvanceResponse);&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;if(isAdmin &amp;&amp; (LeagueSetting.FranchiseStyle !=  FranchiseStyle.Legacy))&#xD;&#xA;{ &#xD;&#xA;    FillAdvanceResponseForm(request.ResponseForms);&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;// Refresh the request.&#xD;&#xA;request.Refresh();&#xD;&#xA;" />
			<attribute name="RefreshCareerClockRequest" idx="132" type="FranchiseServer_CareerFlow_RefreshCareerClockRequest" guid="6708691-1948780" final="true" default="// Create the response forms array.&#xD;&#xA;request.ResponseForms.EraseAll();&#xD;&#xA;request.ResponseForms.Append(AdvanceRequestReadyResponse);&#xD;&#xA;&#xD;&#xA;// If this is the league commissioner, give him the option to advance without&#xD;&#xA;// waiting on the other users.&#xD;&#xA;if (canForceAdvance)&#xD;&#xA;{&#xD;&#xA;    request.CanUpdateResponse = true;&#xD;&#xA;    request.ResponseForms.Append(AdvanceRequestAdvanceResponse);&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;if(isAdmin &amp;&amp; (LeagueSetting.FranchiseStyle !=  FranchiseStyle.Legacy))&#xD;&#xA;{ &#xD;&#xA;    FillAdvanceResponseForm(request.ResponseForms);&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;// Refresh the request.&#xD;&#xA;request.Refresh();&#xD;&#xA;" />
			<attribute name="RefreshNewCareerWaitRequest" idx="133" type="FranchiseServer_CareerFlow_RefreshNewCareerWaitRequest" guid="6708691-1948629" final="true" default="// If user was commissioner&#xD;&#xA;if(request.IsCommissioner == true)&#xD;&#xA;{&#xD;&#xA;  // commissioner loses fantasy draft option&#xD;&#xA;  if(isCommissioner == false)&#xD;&#xA;  {&#xD;&#xA;    request.ResponseForms.FindAndErase(StartDraftResponse);    &#xD;&#xA;  }&#xD;&#xA;}&#xD;&#xA;else&#xD;&#xA;{&#xD;&#xA;  // commissioner gains fantasy draft option&#xD;&#xA;  if(isCommissioner == true)&#xD;&#xA;  {&#xD;&#xA;    request.ResponseForms.Append(StartDraftResponse);&#xD;&#xA;  }&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;request.IsCommissioner = isCommissioner;&#xD;&#xA;request.Refresh();&#xD;&#xA;&#xD;&#xA;" />
			<attribute name="RefreshStartDraftRequest" idx="134" type="FranchiseServer_CareerFlow_RefreshStartDraftRequest" guid="6708691-1948618" final="true" default="request.ResponseForms.EraseAll();&#xD;&#xA;&#xD;&#xA;if( isCommissioner )&#xD;&#xA;{&#xD;&#xA;  request.ResponseForms = new ResponseForm[2];&#xD;&#xA;  {&#xD;&#xA;    request.ResponseForms.Append( StartDraftResponse );&#xD;&#xA;    request.ResponseForms.Append( SimDraftResponse );&#xD;&#xA;  }&#xD;&#xA;  request.DefaultResponse = SimDraftResponse;&#xD;&#xA;  request.IsCommissioner = true;&#xD;&#xA;  request.IsResponseRequired = true;&#xD;&#xA;}&#xD;&#xA;else&#xD;&#xA;{&#xD;&#xA;  request.ResponseForms = new ResponseForm[1];&#xD;&#xA;  {&#xD;&#xA;    request.ResponseForms.Append( DraftReadyResponse );&#xD;&#xA;  }&#xD;&#xA;  request.DefaultResponse = DraftReadyResponse ;&#xD;&#xA;  request.IsCommissioner = false;&#xD;&#xA;  request.IsResponseRequired = false;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;// Refresh the request.&#xD;&#xA;request.Refresh();&#xD;&#xA;" />
