	<schemas>
		<schema name="TeamManager" numMembers="58" base="Module" assetId="6498680" isRecordPersistent="true" majorVersionCRC="849696530" minorVersionCRC="-171359633">
			<attribute name="AddPlayer" idx="0" type="TeamManager_AddPlayer" guid="6498680-1925986" final="true" default="// Update the player's team history.&#xD;&#xA;player.PLYR_CONSECYEARSWITHTEAM = 0;&#xD;&#xA;&#xD;&#xA;// If the player has been drafted, add him to the drafted players array.&#xD;&#xA;if (contractStatus == PlayerContractStatus.Drafted)&#xD;&#xA;{&#xD;&#xA;    team.CommittedPlayers.Append(player);&#xD;&#xA;}&#xD;&#xA;// If the player has been signed, add him to the roster.&#xD;&#xA;else if (contractStatus == PlayerContractStatus.Signed)&#xD;&#xA;{&#xD;&#xA;   team.Roster.Append(player);&#xD;&#xA;&#xD;&#xA;    // Upadate player's Injured Reserve status and team's active roster size&#xD;&#xA;    player.IsInjuredReserve = false;&#xD;&#xA;    team.ActiveRosterSize = team.ActiveRosterSize + 1;&#xD;&#xA;}&#xD;&#xA;" />
