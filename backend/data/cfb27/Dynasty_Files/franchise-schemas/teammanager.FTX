			<attribute name="FireStaffPerson" idx="13" type="TeamManager_FireStaffPerson" guid="6498680-1926112" final="true" default="if(staffPerson.Position == CoachPosition.HeadCoach || staffPerson.Position == CoachPosition.OffensiveCoordinator || staffPerson.Position == CoachPosition.DefensiveCoordinator)&#xD;&#xA;{&#xD;&#xA;ReleaseCoach(team, staffPerson.Position);&#xD;&#xA;}&#xD;&#xA;else if(staffPerson.Position == CoachPosition.Scout)&#xD;&#xA;{&#xD;&#xA;ReleaseScout(team);&#xD;&#xA;}&#xD;&#xA;else if(staffPerson.Position == CoachPosition.Trainer)&#xD;&#xA;{&#xD;&#xA;ReleaseTrainer(team);&#xD;&#xA;}&#xD;&#xA;" />
