			<attribute name="IssueFranchiseTagNotifyRequest" idx="18" type="TeamManager_IssueFranchiseTagNotifyRequest" guid="6498680-1926050" final="true" default="//not used in college&#xD;&#xA;0;" />
			<attribute name="IssueStaffEventNotificationRequest" idx="19" type="TeamManager_IssueStaffEventNotificationRequest" guid="6498680-1926117" final="true" default="StaffEventNotificationRequest request = new StaffEventNotificationRequest ;&#xD;&#xA;&#xD;&#xA;StaffEventNotificationRequest nullRequest = null;&#xD;&#xA;&#xD;&#xA;if (request != nullRequest)&#xD;&#xA;{&#xD;&#xA;    request.RequestData = contractOffer;&#xD;&#xA;    request.IsResponseRequired = false;&#xD;&#xA;    &#xD;&#xA;    request.ResponseForms = new ResponseForm[1];&#xD;&#xA;    request.ResponseForms.Append( StaffHiringNotificationDismissResponse);&#xD;&#xA;&#xD;&#xA;    request.DefaultResponse = StaffHiringNotificationDismissResponse;&#xD;&#xA;    request.EventType = eventType;&#xD;&#xA;&#xD;&#xA;    request.Issue(requestReceiver);&#xD;&#xA;}" />
