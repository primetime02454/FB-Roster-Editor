	<schemas>
		<schema name="TransactionHistoryManager" numMembers="27" base="Module" assetId="6498928" isRecordPersistent="true" majorVersionCRC="-290527646" minorVersionCRC="-311809445">
			<attribute name="AppendTransaction" idx="0" type="TransactionHistoryManager_AppendTransaction" guid="6498928-1927830" final="true" default="// Set the transaction ID&#xD;&#xA;entry.TransactionId = TransactionId;&#xD;&#xA;TransactionId = TransactionId + 1;&#xD;&#xA;&#xD;&#xA;if (TransactionList.Population() == TransactionList.Capacity())&#xD;&#xA;{&#xD;&#xA;    TransactionList[TransactionListBegin] = entry;&#xD;&#xA;    TransactionListBegin = (TransactionListBegin + 1) % TransactionList.Capacity();&#xD;&#xA;}&#xD;&#xA;else&#xD;&#xA;{&#xD;&#xA;    TransactionList.Append(entry);&#xD;&#xA;}&#xD;&#xA;" />
			<attribute name="AppendWeekSummary" idx="1" type="TransactionHistoryManager_AppendWeekSummary" guid="6498928-2227082" final="true" />
			<attribute name="ClearCoachTransactionHistoryEntries" idx="2" type="none()" guid="6498928-2255071" final="true" />
			<attribute name="ClearTransactions" idx="3" type="none()" guid="6498928-1927834" final="true" default="TransactionList.EraseAll();&#xD;&#xA;TransactionListBegin = 0;&#xD;&#xA;" />
			<attribute name="ClearTransactionsForStaffPerson" idx="4" type="TransactionHistoryManager_ClearTransactionsForStaffPerson" guid="6498928-2255066" final="true" />
			<attribute name="ClearWeekSummaries" idx="5" type="none()" guid="6498928-2227083" final="true" />
