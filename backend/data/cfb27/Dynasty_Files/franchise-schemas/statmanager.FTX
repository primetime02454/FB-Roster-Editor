			<attribute name="GradeHBPerformance" idx="29" type="StatManager_GradeHBPerformance" guid="6493950-1909367" final="true" default="// As there is no int-float conversion in GC multipliers and modifiers have been multiplied by 100 and this variable is used when needed to keep the formula consistent and to keep the int32_t in range&#xD;&#xA;int floatToIntConversionAdjustment = 100;&#xD;&#xA;&#xD;&#xA;int adjustGameRatingRange = 1000000;&#xD;&#xA;&#xD;&#xA;int rushingMultiplier = 50;&#xD;&#xA;int receivingMultiplier = 20;&#xD;&#xA;int receptionMultiplier = 50;&#xD;&#xA;int rushTDMultiplier = 700;&#xD;&#xA;int receivingTDMultiplier = 700;&#xD;&#xA;int fumbleMultiplier = 1000;&#xD;&#xA;&#xD;&#xA;int gameRating = 0;&#xD;&#xA;GameOffensiveStats gameOffensiveStats = gameStats;&#xD;&#xA;if (gameOffensiveStats != null)&#xD;&#xA;{&#xD;&#xA; int rushingAttempts = gameOffensiveStats.RUSHATTEMPTS;&#xD;&#xA; int receptions = gameOffensiveStats.RECEIVECATCHES;&#xD;&#xA; int rushingYards = gameOffensiveStats.RUSHYARDS;&#xD;&#xA; int receivingYards = gameOffensiveStats.RECEIVEYARDS;&#xD;&#xA; int rushingTDs = gameOffensiveStats.RUSHTDS;&#xD;&#xA; int receivingTDs = gameOffensiveStats.RECEIVETDS;&#xD;&#xA; int fumbles = gameOffensiveStats.RUSHFUMBLES;&#xD;&#xA;&#xD;&#xA; int opponentPerformanceModifier = CalculateOpponentPerformanceModifier(gameStats.OpposingTeam);  &#xD;&#xA; int hbRushingModifier = CalculateHBRushingModifier(rushingAttempts);&#xD;&#xA; int hbReceivingModifier = CalculateHBReceivingModifier(receptions);&#xD;&#xA; int skillLevelModifier = CalculateSkillLevelModifier();&#xD;&#xA;&#xD;&#xA; int rushYardsPoints = rushingYards * rushingMultiplier * hbRushingModifier;&#xD;&#xA; int receivingYardsPoints = receivingYards * receivingMultiplier * hbReceivingModifier;&#xD;&#xA; int receptionsPoints = receptions * receptionMultiplier * floatToIntConversionAdjustment;&#xD;&#xA; int tdPoints = rushingTDs * rushTDMultiplier * hbRushingModifier + receivingTDs * receivingTDMultiplier * hbReceivingModifier;&#xD;&#xA;&#xD;&#xA; int positivePoints = tdPoints + rushYardsPoints + receivingYardsPoints + receptionsPoints; &#xD;&#xA; int negativePoints = fumbles * fumbleMultiplier * floatToIntConversionAdjustment;&#xD;&#xA;&#xD;&#xA; int partialResult = (positivePoints - negativePoints) * opponentPerformanceModifier;&#xD;&#xA; int partialResultInRange = partialResult / floatToIntConversionAdjustment;&#xD;&#xA;&#xD;&#xA; gameRating = (partialResultInRange * skillLevelModifier) / adjustGameRatingRange;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;gameRating;" />
			<attribute name="GradeLBPerformance" idx="30" type="StatManager_GradeLBPerformance" guid="6493950-1909391" final="true" default="// As there is no int-float conversion in GC multipliers and modifiers have been multiplied by 100 and this variable is used when needed to keep the formula consistent&#xD;&#xA;int floatToIntConversionAdjustment = 100;&#xD;&#xA;&#xD;&#xA;int adjustGameRatingRange = 1000000;&#xD;&#xA;&#xD;&#xA;int tacklesMultiplier = 1000;&#xD;&#xA;int tacklesForLossMultiplier = 1500;&#xD;&#xA;int sacksMultiplier = 2000;&#xD;&#xA;int interceptionsMultiplier = 3000;&#xD;&#xA;int forcedFumblesMultiplier = 1500;&#xD;&#xA;int fumbleRecoveriesMultiplier = 800;&#xD;&#xA;int tdsMultiplier = 4000;&#xD;&#xA;&#xD;&#xA;int gameRating = 0;&#xD;&#xA;GameDefensiveStats gameDefensiveStats = gameStats;&#xD;&#xA;if (gameDefensiveStats != null)&#xD;&#xA;{&#xD;&#xA;int tackles = gameDefensiveStats.DEFTACKLES;&#xD;&#xA;int tacklesForLoss = gameDefensiveStats.DEFTACKLESFORLOSS;&#xD;&#xA;int sacks = gameDefensiveStats.DLINESACKS;&#xD;&#xA;int interceptions = gameDefensiveStats.DSECINTS;&#xD;&#xA;int forcedFumbles = gameDefensiveStats.DLINEFORCEDFUMBLES;&#xD;&#xA;int fumbleRecoveries = gameDefensiveStats.DLINEFUMBLERECOVERIES;&#xD;&#xA;int tds = gameDefensiveStats.DLINEFUMBLETDS + gameDefensiveStats.DSECINTTDS;&#xD;&#xA;&#xD;&#xA;int opponentPerformanceModifier = CalculateOpponentPerformanceModifier(gameStats.OpposingTeam);&#xD;&#xA;int skillLevelModifier = CalculateSkillLevelModifier();&#xD;&#xA;&#xD;&#xA;gameRating = ((tackles * tacklesMultiplier + tacklesForLoss * tacklesForLossMultiplier + sacks * sacksMultiplier + interceptions * interceptionsMultiplier + forcedFumbles * forcedFumblesMultiplier + fumbleRecoveries * fumbleRecoveriesMultiplier + tds * tdsMultiplier) * opponentPerformanceModifier * skillLevelModifier) / adjustGameRatingRange;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;gameRating;" />
			<attribute name="GradeQBPerformance" idx="31" type="StatManager_GradeQBPerformance" guid="6493950-1909346" final="true" default="// As there is no int-float conversion in GC multipliers and modifiers have been multiplied by 100 and this variable is used when needed to keep the formula consistent and to keep the int32_t in range&#xD;&#xA;int floatToIntConversionAdjustment = 100;&#xD;&#xA;&#xD;&#xA;int adjustGameRatingRange = 1000000;&#xD;&#xA;&#xD;&#xA;int completionMultiplier = 2500;&#xD;&#xA;int passingMultiplier = 17;&#xD;&#xA;int rushingMultiplier = 20;&#xD;&#xA;int passTDMultiplier = 700;&#xD;&#xA;int rushTDMultiplier = 700;&#xD;&#xA;int interceptionMultiplier = 1500;&#xD;&#xA;int fumbleMultiplier = 1000;&#xD;&#xA;int sacksAllowedMultiplier = 100;&#xD;&#xA;&#xD;&#xA;int gameRating = 0;&#xD;&#xA;GameOffensiveStats gameOffensiveStats = gameStats;&#xD;&#xA;if (gameOffensiveStats != null)&#xD;&#xA;{&#xD;&#xA;int passingAttempts = gameOffensiveStats.PASSATTEMPTS;&#xD;&#xA;int rushingAttempts = gameOffensiveStats.RUSHATTEMPTS;&#xD;&#xA;int passingCompletions = gameOffensiveStats.PASSCOMPLETED;&#xD;&#xA;int passingYards = gameOffensiveStats.PASSYARDS;&#xD;&#xA;int rushingYards = gameOffensiveStats.RUSHYARDS;&#xD;&#xA;int passingTDs = gameOffensiveStats.PASSTDS;&#xD;&#xA;int rushingTDs = gameOffensiveStats.RUSHTDS;&#xD;&#xA;int interceptions = gameOffensiveStats.PASSINTS;&#xD;&#xA;int fumbles = gameOffensiveStats.RUSHFUMBLES;&#xD;&#xA;int sacksAllowed = gameOffensiveStats.PASSSACKED;&#xD;&#xA;&#xD;&#xA;int opponentPerformanceModifier = CalculateOpponentPerformanceModifier(gameStats.OpposingTeam);&#xD;&#xA;int qbCompletionModifier = CalculateQBCompletionModifier(passingAttempts);&#xD;&#xA;int qbPassEfficiencyModifier = CalculateQBPassEfficiencyModifier(passingAttempts);&#xD;&#xA;int qbRushEfficiencyModifier = CalculateQBRushEfficiencyModifier(passingAttempts, rushingAttempts);&#xD;&#xA;int skillLevelModifier = CalculateSkillLevelModifier();&#xD;&#xA;&#xD;&#xA;int completionPoints = passingAttempts != 0 ? (passingCompletions * completionMultiplier * qbCompletionModifier) / passingAttempts : 0;&#xD;&#xA;int passYardsPoints = passingYards * passingMultiplier * qbPassEfficiencyModifier;&#xD;&#xA;int rushYardsPoints = rushingYards * rushingMultiplier * qbRushEfficiencyModifier;&#xD;&#xA;int tdPoints = passingTDs * passTDMultiplier * qbPassEfficiencyModifier + rushingTDs * rushTDMultiplier * qbRushEfficiencyModifier;&#xD;&#xA;&#xD;&#xA;int positivePoints = tdPoints + rushYardsPoints + passYardsPoints + completionPoints;&#xD;&#xA;int negativePoints = (interceptions * interceptionMultiplier + fumbles * fumbleMultiplier + sacksAllowed * sacksAllowedMultiplier) * floatToIntConversionAdjustment; &#xD;&#xA;&#xD;&#xA;int partialResult = (positivePoints - negativePoints) * opponentPerformanceModifier;&#xD;&#xA;int partialResultInRange = partialResult / floatToIntConversionAdjustment;&#xD;&#xA;&#xD;&#xA;gameRating = (partialResultInRange * skillLevelModifier) / adjustGameRatingRange;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;gameRating;" />
			<attribute name="GradeWRPerformance" idx="32" type="StatManager_GradeWRPerformance" guid="6493950-1909379" final="true" default="// As there is no int-float conversion in GC multipliers and modifiers have been multiplied by 100 and this variable is used when needed to keep the formula consistent and to keep the int32_t in range&#xD;&#xA;int floatToIntConversionAdjustment = 100;&#xD;&#xA;&#xD;&#xA;int adjustGameRatingRange = 1000000;&#xD;&#xA;&#xD;&#xA;int rushingMultiplier = 20;&#xD;&#xA;int receivingMultiplier = 50;&#xD;&#xA;int receptionMultiplier = 50;&#xD;&#xA;int rushTDMultiplier = 700;&#xD;&#xA;int receivingTDMultiplier = 700;&#xD;&#xA;int fumbleMultiplier = 1000;&#xD;&#xA;&#xD;&#xA;int gameRating = 0;&#xD;&#xA;GameOffensiveStats gameOffensiveStats = gameStats;&#xD;&#xA;if (gameOffensiveStats != null)&#xD;&#xA;{&#xD;&#xA;int rushingAttempts = gameOffensiveStats.RUSHATTEMPTS;&#xD;&#xA;int receptions = gameOffensiveStats.RECEIVECATCHES;&#xD;&#xA;int rushingYards = gameOffensiveStats.RUSHYARDS;&#xD;&#xA;int receivingYards = gameOffensiveStats.RECEIVEYARDS;&#xD;&#xA;int rushingTDs = gameOffensiveStats.RUSHTDS;&#xD;&#xA;int receivingTDs = gameOffensiveStats.RECEIVETDS;&#xD;&#xA;int fumbles = gameOffensiveStats.RUSHFUMBLES;&#xD;&#xA;&#xD;&#xA;int opponentPerformanceModifier = CalculateOpponentPerformanceModifier(gameStats.OpposingTeam);&#xD;&#xA;int wrRushingModifier = CalculateWRRushingModifier(rushingAttempts);&#xD;&#xA;int wrReceivingModifier = CalculateWRReceivingModifier(receptions);&#xD;&#xA;int skillLevelModifier = CalculateSkillLevelModifier();&#xD;&#xA;&#xD;&#xA;int rushYardsPoints = rushingYards * rushingMultiplier * wrRushingModifier;&#xD;&#xA;int receivingYardsPoints = receivingYards * receivingMultiplier * wrReceivingModifier; &#xD;&#xA;int receptionsPoints = receptions * receptionMultiplier * floatToIntConversionAdjustment;&#xD;&#xA;int tdPoints = rushingTDs * rushTDMultiplier * wrRushingModifier + receivingTDs * receivingTDMultiplier * wrReceivingModifier;&#xD;&#xA;&#xD;&#xA;int positivePoints = tdPoints + rushYardsPoints + receivingYardsPoints + receptionsPoints; &#xD;&#xA;int negativePoints = fumbles * fumbleMultiplier * floatToIntConversionAdjustment;&#xD;&#xA;&#xD;&#xA;int partialResult = (positivePoints - negativePoints) * opponentPerformanceModifier;&#xD;&#xA;int partialResultInRange = partialResult / floatToIntConversionAdjustment;&#xD;&#xA;&#xD;&#xA;gameRating = (partialResultInRange * skillLevelModifier) / adjustGameRatingRange;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;gameRating;" />
