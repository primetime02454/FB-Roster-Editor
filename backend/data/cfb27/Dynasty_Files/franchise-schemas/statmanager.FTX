			<attribute name="CalculateOpponentPerformanceModifier" idx="2" type="StatManager_CalculateOpponentPerformanceModifier" guid="6493950-1909350" final="true" default="int seasonWinPercentage = team.SeasonWinPct;&#xD;&#xA;if (seasonWinPercentage &lt; 200)&#xD;&#xA;{&#xD;&#xA;  85;&#xD;&#xA;}&#xD;&#xA;else if (seasonWinPercentage &gt;= 200 &amp;&amp; seasonWinPercentage &lt; 400)&#xD;&#xA;{&#xD;&#xA;  95;&#xD;&#xA;}&#xD;&#xA;else if (seasonWinPercentage &gt;= 400 &amp;&amp; seasonWinPercentage &lt; 600)&#xD;&#xA;{&#xD;&#xA;  100;&#xD;&#xA;}&#xD;&#xA;else if (seasonWinPercentage &gt;= 600 &amp;&amp; seasonWinPercentage &lt; 800)&#xD;&#xA;{&#xD;&#xA;  105;&#xD;&#xA;}&#xD;&#xA;else&#xD;&#xA;{&#xD;&#xA;  115;&#xD;&#xA;}" />
