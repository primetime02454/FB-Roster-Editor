			<attribute name="EvaluatePlayerPerformanceGrade" idx="12" type="StatManager_EvaluatePlayerPerformanceGrade" guid="6493950-1909341" final="true" default="int gameRatingMinValue = 0;&#xD;&#xA;int gameRatingMaxValue = 100;&#xD;&#xA;int gameRating = 0;&#xD;&#xA;&#xD;&#xA;if (player.Position == PositionE.QB)&#xD;&#xA;{&#xD;&#xA;  gameRating = GradeQBPerformance(gameStats);&#xD;&#xA;}&#xD;&#xA;else if (player.Position == PositionE.HB)&#xD;&#xA;{&#xD;&#xA;  gameRating = GradeHBPerformance(gameStats);&#xD;&#xA;}&#xD;&#xA;else if (player.Position == PositionE.WR)&#xD;&#xA;{&#xD;&#xA;  gameRating = GradeWRPerformance(gameStats);&#xD;&#xA;}&#xD;&#xA;else if (player.Position == PositionE.MLB)&#xD;&#xA;{&#xD;&#xA;  gameRating = GradeLBPerformance(gameStats);&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;gameRating = gameRating &lt; gameRatingMinValue ? gameRatingMinValue : gameRating;&#xD;&#xA;gameRating = gameRating &gt; gameRatingMaxValue ? gameRatingMaxValue : gameRating;&#xD;&#xA;gameStats.GAMERATING = gameRating;" />
