			<attribute name="IssueAwardNotificationRequest" idx="14" type="AwardsEval_IssueAwardNotificationRequest" guid="6378667-2233003" final="true" default="bool issueCommand = true;&#xD;&#xA;&#xD;&#xA;if (!isUserPlayer &amp;&amp;&#xD;&#xA;   (award.AwardType == AwardType.ALL_AM_1ST ||&#xD;&#xA;    award.AwardType == AwardType.ALL_AM_1ST_CONF ||&#xD;&#xA;    award.AwardType == AwardType.ALL_AM_1ST_PRE ||&#xD;&#xA;    award.AwardType == AwardType.ALL_AM_1ST_PRE_CONF ||&#xD;&#xA;    award.AwardType == AwardType.ALL_AM_2ND ||&#xD;&#xA;    award.AwardType == AwardType.ALL_AM_2ND_CONF ||&#xD;&#xA;    award.AwardType == AwardType.ALL_AM_2ND_PRE ||&#xD;&#xA;    award.AwardType == AwardType.ALL_AM_2ND_PRE_CONF ||&#xD;&#xA;    award.AwardType == AwardType.ALL_AM_FR ||&#xD;&#xA;    award.AwardType == AwardType.ALL_AM_FR_CONF))&#xD;&#xA;{&#xD;&#xA;  issueCommand = false;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;if (issueCommand)&#xD;&#xA;{&#xD;&#xA;  AwardNotificationRequest request = new AwardNotificationRequest;&#xD;&#xA;  request.IsResponseRequired = false;&#xD;&#xA;  request.IsConnectionRequired = false;&#xD;&#xA;  request.IsBlocking = false;&#xD;&#xA;  request.IsPersistent = false;&#xD;&#xA;  request.Priority = 2;&#xD;&#xA;&#xD;&#xA;  if (award.AwardType == AwardType.HEISMAN)&#xD;&#xA;  {&#xD;&#xA;    request.Priority = 1;&#xD;&#xA;  }&#xD;&#xA;&#xD;&#xA;  request.Award = award;&#xD;&#xA;  request.RequestData = userEntity;&#xD;&#xA;  request.Team = team;&#xD;&#xA;  request.IsUserPlayer = isUserPlayer;&#xD;&#xA;&#xD;&#xA;  request.UIDisplayStyle = AwardTypeEnumTableEntry.UIDisplayStyle;&#xD;&#xA;  request.ShowRoosterOnHubButton = AwardTypeEnumTableEntry.ShowRoosterOnHUBButton;&#xD;&#xA;  request.ShowRoosterOnHubTab = AwardTypeEnumTableEntry.ShowRoosterOnHubTab;&#xD;&#xA;&#xD;&#xA;request.Issue(userEntity);&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;" />
			<attribute name="LastSeasonWeeklyAwards" idx="15" type="Award[]" />
