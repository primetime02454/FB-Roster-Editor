			<attribute name="NarrativePlayerMetersEval" idx="18" type="NarrativePlayerMetersEval" />
			<attribute name="ProcessAnnualAwards" idx="19" type="none()" guid="6378667-1904815" final="true" default="//Reset heisman winner swap&#xD;&#xA;HasSwappedHeismanWinner = false;&#xD;&#xA;&#xD;&#xA;// update the annual awards&#xD;&#xA;// coach awards&#xD;&#xA;UpdateAward( AwardType.BEST_HC, false );&#xD;&#xA;UpdateAward( AwardType.BEST_AC, false );&#xD;&#xA;// best player awards&#xD;&#xA;UpdateAward( AwardType.BEST_POTY, false );&#xD;&#xA;UpdateAward( AwardType.BEST_FRESHMAN_POTY, false );&#xD;&#xA;UpdateAward( AwardType.MOST_VERSATILE, false );&#xD;&#xA;UpdateAward( AwardType.BEST_ACADEMIC, false );&#xD;&#xA;UpdateAward( AwardType.BEST_PLAYER, false );&#xD;&#xA;UpdateAward( AwardType.HEISMAN, false );&#xD;&#xA;// best positional awards&#xD;&#xA;UpdateAward( AwardType.BEST_SR_QB, false );&#xD;&#xA;UpdateAward( AwardType.BEST_DEF_1, false );&#xD;&#xA;UpdateAward( AwardType.BEST_DE, false );&#xD;&#xA;UpdateAward( AwardType.BEST_REC, false );&#xD;&#xA;UpdateAward( AwardType.BEST_DEF_2, false );&#xD;&#xA;UpdateAward( AwardType.BEST_QB, false );&#xD;&#xA;UpdateAward( AwardType.BEST_RB, false );&#xD;&#xA;UpdateAward( AwardType.BEST_TE, false );&#xD;&#xA;UpdateAward( AwardType.BEST_KICK, false );&#xD;&#xA;UpdateAward( AwardType.BEST_IL, false );&#xD;&#xA;UpdateAward( AwardType.BEST_DB, false );&#xD;&#xA;UpdateAward( AwardType.BEST_PUNT, false );&#xD;&#xA;UpdateAward( AwardType.BEST_C, false );&#xD;&#xA;UpdateAward( AwardType.BEST_SR, false );&#xD;&#xA;UpdateAward( AwardType.BEST_LB, false );&#xD;&#xA;UpdateAward( AwardType.BEST_DL, false );&#xD;&#xA;&#xD;&#xA;// all american team&#xD;&#xA;UpdateAward( AwardType.ALL_AM_1ST, false );&#xD;&#xA;UpdateAward( AwardType.ALL_AM_2ND, false );&#xD;&#xA;UpdateAward( AwardType.ALL_AM_FR, false );&#xD;&#xA;" />
			<attribute name="ProcessPostSeasonWeeklyAwards" idx="20" type="none()" guid="6378667-2252105" final="true" default="// update the player of the week awards&#xD;&#xA;UpdateAward( AwardType.Defensive_Player_of_Week, false );&#xD;&#xA;UpdateAward( AwardType.Offensive_Player_of_Week, false );" />
			<attribute name="ProcessPreseasonAwards" idx="21" type="none()" guid="6378667-1988131" final="true" default="UpdateAward( AwardType.ALL_AM_1ST_PRE, false );&#xD;&#xA;UpdateAward( AwardType.ALL_AM_2ND_PRE, false );&#xD;&#xA;" />
			<attribute name="ProcessRegularSeasonWeeklyAwards" idx="22" type="none()" guid="6378667-1904799" final="true" default="&#xD;&#xA;UpdateAward( AwardType.HEISMAN, true);&#xD;&#xA;&#xD;&#xA;// update the player of the week awards&#xD;&#xA;UpdateAward( AwardType.Defensive_Player_of_Week, false );&#xD;&#xA;UpdateAward( AwardType.Offensive_Player_of_Week, false );" />
