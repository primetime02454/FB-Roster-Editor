	<!--SCHEMAS-->
	<schemas>
		<schema name="AwardsTuning" numMembers="11" base="BaseTuning" defaultStoreCapacity="1" assetId="6320448" defaultStoreGroupId="2" isRecordPersistent="true" defaultStoreGroupName="Tuning" defaultStoreOptimizationId="1" defaultStoreOptimizationName="Default_" majorVersionCRC="560490121" minorVersionCRC="-133805819">
			<attribute name="bonusUserPlayerGPA" idx="0" type="int" minValue="0" maxValue="200" default="0" />
			<attribute name="CalculateBestPositionOfYearRating" idx="1" type="AwardsTuning_CalculateBestPositionOfYearRating" guid="6320448-1900092" default="int playerRating = 0;&#xD;&#xA;int playerOVR = player.GetBestOverallGrade();&#xD;&#xA;int seasonModifier = (50 / team.TeamRank) + (team.TeamPrestige * 2);&#xD;&#xA;SeasonStats playerSeasonStats = statManager.GetPlayerSeasonStatsForYear(player, year);&#xD;&#xA;&#xD;&#xA;if(awardType == AwardType.BEST_DEF_1)&#xD;&#xA;{&#xD;&#xA;    playerRating =   (statManager.GetPlayerSeasonStat(playerSeasonStats, StatType.DefensiveInts) * 6) +&#xD;&#xA;        (statManager.GetPlayerSeasonStat(playerSeasonStats, StatType.DLineFumbleRecoveries) * 3) +&#xD;&#xA;        (statManager.GetPlayerSeasonStat(playerSeasonStats, StatType.DLineForcedFumbles) * 3) +&#xD;&#xA;        (statManager.GetPlayerSeasonStat(playerSeasonStats, StatType.DefensiveTacklesForLoss) * 5) +&#xD;&#xA; (statManager.GetPlayerSeasonStat(playerSeasonStats, StatType.DefensiveSacks) * 7) +&#xD;&#xA; (statManager.GetPlayerSeasonStat(playerSeasonStats, StatType.DefensiveTDS ) * 10) +&#xD;&#xA;  ((statManager.GetPlayerSeasonStat(playerSeasonStats, StatType.DefensiveTotalTackles) * 3) / 5) +&#xD;&#xA;        ((playerOVR * 3) /4) +&#xD;&#xA; seasonModifier;&#xD;&#xA;&#xD;&#xA;}&#xD;&#xA;else if(awardType == AwardType.BEST_REC)&#xD;&#xA;{&#xD;&#xA;   playerRating = (statManager.GetPlayerSeasonStat(playerSeasonStats, StatType.PassTds) *  2) +&#xD;&#xA; (statManager.GetPlayerSeasonStat(playerSeasonStats, StatType.RushLongest)/ 5) +&#xD;&#xA; (statManager.GetPlayerSeasonStat(playerSeasonStats, StatType.ReceiveLongest) / 5) +&#xD;&#xA;        ((statManager.GetPlayerSeasonStat(playerSeasonStats, StatType.RushTds) * 18)/ 4) +&#xD;&#xA;        (statManager.GetPlayerSeasonStat(playerSeasonStats, StatType.ReceiveTDs) * 5) +&#xD;&#xA;        (statManager.GetPlayerSeasonStat(playerSeasonStats, StatType.RushYards) / 30) +&#xD;&#xA;  (statManager.GetPlayerSeasonStat(playerSeasonStats, StatType.ReceiveCatches) / 2) +&#xD;&#xA;        (statManager.GetPlayerSeasonStat(playerSeasonStats, StatType.ReceiveYards) / 20) -&#xD;&#xA;        (statManager.GetPlayerSeasonStat(playerSeasonStats, StatType.RushFumbles) * 3) -     &#xD;&#xA; (statManager.GetPlayerSeasonStat(playerSeasonStats, StatType.ReceiveDrops) / 2) +&#xD;&#xA;       ((playerOVR * 2) /4);&#xD;&#xA;}&#xD;&#xA;else if(awardType == AwardType.BEST_DEF_2)&#xD;&#xA;{&#xD;&#xA;    playerRating =   (statManager.GetPlayerSeasonStat(playerSeasonStats, StatType.DefensiveInts) * 6) +&#xD;&#xA;        (statManager.GetPlayerSeasonStat(playerSeasonStats, StatType.DLineFumbleRecoveries) * 3) +&#xD;&#xA;        (statManager.GetPlayerSeasonStat(playerSeasonStats, StatType.DLineForcedFumbles) * 3) +&#xD;&#xA;        (statManager.GetPlayerSeasonStat(playerSeasonStats, StatType.DefensiveTacklesForLoss) * 5) +&#xD;&#xA; (statManager.GetPlayerSeasonStat(playerSeasonStats, StatType.DefensivePassDeflections) * 3) +&#xD;&#xA; (statManager.GetPlayerSeasonStat(playerSeasonStats, StatType.DefensiveSacks) * 5) +&#xD;&#xA; (statManager.GetPlayerSeasonStat(playerSeasonStats, StatType.DefensiveTDS ) * 6) +&#xD;&#xA;  ((statManager.GetPlayerSeasonStat(playerSeasonStats, StatType.DefensiveTotalTackles) * 2) / 5) +&#xD;&#xA;        ((playerOVR * 3) /4) +&#xD;&#xA; seasonModifier;&#xD;&#xA;}&#xD;&#xA;else if(awardType == AwardType.BEST_LB)&#xD;&#xA;{&#xD;&#xA;    playerRating =   (statManager.GetPlayerSeasonStat(playerSeasonStats, StatType.DefensiveInts) * 6) +&#xD;&#xA;        (statManager.GetPlayerSeasonStat(playerSeasonStats, StatType.DLineFumbleRecoveries) * 3) +&#xD;&#xA;        (statManager.GetPlayerSeasonStat(playerSeasonStats, StatType.DLineForcedFumbles) * 3) +&#xD;&#xA;        (statManager.GetPlayerSeasonStat(playerSeasonStats, StatType.DefensiveTacklesForLoss) * 4) +&#xD;&#xA; (statManager.GetPlayerSeasonStat(playerSeasonStats, StatType.DefensiveSacks) * 5) +&#xD;&#xA; (statManager.GetPlayerSeasonStat(playerSeasonStats, StatType.DefensiveTDS ) * 10) +&#xD;&#xA;  ((statManager.GetPlayerSeasonStat(playerSeasonStats, StatType.DefensiveTotalTackles) * 3) / 5) +&#xD;&#xA;        ((playerOVR * 3) /4) +&#xD;&#xA; seasonModifier;&#xD;&#xA;&#xD;&#xA;}&#xD;&#xA;else if(awardType == AwardType.BEST_QB)&#xD;&#xA;{&#xD;&#xA;  playerRating = (statManager.GetPlayerSeasonStat(playerSeasonStats, StatType.PassTds) * 2) +&#xD;&#xA; (statManager.GetPlayerSeasonStat(playerSeasonStats, StatType.PassLongest) / 2) +&#xD;&#xA; (statManager.GetPlayerSeasonStat(playerSeasonStats, StatType.RushLongest) /2) +&#xD;&#xA; (statManager.GetPlayerSeasonStat(playerSeasonStats, StatType.ReceiveLongest) / 2) +&#xD;&#xA;        ((statManager.GetPlayerSeasonStat(playerSeasonStats, StatType.RushTds) *18)/ 4) +&#xD;&#xA;        (statManager.GetPlayerSeasonStat(playerSeasonStats, StatType.ReceiveTDs) * 4) +&#xD;&#xA;        (statManager.GetPlayerSeasonStat(playerSeasonStats, StatType.PassYards) / 40) +&#xD;&#xA;        (statManager.GetPlayerSeasonStat(playerSeasonStats, StatType.RushYards) / 25) +&#xD;&#xA;        (statManager.GetPlayerSeasonStat(playerSeasonStats, StatType.ReceiveYards) / 25) +&#xD;&#xA;        (statManager.GetPlayerSeasonStat(playerSeasonStats, StatType.PassInts) * -4) +&#xD;&#xA;        (statManager.GetPlayerSeasonStat(playerSeasonStats, StatType.RushFumbles) * -4) +&#xD;&#xA;        ((playerOVR * 3) /4) +&#xD;&#xA; seasonModifier;&#xD;&#xA;&#xD;&#xA;}&#xD;&#xA;else if(awardType == AwardType.BEST_RB)&#xD;&#xA;{&#xD;&#xA;     playerRating = (statManager.GetPlayerSeasonStat(playerSeasonStats, StatType.PassTds) * 4) +&#xD;&#xA; (statManager.GetPlayerSeasonStat(playerSeasonStats, StatType.RushLongest) /2) +&#xD;&#xA; (statManager.GetPlayerSeasonStat(playerSeasonStats, StatType.ReceiveLongest) / 2) +&#xD;&#xA;        ((statManager.GetPlayerSeasonStat(playerSeasonStats, StatType.RushTds) * 18)/ 4) +&#xD;&#xA;        (statManager.GetPlayerSeasonStat(playerSeasonStats, StatType.ReceiveTDs) * 4) +&#xD;&#xA;        (statManager.GetPlayerSeasonStat(playerSeasonStats, StatType.RushYards) / 25) +&#xD;&#xA;        (statManager.GetPlayerSeasonStat(playerSeasonStats, StatType.ReceiveYards) / 55) +&#xD;&#xA;  (statManager.GetPlayerSeasonStat(playerSeasonStats, StatType.ReceiveCatches) / 2) +&#xD;&#xA;        (statManager.GetPlayerSeasonStat(playerSeasonStats, StatType.RushFumbles) * -4) +&#xD;&#xA;        ((playerOVR * 3) /4) +&#xD;&#xA; seasonModifier;&#xD;&#xA;&#xD;&#xA;}&#xD;&#xA;else if(awardType == AwardType.BEST_TE)&#xD;&#xA;{&#xD;&#xA;  playerRating = (statManager.GetPlayerSeasonStat(playerSeasonStats, StatType.PassTds) * 4) +&#xD;&#xA; (statManager.GetPlayerSeasonStat(playerSeasonStats, StatType.RushLongest) /2) +&#xD;&#xA; (statManager.GetPlayerSeasonStat(playerSeasonStats, StatType.ReceiveLongest) / 2) +&#xD;&#xA;        (statManager.GetPlayerSeasonStat(playerSeasonStats, StatType.RushTds) * 2) +&#xD;&#xA;  (statManager.GetPlayerSeasonStat(playerSeasonStats, StatType.ReceiveCatches) / 2) +&#xD;&#xA;        (statManager.GetPlayerSeasonStat(playerSeasonStats, StatType.ReceiveTDs) * 5) +&#xD;&#xA;        (statManager.GetPlayerSeasonStat(playerSeasonStats, StatType.RushYards) / 55) +&#xD;&#xA;        (statManager.GetPlayerSeasonStat(playerSeasonStats, StatType.ReceiveYards) / 20) -&#xD;&#xA;        (statManager.GetPlayerSeasonStat(playerSeasonStats, StatType.RushFumbles) * 3) -     &#xD;&#xA; (statManager.GetPlayerSeasonStat(playerSeasonStats, StatType.ReceiveDrops) * 2) +&#xD;&#xA;       ((playerOVR * 3) /4) +&#xD;&#xA; seasonModifier;&#xD;&#xA;}&#xD;&#xA;else if(awardType == AwardType.BEST_DL)&#xD;&#xA;{&#xD;&#xA;    playerRating =   (statManager.GetPlayerSeasonStat(playerSeasonStats, StatType.DefensiveInts) * 6) +&#xD;&#xA;        (statManager.GetPlayerSeasonStat(playerSeasonStats, StatType.DLineFumbleRecoveries) * 3) +&#xD;&#xA;        (statManager.GetPlayerSeasonStat(playerSeasonStats, StatType.DLineForcedFumbles) * 3) +&#xD;&#xA;        (statManager.GetPlayerSeasonStat(playerSeasonStats, StatType.DefensiveTacklesForLoss) * 3) +&#xD;&#xA; (statManager.GetPlayerSeasonStat(playerSeasonStats, StatType.DefensivePassDeflections) * 2) +&#xD;&#xA; (statManager.GetPlayerSeasonStat(playerSeasonStats, StatType.DefensiveSacks) * 5) +&#xD;&#xA; (statManager.GetPlayerSeasonStat(playerSeasonStats, StatType.DefensiveTDS ) * 6) +&#xD;&#xA;  ((statManager.GetPlayerSeasonStat(playerSeasonStats, StatType.DefensiveTotalTackles) * 2) / 5) +&#xD;&#xA;        ((playerOVR * 3) /4) +&#xD;&#xA; seasonModifier;&#xD;&#xA;&#xD;&#xA;}&#xD;&#xA;else if(awardType == AwardType.BEST_KICK)&#xD;&#xA;{&#xD;&#xA;  playerRating = ((statManager.GetPlayerSeasonStat(playerSeasonStats, StatType.FieldGoalMade) * 3) -&#xD;&#xA;        ((statManager.GetPlayerSeasonStat(playerSeasonStats, StatType.FieldGoalAttempts) - statManager.GetPlayerSeasonStat(playerSeasonStats, StatType.FieldGoalMade)) * 5)) +&#xD;&#xA; (statManager.GetPlayerSeasonStat(playerSeasonStats, StatType.FieldGoalLongest)) +&#xD;&#xA;      ((playerOVR * 2) /4);&#xD;&#xA;}&#xD;&#xA;else if(awardType == AwardType.BEST_IL)&#xD;&#xA;{&#xD;&#xA;  playerRating = &#xD;&#xA;        ((100 - statManager.GetPlayerSeasonStat(playerSeasonStats, StatType.SacksAllowed))) +&#xD;&#xA;        ((playerOVR * 2) /4);&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;else if(awardType == AwardType.BEST_C)&#xD;&#xA;{&#xD;&#xA;  playerRating = &#xD;&#xA;        ((100 - statManager.GetPlayerSeasonStat(playerSeasonStats, StatType.SacksAllowed))) +&#xD;&#xA;        ((playerOVR * 2) /4);&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;else if(awardType == AwardType.BEST_PUNT)&#xD;&#xA;{&#xD;&#xA; int puntYards = statManager.GetPlayerSeasonStat(playerSeasonStats, StatType.PuntYards);&#xD;&#xA; int puntAttempts = statManager.GetPlayerSeasonStat(playerSeasonStats, StatType.PuntAttempts);&#xD;&#xA; int puntsIn20 = statManager.GetPlayerSeasonStat(playerSeasonStats, StatType.PuntIn20);&#xD;&#xA; int puntTouchBacks = statManager.GetPlayerSeasonStat(playerSeasonStats, StatType.PuntTouchbacks);&#xD;&#xA;     playerRating = (2 * (puntYards / puntAttempts)) + puntsIn20 - puntTouchBacks +&#xD;&#xA;      ((playerOVR * 2) /4);&#xD;&#xA;}&#xD;&#xA;else if(awardType == AwardType.BEST_DB)&#xD;&#xA;{&#xD;&#xA;    playerRating =   (statManager.GetPlayerSeasonStat(playerSeasonStats, StatType.DefensiveInts) * 6) +&#xD;&#xA;        (statManager.GetPlayerSeasonStat(playerSeasonStats, StatType.DLineFumbleRecoveries) * 3) +&#xD;&#xA;        (statManager.GetPlayerSeasonStat(playerSeasonStats, StatType.DLineForcedFumbles) * 3) +&#xD;&#xA;        (statManager.GetPlayerSeasonStat(playerSeasonStats, StatType.DefensiveTacklesForLoss) * 4) +&#xD;&#xA; (statManager.GetPlayerSeasonStat(playerSeasonStats, StatType.DefensiveSacks) * 5) +&#xD;&#xA; (statManager.GetPlayerSeasonStat(playerSeasonStats, StatType.DefensiveTDS ) * 10) +&#xD;&#xA;  ((statManager.GetPlayerSeasonStat(playerSeasonStats, StatType.DefensiveTotalTackles) * 3) / 5) +&#xD;&#xA;        ((playerOVR * 3) /4)+&#xD;&#xA;  seasonModifier;&#xD;&#xA;&#xD;&#xA;}&#xD;&#xA;else if(awardType == AwardType.BEST_SR)&#xD;&#xA;{&#xD;&#xA;   int puntReturnTDs = statManager.GetPlayerSeasonStat(playerSeasonStats, StatType.PuntReturnTDS);&#xD;&#xA;    int kickReturnTDs = statManager.GetPlayerSeasonStat(playerSeasonStats, StatType.KickReturnTDS);&#xD;&#xA;    int puntYards = statManager.GetPlayerSeasonStat(playerSeasonStats, StatType.PuntReturnYards);&#xD;&#xA;    int kickYards = statManager.GetPlayerSeasonStat(playerSeasonStats, StatType.KickReturnYards);&#xD;&#xA; int longPuntReturn = statManager.GetPlayerSeasonStat(playerSeasonStats, StatType.PuntReturnLongest);&#xD;&#xA; int longKickReturn = statManager.GetPlayerSeasonStat(playerSeasonStats, StatType.KickReturnLongest);&#xD;&#xA;    playerRating = (10 * puntReturnTDs) + (10 * kickReturnTDs) +&#xD;&#xA;      ((puntYards + kickYards + longPuntReturn + longKickReturn) / 20) + &#xD;&#xA;  ((playerOVR * 2) /4);&#xD;&#xA;}&#xD;&#xA;else if(awardType == AwardType.BEST_SR_QB)&#xD;&#xA;{&#xD;&#xA; playerRating = (statManager.GetPlayerSeasonStat(playerSeasonStats, StatType.PassTds) * 2) +&#xD;&#xA; (statManager.GetPlayerSeasonStat(playerSeasonStats, StatType.PassLongest) / 2) +&#xD;&#xA; (statManager.GetPlayerSeasonStat(playerSeasonStats, StatType.RushLongest) /2) +&#xD;&#xA; (statManager.GetPlayerSeasonStat(playerSeasonStats, StatType.ReceiveLongest) / 2) +&#xD;&#xA;        ((statManager.GetPlayerSeasonStat(playerSeasonStats, StatType.RushTds) *18)/ 4) +&#xD;&#xA;        (statManager.GetPlayerSeasonStat(playerSeasonStats, StatType.ReceiveTDs) * 4) +&#xD;&#xA;        (statManager.GetPlayerSeasonStat(playerSeasonStats, StatType.PassYards) / 40) +&#xD;&#xA;        (statManager.GetPlayerSeasonStat(playerSeasonStats, StatType.RushYards) / 25) +&#xD;&#xA;        (statManager.GetPlayerSeasonStat(playerSeasonStats, StatType.ReceiveYards) / 25) +&#xD;&#xA;        (statManager.GetPlayerSeasonStat(playerSeasonStats, StatType.PassInts) * -4) +&#xD;&#xA;        (statManager.GetPlayerSeasonStat(playerSeasonStats, StatType.RushFumbles) * -4) +&#xD;&#xA;        ((playerOVR * 3) /4) +&#xD;&#xA; seasonModifier;&#xD;&#xA;}&#xD;&#xA;else if(awardType == AwardType.BEST_DE)&#xD;&#xA;{&#xD;&#xA;    playerRating =   (statManager.GetPlayerSeasonStat(playerSeasonStats, StatType.DefensiveInts) * 6) +&#xD;&#xA;        (statManager.GetPlayerSeasonStat(playerSeasonStats, StatType.DLineFumbleRecoveries) * 3) +&#xD;&#xA;        (statManager.GetPlayerSeasonStat(playerSeasonStats, StatType.DLineForcedFumbles) * 3) +&#xD;&#xA;        (statManager.GetPlayerSeasonStat(playerSeasonStats, StatType.DefensiveTacklesForLoss) * 5) +&#xD;&#xA; (statManager.GetPlayerSeasonStat(playerSeasonStats, StatType.DefensiveSacks) * 7) +&#xD;&#xA; (statManager.GetPlayerSeasonStat(playerSeasonStats, StatType.DefensiveTDS ) * 10) +&#xD;&#xA;  ((statManager.GetPlayerSeasonStat(playerSeasonStats, StatType.DefensiveTotalTackles) * 3) / 5) +&#xD;&#xA;        ((playerOVR * 3) /4) +&#xD;&#xA; seasonModifier;&#xD;&#xA;&#xD;&#xA;}&#xD;&#xA;playerRating;" />
			<attribute name="CalculateCoachOfTheYearRating" idx="2" type="AwardsTuning_CalculateCoachOfTheYearRating" guid="6320448-1900055" default="int coachRating = 0;&#xD;&#xA;&#xD;&#xA;if(statManager != null &amp;&amp; coach != null &amp;&amp; coach.SeasonStats != null &amp;&amp; team != null)&#xD;&#xA;{&#xD;&#xA;    int overallRating = team.TEAM_RATINGOVR;&#xD;&#xA;    int seasonsWithTeam = coach.SeasonsWithTeam;&#xD;&#xA;    int thisSeasWins = coach.SeasonStats.Wins;&#xD;&#xA;    int lastSeasWins = team.TEAM_PREVSEASWINS;&#xD;&#xA;&#xD;&#xA;    // Avoid division by zero, and also nonsensical values from negative denominators.&#xD;&#xA;    if(overallRating &gt; 0)&#xD;&#xA;    {&#xD;&#xA;        if(seasonsWithTeam &lt;= 1)&#xD;&#xA;        {    &#xD;&#xA;            coachRating = ((105 * coach.SeasonStats.Wins) / overallRating + (thisSeasWins - lastSeasWins));&#xD;&#xA;        }&#xD;&#xA;        else if(seasonsWithTeam &gt; 1)&#xD;&#xA;        {    &#xD;&#xA;            coachRating = ((100 * coach.SeasonStats.Wins) / overallRating + (thisSeasWins - lastSeasWins));&#xD;&#xA;        }&#xD;&#xA;    }&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;//Clamp to 0&#xD;&#xA;if(coachRating &lt; 0)&#xD;&#xA;{&#xD;&#xA;    coachRating = 0;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;coachRating;" />
			<attribute name="CalculateDefPlayerOfWeekRating" idx="3" type="AwardsTuning_CalculateDefPlayerOfWeekRating" guid="6320448-1900049" default="// Caution! This expression is called on every signed player every week of the season&#xD;&#xA;// Be aware of what you are doing as changes here can significantly impact sim time&#xD;&#xA;&#xD;&#xA;int playerRating = 0;&#xD;&#xA;&#xD;&#xA;if(statManager!= null &amp;&amp; player != null)&#xD;&#xA;{&#xD;&#xA;    playerRating = &#xD;&#xA;        ( statManager.GetPlayerGameStat(player, StatType.DefensiveInts, week) * 6 ) +&#xD;&#xA;        ( statManager.GetPlayerGameStat(player, StatType.DLineForcedFumbles, week) * 5 ) +&#xD;&#xA;        ( statManager.GetPlayerGameStat(player, StatType.DLineFumbleRecoveries, week) * 5 ) +&#xD;&#xA;        ( statManager.GetPlayerGameStat(player, StatType.DefensiveTacklesForLoss, week) * 3 ) +&#xD;&#xA;        ( (statManager.GetPlayerGameStat(player, StatType.DefensiveTackles, week) * 2)/3 ) +&#xD;&#xA;        ( statManager.GetPlayerGameStat(player, StatType.DefensiveIntsTDS, week) * 10 );&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;playerRating;" />
			<attribute name="CalculateOffPlayerOfWeekRating" idx="4" type="AwardsTuning_CalculateOffPlayerOfWeekRating" guid="6320448-1900043" default="// Caution! This expression is called on every signed player every week of the season&#xD;&#xA;// Be aware of what you are doing as changes here can significantly impact sim time&#xD;&#xA;&#xD;&#xA;int playerRating = 0;&#xD;&#xA;&#xD;&#xA;if(statManager != null &amp;&amp; player != null)&#xD;&#xA;{&#xD;&#xA;  int fieldGoalsMissed = statManager.GetPlayerGameStat(player, StatType.FieldGoalAttempts, week) - statManager.GetPlayerGameStat(player, StatType.FieldGoalMade, week);&#xD;&#xA;&#xD;&#xA;  int passing = ( statManager.GetPlayerGameStat(player, StatType.PassTds, week) * 3 ) -&#xD;&#xA;      ( statManager.GetPlayerGameStat(player, StatType.PassInts, week) * 3 ) +&#xD;&#xA;      ( statManager.GetPlayerGameStat(player, StatType.PassYards, week) / 25 );&#xD;&#xA;&#xD;&#xA;  int rushing = ( statManager.GetPlayerGameStat(player, StatType.RushTds, week) * 5 ) -&#xD;&#xA;      ( statManager.GetPlayerGameStat(player, StatType.RushFumbles, week) * 2 ) +&#xD;&#xA;      ( statManager.GetPlayerGameStat(player, StatType.RushYards, week) / 16 );&#xD;&#xA;&#xD;&#xA;  int recieving = ( statManager.GetPlayerGameStat(player, StatType.ReceiveTDs, week) * 5 ) +&#xD;&#xA;      ( statManager.GetPlayerGameStat(player, StatType.ReceiveYards, week) / 16 );&#xD;&#xA;&#xD;&#xA;  int kicking = ( statManager.GetPlayerGameStat(player, StatType.ExtraPointMade, week) ) +&#xD;&#xA;      ( statManager.GetPlayerGameStat(player, StatType.FieldGoalMade, week) * 3 ) -&#xD;&#xA;      ( fieldGoalsMissed * 2);&#xD;&#xA;&#xD;&#xA;  int returning = ( statManager.GetPlayerGameStat(player, StatType.PuntReturnTDS, week) * 12 ) +&#xD;&#xA;      ( statManager.GetPlayerGameStat(player, StatType.KickReturnTDS, week) * 12 );&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;    playerRating = passing + rushing + recieving + kicking + returning;&#xD;&#xA;&#xD;&#xA;    // Prevent a negative rating from interceptions and fumbles&#xD;&#xA;    if (playerRating &lt; 0)&#xD;&#xA;    {&#xD;&#xA;        playerRating = 0;&#xD;&#xA;    }&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;playerRating;" />
			<attribute name="CalculatePlayerAllAmRating" idx="5" type="AwardsTuning_CalculatePlayerAllAmRating" guid="6320448-1988116" default="int playerRating = 0;&#xD;&#xA;int playerOVR = player.GetBestOverallGrade();&#xD;&#xA;int seasonModifier = (50 / team.TeamRank) + (team.TeamPrestige * 2);&#xD;&#xA;SeasonStats playerSeasonStats = statManager.GetPlayerSeasonStatsForYear(player, year);&#xD;&#xA;&#xD;&#xA;if (playerSeasonStats != null) {&#xD;&#xA;&#xD;&#xA;  PositionE position = player.Position;&#xD;&#xA;  if (position == PositionE.WR) {&#xD;&#xA;     playerRating = (statManager.GetPlayerSeasonStat(playerSeasonStats, StatType.PassTds) * 2) +&#xD;&#xA; (statManager.GetPlayerSeasonStat(playerSeasonStats, StatType.RushLongest) / 5) +&#xD;&#xA; (statManager.GetPlayerSeasonStat(playerSeasonStats, StatType.ReceiveLongest) / 5) +&#xD;&#xA;        ((statManager.GetPlayerSeasonStat(playerSeasonStats, StatType.RushTds) *18) / 4) +&#xD;&#xA;        (statManager.GetPlayerSeasonStat(playerSeasonStats, StatType.ReceiveTDs) * 5) +&#xD;&#xA;        (statManager.GetPlayerSeasonStat(playerSeasonStats, StatType.RushYards) / 30) +&#xD;&#xA;        (statManager.GetPlayerSeasonStat(playerSeasonStats, StatType.ReceiveYards) / 20) +&#xD;&#xA;  (statManager.GetPlayerSeasonStat(playerSeasonStats, StatType.ReceiveCatches) / 2) -&#xD;&#xA;        (statManager.GetPlayerSeasonStat(playerSeasonStats, StatType.RushFumbles) * 3) +&#xD;&#xA;       ((playerOVR * 2) /4);&#xD;&#xA;&#xD;&#xA;  } else if (position == PositionE.LOLB || position == PositionE.MLB || position == PositionE.ROLB) {&#xD;&#xA;    playerRating = (statManager.GetPlayerSeasonStat(playerSeasonStats, StatType.DefensiveInts) * 6) +&#xD;&#xA;       (statManager.GetPlayerSeasonStat(playerSeasonStats, StatType.DLineFumbleRecoveries) * 3) +&#xD;&#xA;       (statManager.GetPlayerSeasonStat(playerSeasonStats, StatType.DLineForcedFumbles) * 3) +&#xD;&#xA;       (statManager.GetPlayerSeasonStat(playerSeasonStats, StatType.DefensiveTacklesForLoss) * 4) +&#xD;&#xA; (statManager.GetPlayerSeasonStat(playerSeasonStats, StatType.DefensiveSacks) * 5) +&#xD;&#xA; (statManager.GetPlayerSeasonStat(playerSeasonStats, StatType.DefensiveTDS ) * 10) +&#xD;&#xA; ((statManager.GetPlayerSeasonStat(playerSeasonStats, StatType.DefensiveTotalTackles) * 3) / 5) +&#xD;&#xA;       ((playerOVR * 3) /4)+&#xD;&#xA;    seasonModifier;&#xD;&#xA;&#xD;&#xA;  } else if (position == PositionE.QB) {&#xD;&#xA;    playerRating = (statManager.GetPlayerSeasonStat(playerSeasonStats, StatType.PassTds) * 2) +&#xD;&#xA; (statManager.GetPlayerSeasonStat(playerSeasonStats, StatType.PassLongest) / (4/2)) +&#xD;&#xA; (statManager.GetPlayerSeasonStat(playerSeasonStats, StatType.RushLongest) /(4/2)) +&#xD;&#xA; (statManager.GetPlayerSeasonStat(playerSeasonStats, StatType.ReceiveLongest) / (4/2)) +&#xD;&#xA;        (statManager.GetPlayerSeasonStat(playerSeasonStats, StatType.RushTds) * 4) +&#xD;&#xA;        (statManager.GetPlayerSeasonStat(playerSeasonStats, StatType.ReceiveTDs) * 5) +&#xD;&#xA;        (statManager.GetPlayerSeasonStat(playerSeasonStats, StatType.PassYards) / 45) +&#xD;&#xA;        (statManager.GetPlayerSeasonStat(playerSeasonStats, StatType.RushYards) / 25) +&#xD;&#xA;        (statManager.GetPlayerSeasonStat(playerSeasonStats, StatType.ReceiveYards) / 25) +&#xD;&#xA;        (statManager.GetPlayerSeasonStat(playerSeasonStats, StatType.PassInts) * -4) +&#xD;&#xA;        (statManager.GetPlayerSeasonStat(playerSeasonStats, StatType.RushFumbles) * -3) +&#xD;&#xA;       ((playerOVR * 3) /4);&#xD;&#xA;&#xD;&#xA;  } else if (position == PositionE.HB || position == PositionE.FB) {&#xD;&#xA;    playerRating = (statManager.GetPlayerSeasonStat(playerSeasonStats, StatType.PassTds) * 4) +&#xD;&#xA; (statManager.GetPlayerSeasonStat(playerSeasonStats, StatType.RushLongest) /2) +&#xD;&#xA; (statManager.GetPlayerSeasonStat(playerSeasonStats, StatType.ReceiveLongest) / 2) +&#xD;&#xA;        (statManager.GetPlayerSeasonStat(playerSeasonStats, StatType.RushTds) * 4) +&#xD;&#xA;        (statManager.GetPlayerSeasonStat(playerSeasonStats, StatType.ReceiveTDs) * 2) +&#xD;&#xA;        (statManager.GetPlayerSeasonStat(playerSeasonStats, StatType.RushYards) / 35) +&#xD;&#xA;        (statManager.GetPlayerSeasonStat(playerSeasonStats, StatType.ReceiveYards) / 55) +&#xD;&#xA;  (statManager.GetPlayerSeasonStat(playerSeasonStats, StatType.ReceiveCatches) / 4) +&#xD;&#xA;        (statManager.GetPlayerSeasonStat(playerSeasonStats, StatType.RushFumbles) * -4) +&#xD;&#xA;        ((playerOVR * 2) /4)+&#xD;&#xA; seasonModifier;&#xD;&#xA;&#xD;&#xA;  } else if (position == PositionE.TE) {&#xD;&#xA;    playerRating = (statManager.GetPlayerSeasonStat(playerSeasonStats, StatType.PassTds) * 4) +&#xD;&#xA; (statManager.GetPlayerSeasonStat(playerSeasonStats, StatType.RushLongest) /2) +&#xD;&#xA; (statManager.GetPlayerSeasonStat(playerSeasonStats, StatType.ReceiveLongest) / 2) +&#xD;&#xA;        (statManager.GetPlayerSeasonStat(playerSeasonStats, StatType.RushTds) * 2) +&#xD;&#xA;        (statManager.GetPlayerSeasonStat(playerSeasonStats, StatType.ReceiveTDs) * 5) +&#xD;&#xA;        (statManager.GetPlayerSeasonStat(playerSeasonStats, StatType.RushYards) / 55) +&#xD;&#xA;        (statManager.GetPlayerSeasonStat(playerSeasonStats, StatType.ReceiveYards) / 20) +&#xD;&#xA;  (statManager.GetPlayerSeasonStat(playerSeasonStats, StatType.ReceiveCatches) / 2) -&#xD;&#xA;        (statManager.GetPlayerSeasonStat(playerSeasonStats, StatType.RushFumbles) * 3) -&#xD;&#xA;  (statManager.GetPlayerSeasonStat(playerSeasonStats, StatType.ReceiveDrops) * 2) +&#xD;&#xA;        ((playerOVR * 3) /4) +&#xD;&#xA; seasonModifier;&#xD;&#xA;  &#xD;&#xA;} else if (position == PositionE.K) {&#xD;&#xA;    playerRating = ((statManager.GetPlayerSeasonStat(playerSeasonStats, StatType.FieldGoalMade) * 3) - &#xD;&#xA;   ((statManager.GetPlayerSeasonStat(playerSeasonStats, StatType.FieldGoalAttempts) - statManager.GetPlayerSeasonStat(playerSeasonStats, StatType.FieldGoalMade)) * 5)) +&#xD;&#xA;   (statManager.GetPlayerSeasonStat(playerSeasonStats, StatType.FieldGoalLongest)) +&#xD;&#xA;   ((playerOVR * 2) /4);&#xD;&#xA;&#xD;&#xA;  } else if (position == PositionE.LG || position == PositionE.RG || position == PositionE.LT || position == PositionE.RT || position == PositionE.C) {&#xD;&#xA;    playerRating = &#xD;&#xA;        ((100 - statManager.GetPlayerSeasonStat(playerSeasonStats, StatType.SacksAllowed))) +&#xD;&#xA;        ((playerOVR * 2) /4);&#xD;&#xA;&#xD;&#xA;  } else if (position == PositionE.SS || position == PositionE.FS || position == PositionE.CB) {&#xD;&#xA;    playerRating = (statManager.GetPlayerSeasonStat(playerSeasonStats, StatType.DefensiveInts) * 6) +&#xD;&#xA;        (statManager.GetPlayerSeasonStat(playerSeasonStats, StatType.DLineFumbleRecoveries) * 3) +&#xD;&#xA;        (statManager.GetPlayerSeasonStat(playerSeasonStats, StatType.DLineForcedFumbles) * 3) +&#xD;&#xA;        (statManager.GetPlayerSeasonStat(playerSeasonStats, StatType.DefensiveTacklesForLoss) * 4) +&#xD;&#xA; (statManager.GetPlayerSeasonStat(playerSeasonStats, StatType.DefensiveSacks) * 5) +&#xD;&#xA; (statManager.GetPlayerSeasonStat(playerSeasonStats, StatType.DefensiveTDS ) * 10) +&#xD;&#xA;  ((statManager.GetPlayerSeasonStat(playerSeasonStats, StatType.DefensiveTotalTackles) * 3) / 5) +&#xD;&#xA;        ((playerOVR * 3) /4)+&#xD;&#xA;  seasonModifier;&#xD;&#xA;&#xD;&#xA;  } else if (position == PositionE.P) {&#xD;&#xA;    int puntYards = statManager.GetPlayerSeasonStat(playerSeasonStats, StatType.PuntYards);&#xD;&#xA;    int puntAttempts = statManager.GetPlayerSeasonStat(playerSeasonStats, StatType.PuntAttempts);&#xD;&#xA;    int puntsIn20 = statManager.GetPlayerSeasonStat(playerSeasonStats, StatType.PuntIn20);&#xD;&#xA; int puntTouchBacks = statManager.GetPlayerSeasonStat(playerSeasonStats, StatType.PuntTouchbacks);&#xD;&#xA;    playerRating = (2 * (puntYards / puntAttempts)) + puntsIn20 - puntTouchBacks +&#xD;&#xA;     ((playerOVR * 2) /4);&#xD;&#xA;&#xD;&#xA;  } else if (position == PositionE.PR || position == PositionE.KR) {&#xD;&#xA;    int puntReturnTDs = statManager.GetPlayerSeasonStat(playerSeasonStats, StatType.PuntReturnTDS);&#xD;&#xA;    int kickReturnTDs = statManager.GetPlayerSeasonStat(playerSeasonStats, StatType.KickReturnTDS);&#xD;&#xA;    int puntYards = statManager.GetPlayerSeasonStat(playerSeasonStats, StatType.PuntReturnYards);&#xD;&#xA;    int kickYards = statManager.GetPlayerSeasonStat(playerSeasonStats, StatType.KickReturnYards);&#xD;&#xA; int longPuntReturn = statManager.GetPlayerSeasonStat(playerSeasonStats, StatType.PuntReturnLongest);&#xD;&#xA; int longKickReturn = statManager.GetPlayerSeasonStat(playerSeasonStats, StatType.KickReturnLongest);&#xD;&#xA;    playerRating = (10 * puntReturnTDs) + (10 * kickReturnTDs) +&#xD;&#xA;      ((puntYards + kickYards + longPuntReturn + longKickReturn) / 20) + &#xD;&#xA;  ((playerOVR * 2) /4);&#xD;&#xA;&#xD;&#xA;  } else if (position == PositionE.RE || position == PositionE.LE || position == PositionE.DT) {&#xD;&#xA;      playerRating = (statManager.GetPlayerSeasonStat(playerSeasonStats, StatType.DefensiveInts) * 6) +&#xD;&#xA;        (statManager.GetPlayerSeasonStat(playerSeasonStats, StatType.DLineFumbleRecoveries) * 3) +&#xD;&#xA;        (statManager.GetPlayerSeasonStat(playerSeasonStats, StatType.DLineForcedFumbles) * 3) +&#xD;&#xA;        (statManager.GetPlayerSeasonStat(playerSeasonStats, StatType.DefensiveTacklesForLoss) * 3) +&#xD;&#xA; (statManager.GetPlayerSeasonStat(playerSeasonStats, StatType.DefensivePassDeflections) * 2) +&#xD;&#xA; (statManager.GetPlayerSeasonStat(playerSeasonStats, StatType.DefensiveSacks) * 5) +&#xD;&#xA; (statManager.GetPlayerSeasonStat(playerSeasonStats, StatType.DefensiveTDS ) * 6) +&#xD;&#xA;  ((statManager.GetPlayerSeasonStat(playerSeasonStats, StatType.DefensiveTotalTackles) * 2) / 5) +&#xD;&#xA;        ((playerOVR * 3) /4) +&#xD;&#xA; seasonModifier;&#xD;&#xA;  }&#xD;&#xA;&#xD;&#xA;} else if(awardType == AwardType.ALL_AM_1ST_PRE || awardType == AwardType.ALL_AM_2ND_PRE) {&#xD;&#xA;&#xD;&#xA; playerRating = (playerOVR+team.TeamPrestige+15);&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;playerRating;&#xD;&#xA;" />
			<attribute name="CalculatePlayerMVPRating" idx="6" type="AwardsTuning_CalculatePlayerMVPRating" guid="6320448-1988072" default="int playerRating = 0;&#xD;&#xA;int playerOVR = player.GetBestOverallGrade();&#xD;&#xA;int seasonModifier = (3 * (team.ConfWin + team.NonConfWin)) + (team.PrestigeRank * 2);&#xD;&#xA;SeasonStats playerSeasonStats = statManager.GetPlayerSeasonStatsForYear(player, year);&#xD;&#xA;if(awardType == AwardType.BEST_PLAYER)&#xD;&#xA;{&#xD;&#xA;    int fieldGoalsMissed = statManager.GetPlayerSeasonStat(playerSeasonStats, StatType.FieldGoalAttempts) - statManager.GetPlayerSeasonStat(playerSeasonStats, StatType.FieldGoalMade);&#xD;&#xA;  int passing = ( statManager.GetPlayerSeasonStat(playerSeasonStats, StatType.PassTds) * 3 ) -&#xD;&#xA;      ( statManager.GetPlayerSeasonStat(playerSeasonStats, StatType.PassInts) * 3 ) +&#xD;&#xA;      ( statManager.GetPlayerSeasonStat(playerSeasonStats, StatType.PassYards) / 25 );&#xD;&#xA;  int rushing = ( statManager.GetPlayerSeasonStat(playerSeasonStats, StatType.RushTds) * 5 ) -&#xD;&#xA;      ( statManager.GetPlayerSeasonStat(playerSeasonStats, StatType.RushFumbles) * 2 ) +&#xD;&#xA;      ( statManager.GetPlayerSeasonStat(playerSeasonStats, StatType.RushYards) / 16 );&#xD;&#xA;  int recieving = ( statManager.GetPlayerSeasonStat(playerSeasonStats, StatType.ReceiveTDs) * 5 ) +&#xD;&#xA;      ( statManager.GetPlayerSeasonStat(playerSeasonStats, StatType.ReceiveYards) / 16 );&#xD;&#xA;  int kicking = ( statManager.GetPlayerSeasonStat(playerSeasonStats, StatType.ExtraPointMade) ) +&#xD;&#xA;      ( statManager.GetPlayerSeasonStat(playerSeasonStats, StatType.FieldGoalMade) * 3 ) -&#xD;&#xA;      ( fieldGoalsMissed * 2);&#xD;&#xA;  int returning = ( statManager.GetPlayerSeasonStat(playerSeasonStats, StatType.PuntReturnTDS) * 12 ) +&#xD;&#xA;      ( statManager.GetPlayerSeasonStat(playerSeasonStats, StatType.KickReturnTDS) * 12 );&#xD;&#xA;    int offPlayerRating = passing + rushing + recieving + kicking + returning;&#xD;&#xA;    int defPlayerRating = &#xD;&#xA;        ( statManager.GetPlayerSeasonStat(playerSeasonStats, StatType.DefensiveInts) * 6 ) +&#xD;&#xA;        ( statManager.GetPlayerSeasonStat(playerSeasonStats, StatType.DLineForcedFumbles) * 5 ) +&#xD;&#xA;        ( statManager.GetPlayerSeasonStat(playerSeasonStats, StatType.DLineFumbleRecoveries) * 5 ) +&#xD;&#xA;        ( statManager.GetPlayerSeasonStat(playerSeasonStats, StatType.DefensiveSacks) * 3 ) +&#xD;&#xA;        ( (statManager.GetPlayerSeasonStat(playerSeasonStats, StatType.DefensiveTackles) * 2)/3 ) +&#xD;&#xA;        ( statManager.GetPlayerSeasonStat(playerSeasonStats, StatType.DefensiveIntsTDS) * 10 );&#xD;&#xA;    if(defPlayerRating &gt; offPlayerRating)&#xD;&#xA;    {&#xD;&#xA;        playerRating = defPlayerRating;&#xD;&#xA;    } else {&#xD;&#xA;        playerRating = offPlayerRating;&#xD;&#xA;    }&#xD;&#xA;}&#xD;&#xA;else if(awardType == AwardType.BEST_POTY || awardType == AwardType.BEST_FRESHMAN_POTY)&#xD;&#xA;{&#xD;&#xA;  playerRating = (statManager.GetPlayerSeasonStat(playerSeasonStats, StatType.PassTds) * 2) +&#xD;&#xA;        (statManager.GetPlayerSeasonStat(playerSeasonStats, StatType.RushTds) * 6) +&#xD;&#xA;        (statManager.GetPlayerSeasonStat(playerSeasonStats, StatType.ReceiveTDs) * 5) +&#xD;&#xA;        (statManager.GetPlayerSeasonStat(playerSeasonStats, StatType.PassYards) / 40) +&#xD;&#xA;        (statManager.GetPlayerSeasonStat(playerSeasonStats, StatType.RushYards) / 20) +&#xD;&#xA;        (statManager.GetPlayerSeasonStat(playerSeasonStats, StatType.ReceiveYards) / 16) +&#xD;&#xA;        (statManager.GetPlayerSeasonStat(playerSeasonStats, StatType.PassInts) * 2) +&#xD;&#xA;        (statManager.GetPlayerSeasonStat(playerSeasonStats, StatType.RushFumbles)) +&#xD;&#xA;        seasonModifier;&#xD;&#xA;}&#xD;&#xA;else if(awardType == AwardType.HEISMAN)&#xD;&#xA;{&#xD;&#xA;  playerRating = (statManager.GetPlayerSeasonStat(playerSeasonStats, StatType.PassTds) * 2) +&#xD;&#xA;        (statManager.GetPlayerSeasonStat(playerSeasonStats, StatType.RushTds) * 5) +&#xD;&#xA;        (statManager.GetPlayerSeasonStat(playerSeasonStats, StatType.ReceiveTDs) * 4) +&#xD;&#xA;        (statManager.GetPlayerSeasonStat(playerSeasonStats, StatType.PassYards) / 55) +&#xD;&#xA;        (statManager.GetPlayerSeasonStat(playerSeasonStats, StatType.RushYards) / 20) +&#xD;&#xA;        (statManager.GetPlayerSeasonStat(playerSeasonStats, StatType.ReceiveYards) / 25) +&#xD;&#xA;        ((statManager.GetPlayerSeasonStat(playerSeasonStats, StatType.PassInts) * -3)/2) +&#xD;&#xA;        (statManager.GetPlayerSeasonStat(playerSeasonStats, StatType.RushFumbles) * -1) +&#xD;&#xA;        (statManager.GetPlayerSeasonStat(playerSeasonStats, StatType.DefensiveInts) * 6) +&#xD;&#xA;        (statManager.GetPlayerSeasonStat(playerSeasonStats, StatType.DLineFumbleRecoveries) * 3) +&#xD;&#xA;        (statManager.GetPlayerSeasonStat(playerSeasonStats, StatType.DLineForcedFumbles) * 3) +&#xD;&#xA;        (statManager.GetPlayerSeasonStat(playerSeasonStats, StatType.DefensiveSacks) * 3) +&#xD;&#xA;        ((statManager.GetPlayerSeasonStat(playerSeasonStats, StatType.DefensiveTackles) * 2) / 5) +&#xD;&#xA;        (statManager.GetPlayerSeasonStat(playerSeasonStats, StatType.PuntReturnTDS) * 6) +&#xD;&#xA;        (statManager.GetPlayerSeasonStat(playerSeasonStats, StatType.KickReturnTDS) * 6) +&#xD;&#xA;        (statManager.GetPlayerSeasonStat(playerSeasonStats, StatType.PuntYards) / 100) +&#xD;&#xA;        (statManager.GetPlayerSeasonStat(playerSeasonStats, StatType.KickReturnYards) / 100);&#xD;&#xA;}&#xD;&#xA;playerRating;" />
			<attribute name="FinalistCount" idx="7" type="int" minValue="0" maxValue="100" default="5" />
			<attribute name="heismanQBBonus" idx="8" type="int" minValue="0" maxValue="100" default="4" />
