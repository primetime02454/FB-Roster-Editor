			<attribute name="TransitionPending" idx="38" type="bool" default="False" />
			<attribute name="TransitionStage" idx="39" type="Stage" />
			<attribute name="UpdateSeasonGameRequest" idx="40" type="AdvanceSeasonWeekTransaction_UpdateSeasonGameRequest" guid="6499027-1931628" final="true" default="// If the user is valid, proceed.&#xD;&#xA;if (user != null)&#xD;&#xA;{&#xD;&#xA;    Team userTeam = user.Team;&#xD;&#xA;&#xD;&#xA;    // If the advance transaction is not currently advancing, determine if a seaosn game is pending.&#xD;&#xA;    if (!IsAdvancing &amp;&amp; (PendingGameList != null))&#xD;&#xA;    {&#xD;&#xA;        FindPendingGameView.Subjects = PendingGameList;&#xD;&#xA;        FindPendingGameView.FilterTeam = userTeam;&#xD;&#xA;        FindPendingGameView.Update();&#xD;&#xA;&#xD;&#xA;        // Retrieve the pending game for this team.&#xD;&#xA;       PendingSeasonGame[] pendingGameList = FindPendingGameView.Results;&#xD;&#xA;        if (pendingGameList != null) {&#xD;&#xA;        if (pendingGameList.Population() &gt; 0)&#xD;&#xA;        {&#xD;&#xA;            PendingSeasonGame pendingGame = pendingGameList[0];&#xD;&#xA;            SeasonGame seasonGame = pendingGame.SeasonGame;&#xD;&#xA;&#xD;&#xA;            if (userTeam == seasonGame.HomeTeam)&#xD;&#xA;            {&#xD;&#xA;                if(pendingGame.HomeTeamRequest == null)&#xD;&#xA;                {&#xD;&#xA;                   {&#xD;&#xA;                     // Issue the new request to the user character.&#xD;&#xA;                     Request request = SeasonGameFlow.CreateGameRequest(seasonGame);&#xD;&#xA;                     request.Issue(user.UserEntity);&#xD;&#xA;                     pendingGame.HomeTeamRequest = request;&#xD;&#xA;                     seasonGame.HomeRequestId = request.RequestId;&#xD;&#xA;                     // if the game is complete then override the resolution to dismissed&#xD;&#xA;                     if(SeasonGameFlow.IsGameComplete(seasonGame))&#xD;&#xA;                     {&#xD;&#xA;                         request.Resolution = 3; // dismiss &#xD;&#xA;                      }&#xD;&#xA;                   }&#xD;&#xA;                }&#xD;&#xA;                else&#xD;&#xA;                {&#xD;&#xA;                   if(pendingGame.HomeTeamRequest.TargetUser == user)&#xD;&#xA;                   {                     &#xD;&#xA;                     {&#xD;&#xA;                       pendingGame.HomeTeamRequest.ClearResponse();&#xD;&#xA;                     } &#xD;&#xA;                   }&#xD;&#xA;                   else&#xD;&#xA;                   {&#xD;&#xA;                     {&#xD;&#xA;                       pendingGame.HomeTeamRequest = null;&#xD;&#xA;                       Request request = SeasonGameFlow.CreateGameRequest(seasonGame);&#xD;&#xA;                       request.Issue(user.UserEntity);&#xD;&#xA;                       pendingGame.HomeTeamRequest = request;&#xD;&#xA;                       seasonGame.HomeRequestId = request.RequestId;&#xD;&#xA;                       // if the game is complete then override the resolution to dismissed&#xD;&#xA;                       if(SeasonGameFlow.IsGameComplete(seasonGame))&#xD;&#xA;                       {&#xD;&#xA;                           request.Resolution = 3; // dismiss &#xD;&#xA;                        }&#xD;&#xA;                     }&#xD;&#xA;                   }&#xD;&#xA;                }  &#xD;&#xA;&#xD;&#xA;                // Refresh the opposing Team's Request&#xD;&#xA;                if(pendingGame.AwayTeamRequest != null)&#xD;&#xA;                {&#xD;&#xA;                    if (pendingGame.AwayTeamRequest.RequestId != -1)&#xD;&#xA;                    {&#xD;&#xA;                        pendingGame.AwayTeamRequest.Refresh();&#xD;&#xA;                    }&#xD;&#xA;                }&#xD;&#xA;            }&#xD;&#xA;            else if (userTeam == seasonGame.AwayTeam)&#xD;&#xA;            {&#xD;&#xA;                if(pendingGame.AwayTeamRequest == null)&#xD;&#xA;                {&#xD;&#xA;                   {&#xD;&#xA;                     // Issue the new request to the user character.&#xD;&#xA;                     Request request = SeasonGameFlow.CreateGameRequest(seasonGame);&#xD;&#xA;                     request.Issue(user.UserEntity);&#xD;&#xA;                     pendingGame.AwayTeamRequest = request;&#xD;&#xA;                     seasonGame.AwayRequestId = request.RequestId;&#xD;&#xA;                     // if the game is complete then override the resolution to dismissed&#xD;&#xA;                     if(SeasonGameFlow.IsGameComplete(seasonGame))&#xD;&#xA;                     {&#xD;&#xA;                         request.Resolution = 3; // dismiss &#xD;&#xA;                      }&#xD;&#xA;                   }&#xD;&#xA;                } &#xD;&#xA;                else&#xD;&#xA;                {&#xD;&#xA;                   if(pendingGame.AwayTeamRequest.TargetUser == user)&#xD;&#xA;                   {                     &#xD;&#xA;                     {&#xD;&#xA;                       pendingGame.AwayTeamRequest.ClearResponse();&#xD;&#xA;                     }&#xD;&#xA;                   }&#xD;&#xA;                   else&#xD;&#xA;                   {&#xD;&#xA;                     {&#xD;&#xA;                       pendingGame.AwayTeamRequest = null;&#xD;&#xA;                       Request request = SeasonGameFlow.CreateGameRequest(seasonGame);&#xD;&#xA;                       request.Issue(user.UserEntity);&#xD;&#xA;                       pendingGame.AwayTeamRequest = request;&#xD;&#xA;                       seasonGame.AwayRequestId = request.RequestId;&#xD;&#xA;                       // if the game is complete then override the resolution to dismissed&#xD;&#xA;                       if(SeasonGameFlow.IsGameComplete(seasonGame))&#xD;&#xA;                       {&#xD;&#xA;                           request.Resolution = 3; // dismiss &#xD;&#xA;                        }&#xD;&#xA;                     }&#xD;&#xA;                   }&#xD;&#xA;                }&#xD;&#xA;&#xD;&#xA;                // Refresh the opposing Team's Request&#xD;&#xA;                if(pendingGame.HomeTeamRequest != null )&#xD;&#xA;                {&#xD;&#xA;                    if (pendingGame.HomeTeamRequest.RequestId != -1)&#xD;&#xA;                    {&#xD;&#xA;                           pendingGame.HomeTeamRequest.Refresh();&#xD;&#xA;                    }&#xD;&#xA;                }&#xD;&#xA;            }   &#xD;&#xA;        }&#xD;&#xA;        }&#xD;&#xA;&#xD;&#xA;        FindPendingGameView.Clear();&#xD;&#xA;    }&#xD;&#xA;}" />
			<attribute name="WaitForAdvanceStage" idx="41" type="Stage" />
