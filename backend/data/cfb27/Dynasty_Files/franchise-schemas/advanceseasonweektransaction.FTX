<FranTkData fileName="Franchise-Schemas\AdvanceSeasonWeekTransaction.ftx" dataRevisionVersion="1" isSchema="True">
	<!--SCHEMAS-->
	<schemas>
		<schema name="AdvanceSeasonWeekTransaction" numMembers="42" base="Transaction" assetId="6499027" isRecordPersistent="true" majorVersionCRC="-33275872" minorVersionCRC="943424886">
			<attribute name="ActiveGame" idx="0" type="PendingSeasonGame" />
			<attribute name="ActiveGameList" idx="1" type="PendingSeasonGame[]" />
			<attribute name="ActiveSimGame" idx="2" type="SimulatedGame" />
			<attribute name="AdvanceWeekCompleteEvent" idx="3" type="AdvanceWeekCompleteEvent" />
			<attribute name="BeginAdvanceWeekEvent" idx="4" type="BeginAdvanceWeekEvent" />
			<attribute name="CareerFlow" idx="5" type="FranchiseServer_CareerFlow" />
			<attribute name="ClearSeasonGameRequest" idx="6" type="AdvanceSeasonWeekTransaction_ClearSeasonGameRequest" guid="6499027-1931632" final="true" default="// If the user is valid, proceed.&#xD;&#xA;if (user != null)&#xD;&#xA;{&#xD;&#xA;    Team userTeam = user.Team;&#xD;&#xA;&#xD;&#xA;    // If the advance transaction is not currently advancing, determine if a seaosn game is pending.&#xD;&#xA;    if (!IsAdvancing &amp;&amp; (PendingGameList != null))&#xD;&#xA;    {&#xD;&#xA;        FindPendingGameView.Subjects = PendingGameList;&#xD;&#xA;        FindPendingGameView.FilterTeam = userTeam;&#xD;&#xA;        FindPendingGameView.Update();&#xD;&#xA;&#xD;&#xA;        // Retrieve the pending game for this team.&#xD;&#xA;        PendingSeasonGame[] pendingGameList = FindPendingGameView.Results;&#xD;&#xA;        if (pendingGameList != null) {&#xD;&#xA;        if (pendingGameList.Population() &gt; 0)&#xD;&#xA;        {&#xD;&#xA;            PendingSeasonGame pendingGame = pendingGameList[0];&#xD;&#xA;            SeasonGame seasonGame = pendingGame.SeasonGame;&#xD;&#xA;&#xD;&#xA;            if(!SeasonGameFlow.IsGameComplete(seasonGame))&#xD;&#xA;            {&#xD;&#xA;            // Release the home request.&#xD;&#xA;            if (userTeam == seasonGame.HomeTeam)&#xD;&#xA;            {&#xD;&#xA;                pendingGame.HomeTeamRequest = null;&#xD;&#xA;                seasonGame.HomeRequestId = -1;&#xD;&#xA;            }&#xD;&#xA;            // Release the away request.&#xD;&#xA;            else if (userTeam == seasonGame.AwayTeam)&#xD;&#xA;            {&#xD;&#xA;                pendingGame.AwayTeamRequest = null;&#xD;&#xA;                seasonGame.AwayRequestId = -1;&#xD;&#xA;            }&#xD;&#xA;            }&#xD;&#xA;        }&#xD;&#xA;        }&#xD;&#xA;&#xD;&#xA;        FindPendingGameView.Clear();&#xD;&#xA;    }&#xD;&#xA;}&#xD;&#xA;" />
			<attribute name="CurrentCareerStage" idx="7" type="CareerStage" default="CareerStage:Invalid" />
			<attribute name="CurrentStage" idx="8" type="Stage" />
			<attribute name="EndStage" idx="9" type="Stage" />
			<attribute name="FindPendingGameView" idx="10" type="FindPendingGameForTeam" />
			<attribute name="GetGamesToSimView" idx="11" type="ProcessWeeklyGames_GetGamesToSim" />
			<attribute name="GetPendingGamesView" idx="12" type="ProcessWeeklyGames_GetPendingGames" />
			<attribute name="HandleForceWin" idx="13" type="AdvanceSeasonWeekTransaction_HandleForceWin" guid="6499027-1931657" final="true" default="if (event.NeedsResim)&#xD;&#xA;{&#xD;&#xA; InvalidatePreSimGameForTeam(event.WinTeam);&#xD;&#xA;}" />
			<attribute name="HandlePlayerSuspensionEvent" idx="14" type="AdvanceSeasonWeekTransaction_HandlePlayerSuspensionEvent" guid="6499027-2154168" final="true" default="// If the user is valid, proceed.&#xD;&#xA;if (event.Player != null)&#xD;&#xA;{&#xD;&#xA;    //Use the Team from the Event&#xD;&#xA;    Team userTeam = event.Team;&#xD;&#xA;&#xD;&#xA;    // If the advance transaction is not currently advancing, determine if a season game is pending.&#xD;&#xA;    if (!IsAdvancing &amp;&amp; (PendingGameList != null))&#xD;&#xA;    {&#xD;&#xA;        FindPendingGameView.Subjects = PendingGameList;&#xD;&#xA;        FindPendingGameView.FilterTeam = userTeam;&#xD;&#xA;        FindPendingGameView.Update();&#xD;&#xA;&#xD;&#xA;        // Retrieve the pending game for this team.&#xD;&#xA;        PendingSeasonGame[] pendingGameList = FindPendingGameView.Results;&#xD;&#xA;        if (pendingGameList != null) &#xD;&#xA;        {&#xD;&#xA;            if (pendingGameList.Population() &gt; 0)&#xD;&#xA;            {&#xD;&#xA;                PendingSeasonGame pendingGame = pendingGameList[0];&#xD;&#xA;                SeasonGame seasonGame = pendingGame.SeasonGame;&#xD;&#xA;&#xD;&#xA;                if(!SeasonGameFlow.IsGameComplete(seasonGame))&#xD;&#xA;                {&#xD;&#xA;                    // Release the home request.&#xD;&#xA;                    if (userTeam == seasonGame.HomeTeam)&#xD;&#xA;                    {&#xD;&#xA;                        SeasonGameRequest request = pendingGame.HomeTeamRequest;&#xD;&#xA;                        request.IsLocked = event.IsSuspended;&#xD;&#xA;                        request.Refresh();&#xD;&#xA;                    }&#xD;&#xA;                    // Release the away request.&#xD;&#xA;                    else if (userTeam == seasonGame.AwayTeam)&#xD;&#xA;                    {&#xD;&#xA;                        SeasonGameRequest request = pendingGame.AwayTeamRequest;&#xD;&#xA;                        request.IsLocked = event.IsSuspended;&#xD;&#xA;                        request.Refresh();&#xD;&#xA;                    }&#xD;&#xA;                }&#xD;&#xA;            }&#xD;&#xA;        }&#xD;&#xA;&#xD;&#xA;        FindPendingGameView.Clear();&#xD;&#xA;    }&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA; " />
			<attribute name="HandleRegisterUser" idx="15" type="AdvanceSeasonWeekTransaction_HandleRegisterUser" guid="6499027-1931648" final="true" default="FranchiseUser newUser = event.User;&#xD;&#xA;Team userTeam = newUser.Team;&#xD;&#xA;&#xD;&#xA;InvalidatePreSimGameForTeam(userTeam);" />
			<attribute name="HandleTrade_Trade" idx="16" type="AdvanceSeasonWeekTransaction_HandleTrade_Trade" guid="6499027-1931644" final="true" default="Team teamA = event.TeamA;&#xD;&#xA;Team teamB = event.TeamB;&#xD;&#xA;&#xD;&#xA;InvalidatePreSimGameForTeam(teamA);&#xD;&#xA;InvalidatePreSimGameForTeam(teamB);" />
			<attribute name="HasLeagueStarted" idx="17" type="bool" default="False" />
			<attribute name="InjuryEval" idx="18" type="InjuryEval" />
			<attribute name="InvalidatePreSimGameForTeam" idx="19" type="AdvanceSeasonWeekTransaction_InvalidatePreSimGameForTeam" guid="6499027-1931652" final="true" default="// If the advance transaction is not currently advancing, determine if a season game is pending.&#xD;&#xA;if (!IsAdvancing &amp;&amp; (PendingGameList != null) &amp;&amp; (team != null))&#xD;&#xA;{&#xD;&#xA;    // Find the pending game for the userTeam&#xD;&#xA;    FindPendingGameView.Subjects = PendingGameList;&#xD;&#xA;    FindPendingGameView.FilterTeam = team;&#xD;&#xA;    FindPendingGameView.Update();&#xD;&#xA;&#xD;&#xA;    // Retrieve the pending game for this team.&#xD;&#xA;    PendingSeasonGame[] pendingGameList = FindPendingGameView.Results;&#xD;&#xA;    if (pendingGameList != null) &#xD;&#xA;    {&#xD;&#xA;        if (pendingGameList.Population() &gt; 0)&#xD;&#xA;        {&#xD;&#xA;            PendingSeasonGame pendingGame = pendingGameList[0];&#xD;&#xA;            SeasonGame seasonGame = pendingGame.SeasonGame;&#xD;&#xA;&#xD;&#xA;            if(!seasonGame.HasBeenPublished &amp;&amp; seasonGame.IsSimmed &amp;&amp; (seasonGame.GameStatus != GameStatus.Unplayed))&#xD;&#xA;            {&#xD;&#xA;                // Do this first because the function runs its own validation before clearing the cache&#xD;&#xA;                StatManager.ClearPresimCache(seasonGame);&#xD;&#xA;&#xD;&#xA;                seasonGame.GameStatus = GameStatus.Unplayed;&#xD;&#xA;                seasonGame.HomeScore = 0;&#xD;&#xA;                seasonGame.HomeScoreOT = 0;&#xD;&#xA;                seasonGame.HomeScoreQuarter1 = 0;&#xD;&#xA;                seasonGame.HomeScoreQuarter2 = 0;&#xD;&#xA;                seasonGame.HomeScoreQuarter3 = 0;&#xD;&#xA;                seasonGame.HomeScoreQuarter4 = 0;&#xD;&#xA;                seasonGame.AwayScore = 0;&#xD;&#xA;                seasonGame.AwayScoreOT = 0;&#xD;&#xA;                seasonGame.AwayScoreQuarter1 = 0;&#xD;&#xA;                seasonGame.AwayScoreQuarter2 = 0;&#xD;&#xA;                seasonGame.AwayScoreQuarter3 = 0;&#xD;&#xA;                seasonGame.AwayScoreQuarter4 = 0;&#xD;&#xA;                seasonGame.HomeTeamStatus = GameTeamStatus.Pending;&#xD;&#xA;                seasonGame.AwayTeamStatus = GameTeamStatus.Pending;&#xD;&#xA;                seasonGame.IsSimmed = false;&#xD;&#xA;                seasonGame.IsOvertimeGame = false;&#xD;&#xA;                 seasonGame.QuarterLengthMins = 15;&#xD;&#xA;            }&#xD;&#xA;&#xD;&#xA;        }&#xD;&#xA;    }&#xD;&#xA;    FindPendingGameView.Clear();&#xD;&#xA;}" />
			<attribute name="IsAdvancing" idx="20" type="bool" default="False" />
			<attribute name="IsBlocking" idx="21" type="bool" default="True" />
			<attribute name="IsDone" idx="22" type="bool()" guid="6499027-1895538" />
			<attribute name="IsDynamic" idx="23" type="bool" default="False" />
