	<schemas>
		<schema name="TeamPopularityEval" numMembers="20" base="Module" assetId="6494942" isRecordPersistent="true" majorVersionCRC="1622323806" minorVersionCRC="-1685779552">
			<attribute name="CalculateCurrentPopularityForSeasonGame" idx="0" type="TeamPopularityEval_CalculateCurrentPopularityForSeasonGame" guid="6494942-1913287" final="true" default="PopularityComponentTable newCurrentPopularity = new PopularityComponentTable;&#xD;&#xA;&#xD;&#xA;int nationalModifier = team.CurrentPopularity.NationalPopularity;&#xD;&#xA;int regionalModifier = team.CurrentPopularity.RegionalPopularity;&#xD;&#xA;int localModifier = team.CurrentPopularity.LocalPopularity;&#xD;&#xA;&#xD;&#xA;bool isWin = false;&#xD;&#xA;if((team == seasonGame.AwayTeam &amp;&amp; seasonGame.AwayScore &gt; seasonGame.HomeScore) || (team == seasonGame.HomeTeam &amp;&amp; seasonGame.HomeScore &gt; seasonGame.AwayScore))&#xD;&#xA;{&#xD;&#xA; isWin = true;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;if(seasonGame.SeasonWeekType == SeasonWeekType.PreSeason)&#xD;&#xA;{&#xD;&#xA;       localModifier = localModifier + 0;&#xD;&#xA;       regionalModifier = regionalModifier + 0;&#xD;&#xA;       nationalModifier = nationalModifier + 0;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;if(seasonGame.SeasonWeekType == SeasonWeekType.RegularSeason)&#xD;&#xA;{      &#xD;&#xA; if(seasonGame.TimeOfDay &gt; 1150 &amp;&amp; seasonGame.DayOfWeek == DayOfWeek.Monday)&#xD;&#xA; {&#xD;&#xA;  if(isWin == true)&#xD;&#xA;  {&#xD;&#xA;   localModifier = localModifier + 6;&#xD;&#xA;   regionalModifier = regionalModifier + 5;&#xD;&#xA;   nationalModifier = nationalModifier + 6;&#xD;&#xA;  }&#xD;&#xA;  else&#xD;&#xA;  {&#xD;&#xA;   localModifier = localModifier - 6;&#xD;&#xA;   regionalModifier = regionalModifier - 5;&#xD;&#xA;   nationalModifier = nationalModifier - 4;&#xD;&#xA;  }&#xD;&#xA; }   &#xD;&#xA; else if(seasonGame.TimeOfDay &gt; 1150 &amp;&amp; seasonGame.DayOfWeek == DayOfWeek.Sunday)&#xD;&#xA; {&#xD;&#xA;  if(isWin == true)&#xD;&#xA;  {&#xD;&#xA;   localModifier = localModifier + 6;&#xD;&#xA;   regionalModifier = regionalModifier + 5;&#xD;&#xA;   nationalModifier = nationalModifier + 6;&#xD;&#xA;  }&#xD;&#xA;  else&#xD;&#xA;  {&#xD;&#xA;   localModifier = localModifier - 6;&#xD;&#xA;   regionalModifier = regionalModifier - 5;&#xD;&#xA;   nationalModifier = nationalModifier - 4;&#xD;&#xA;  }&#xD;&#xA; }&#xD;&#xA; else if(seasonGame.ThanksgivingFlag == true)&#xD;&#xA; {&#xD;&#xA;  if(isWin == true)&#xD;&#xA;  {&#xD;&#xA;   localModifier = localModifier + 6;&#xD;&#xA;   regionalModifier = regionalModifier + 5;&#xD;&#xA;   nationalModifier = nationalModifier + 6;&#xD;&#xA;  }&#xD;&#xA;  else&#xD;&#xA;  {&#xD;&#xA;   localModifier = localModifier - 6;&#xD;&#xA;   regionalModifier = regionalModifier - 5;&#xD;&#xA;   nationalModifier = nationalModifier - 6;&#xD;&#xA;  }&#xD;&#xA; }&#xD;&#xA; else if(seasonGame.SeasonWeek &lt;= 17)&#xD;&#xA; {&#xD;&#xA;  if(isWin == true)&#xD;&#xA;  {&#xD;&#xA;   localModifier = localModifier + 6;&#xD;&#xA;   regionalModifier = regionalModifier + 5;&#xD;&#xA;   nationalModifier = nationalModifier + 4;&#xD;&#xA;  }&#xD;&#xA;  else&#xD;&#xA;  {&#xD;&#xA;   localModifier = localModifier - 6;&#xD;&#xA;   regionalModifier = regionalModifier - 5;&#xD;&#xA;   nationalModifier = nationalModifier - 3;&#xD;&#xA;  }&#xD;&#xA; }                     &#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;if(seasonGame.SeasonWeekType == SeasonWeekType.BowlSeason1)&#xD;&#xA;{&#xD;&#xA; if(isWin == true)&#xD;&#xA; {&#xD;&#xA;  localModifier = (localModifier * 110) / 100;&#xD;&#xA;  regionalModifier = (regionalModifier * 110) / 100;&#xD;&#xA;  nationalModifier = (nationalModifier * 105) / 100;&#xD;&#xA; }&#xD;&#xA; else&#xD;&#xA; {&#xD;&#xA;  localModifier = (localModifier * 105) / 100;&#xD;&#xA;  regionalModifier = (regionalModifier * 104) / 100;&#xD;&#xA;  nationalModifier = (nationalModifier * 101) / 100;&#xD;&#xA; }&#xD;&#xA;}&#xD;&#xA;                &#xD;&#xA;if(seasonGame.SeasonWeekType == SeasonWeekType.BowlSeason2)&#xD;&#xA;{&#xD;&#xA; if(isWin == true)&#xD;&#xA; {&#xD;&#xA;  localModifier = (localModifier * 115) / 100;&#xD;&#xA;  regionalModifier = (regionalModifier * 115) / 100;&#xD;&#xA;  nationalModifier = (nationalModifier * 110) / 100;&#xD;&#xA; }&#xD;&#xA; else&#xD;&#xA; {&#xD;&#xA;  localModifier = (localModifier * 105) / 100;&#xD;&#xA;  regionalModifier = (regionalModifier * 105) / 100;&#xD;&#xA;  nationalModifier = (nationalModifier * 105) / 100;&#xD;&#xA; }&#xD;&#xA;}&#xD;&#xA;                &#xD;&#xA;if(seasonGame.SeasonWeekType == SeasonWeekType.BowlSeason3)&#xD;&#xA;{&#xD;&#xA; if(isWin == true)&#xD;&#xA; {&#xD;&#xA;  localModifier = (localModifier * 120) / 100;&#xD;&#xA;  regionalModifier = (regionalModifier * 120) / 100;&#xD;&#xA;  nationalModifier = (nationalModifier * 115) / 100;&#xD;&#xA; }&#xD;&#xA; else&#xD;&#xA; {&#xD;&#xA;  localModifier = (localModifier * 110) / 100;&#xD;&#xA;  regionalModifier = (regionalModifier * 110) / 100;&#xD;&#xA;  nationalModifier = (nationalModifier * 105) / 100;&#xD;&#xA; }&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;if(seasonGame.SeasonWeekType == SeasonWeekType.NationalChampionship)&#xD;&#xA;{&#xD;&#xA; if(isWin == true)&#xD;&#xA; {&#xD;&#xA;  localModifier = 100;&#xD;&#xA;  regionalModifier = 100;&#xD;&#xA;  nationalModifier = 100;&#xD;&#xA; }&#xD;&#xA; else&#xD;&#xA; {&#xD;&#xA;  localModifier = (localModifier * 110) / 100;&#xD;&#xA;  regionalModifier = (regionalModifier * 110) / 100;&#xD;&#xA;  nationalModifier = (nationalModifier * 110) / 100;&#xD;&#xA; }&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;if (team.PresentationId == 20)&#xD;&#xA;{&#xD;&#xA; localModifier = 99;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;// Update the base value from modifiers&#xD;&#xA;&#xD;&#xA;int localPopularity = localModifier;&#xD;&#xA;if(localPopularity &gt; 100)&#xD;&#xA;{&#xD;&#xA; localPopularity = 100;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;if(localPopularity &lt; 5)&#xD;&#xA;{&#xD;&#xA; localPopularity = 5;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;int nationalPopularity = nationalModifier;&#xD;&#xA;if(nationalPopularity &gt; 100)&#xD;&#xA;{&#xD;&#xA; nationalPopularity = 100;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;if(nationalPopularity &lt; 5)&#xD;&#xA;{&#xD;&#xA; nationalPopularity = 5;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;int regionalPopularity = regionalModifier;&#xD;&#xA;if(regionalPopularity &gt; 100)&#xD;&#xA;{&#xD;&#xA; regionalPopularity = 100;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;if(regionalPopularity &lt; 5)&#xD;&#xA;{&#xD;&#xA; regionalPopularity = 5;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;newCurrentPopularity.LocalPopularity = localPopularity;&#xD;&#xA;newCurrentPopularity.NationalPopularity = nationalPopularity;&#xD;&#xA;newCurrentPopularity.RegionalPopularity = regionalPopularity;&#xD;&#xA;&#xD;&#xA;newCurrentPopularity;" />
