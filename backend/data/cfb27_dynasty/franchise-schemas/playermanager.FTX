			<attribute name="ReSignPlayer" idx="36" type="PlayerManager_ReSignPlayer" guid="6498478-1925218" final="true" default="// TODO: Remove this call. All callers should call TeamManager directly.&#xD;&#xA;TeamManager.ReSignPlayer(team, player, contract, wasFranchiseTagged);" />
			<attribute name="RetirePlayer" idx="37" type="PlayerManager_RetirePlayer" guid="6498478-1925180" final="true" default="// If the player is a free agent, retire him from the league.&#xD;&#xA;if (Franchise.FreeAgents.Contains(player))&#xD;&#xA;{&#xD;&#xA;    Franchise.FreeAgents.FindAndErase(player);&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;if (player.GameStats != null)&#xD;&#xA;{&#xD;&#xA;  player.GameStats.EraseAll();&#xD;&#xA;  player.GameStats = null;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;// If the player is currently on a team, retire him from the team.&#xD;&#xA;// Otherwise, just set the player's contract to retired.&#xD;&#xA;if (team == null)&#xD;&#xA;{&#xD;&#xA;    Team nullTeam = null;&#xD;&#xA;    UpdatePlayerContractStatus(player, team, nullTeam, PlayerContractStatus.None, PlayerContractStatus.Retired, false, false) ;&#xD;&#xA;}&#xD;&#xA;else&#xD;&#xA;{&#xD;&#xA;    TeamManager.RetirePlayer(team, player) ;&#xD;&#xA;}&#xD;&#xA;" />
			<attribute name="SchoolYearTransferBonus" idx="38" type="int[]" />
			<attribute name="SignPlayer" idx="39" type="PlayerManager_SignPlayer" guid="6498478-1925199" final="true" default="// TODO: Remove this call. All callers should call TeamManager directly.&#xD;&#xA;TeamManager.SignPlayer(team, player, contract);&#xD;&#xA;" />
			<attribute name="StatManagerRef" idx="40" type="StatManager" />
			<attribute name="TeamManager" idx="41" type="TeamManager" />
			<attribute name="TEPortalRatingBoost" idx="42" type="int" minValue="0" maxValue="10" default="0" />
