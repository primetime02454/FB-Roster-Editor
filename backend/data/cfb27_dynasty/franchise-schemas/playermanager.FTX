			<attribute name="ConvertPlayerPosition" idx="7" type="PlayerManager_ConvertPlayerPosition" guid="6498478-1925235" final="true" default="PositionE oldPosition = player.Position;&#xD;&#xA;PlayerType oldPlayerType = player.PlayerType;&#xD;&#xA;&#xD;&#xA;// Set the player position and player type.&#xD;&#xA;player.Position = newPosition;&#xD;&#xA;player.PlayerType = newPlayerType;&#xD;&#xA;&#xD;&#xA;// Send the convert position event.&#xD;&#xA;ConvertPlayerPositionEvent.Team = team;&#xD;&#xA;ConvertPlayerPositionEvent.Player = player;&#xD;&#xA;ConvertPlayerPositionEvent.OldPosition = oldPosition;&#xD;&#xA;ConvertPlayerPositionEvent.NewPosition = newPosition;&#xD;&#xA;ConvertPlayerPositionEvent.OldPlayerType = oldPlayerType;&#xD;&#xA;ConvertPlayerPositionEvent.NewPlayerType = newPlayerType;&#xD;&#xA;ConvertPlayerPositionEvent.Send();&#xD;&#xA;&#xD;&#xA;// Clear the convert position event members.&#xD;&#xA;ConvertPlayerPositionEvent.Team = null;&#xD;&#xA;ConvertPlayerPositionEvent.Player = null;&#xD;&#xA;" />
			<attribute name="ConvertPlayerPositionEvent" idx="8" type="Player_ConvertPositionEvent" />
			<attribute name="DBPortalRatingBoost" idx="9" type="int" minValue="0" maxValue="10" default="0" />
			<attribute name="DeletePlayer" idx="10" type="PlayerManager_DeletePlayer" guid="6498478-1925195" final="true" default="// If the player is a free agent, remove him from the free agent pool.&#xD;&#xA;if (Franchise.FreeAgents.Contains(player))&#xD;&#xA;{&#xD;&#xA;    Franchise.FreeAgents.FindAndErase(player);&#xD;&#xA;}&#xD;&#xA;// If the player is retired, remove him from the retired pool.&#xD;&#xA;else if ( Franchise.RetiredPlayers.Contains(player))&#xD;&#xA;{&#xD;&#xA;    Franchise.RetiredPlayers.FindAndErase(player);&#xD;&#xA;}&#xD;&#xA;" />
			<attribute name="DLPortalRatingBoost" idx="11" type="int" minValue="0" maxValue="10" default="0" />
