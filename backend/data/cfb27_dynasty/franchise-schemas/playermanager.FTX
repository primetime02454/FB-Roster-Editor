			<attribute name="TransferPlayerToPortal" idx="44" type="PlayerManager_TransferPlayerToPortal" guid="6498478-2083040" />
			<attribute name="UnRetirePlayer" idx="45" type="PlayerManager_UnRetirePlayer" guid="6498478-1925214" final="true" default="Franchise.FreeAgents.Append(player);&#xD;&#xA;&#xD;&#xA;if (Franchise.HallOfFamePlayers.Contains(player))&#xD;&#xA;{&#xD;&#xA;    Franchise.HallOfFamePlayers.FindAndErase(player);&#xD;&#xA;}&#xD;&#xA;" />
			<attribute name="UpdatePlayerContractStatus" idx="46" type="PlayerManager_UpdatePlayerContractStatus" guid="6498478-1925185" final="true" default="// If the player changed teams, clear his consecutive years with team.&#xD;&#xA;if ((oldTeam != newTeam) || (newTeam == null))&#xD;&#xA;{&#xD;&#xA;    player.PLYR_CONSECYEARSWITHTEAM = 0;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;// If the team has changed teams and the old team is non-null, store it as the previous team.&#xD;&#xA;if ((oldTeam != null) &amp;&amp; (oldTeam != newTeam))&#xD;&#xA;{&#xD;&#xA;    player.PrevTeamIndex = oldTeam.TeamIndex;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;// If the new team is valid, set the player's team index.&#xD;&#xA;if (newTeam != null)&#xD;&#xA;{&#xD;&#xA;    player.TeamIndex = newTeam.TeamIndex;&#xD;&#xA;}&#xD;&#xA;// Otherwise, clear the team index.&#xD;&#xA;else&#xD;&#xA;{&#xD;&#xA;    player.TeamIndex = TeamIndex.None;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;Team playerPrevTeam = null;&#xD;&#xA;if ( newTeam == null &amp;&amp; oldTeam == null &amp;&amp; player.PrevTeamIndex != TeamIndex.None )&#xD;&#xA;{&#xD;&#xA;     // Get Player's Previous Team Asset for Free Agents&#xD;&#xA;     playerPrevTeam = TeamManager.FindTeamByTeamIndex(player.PrevTeamIndex);&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;// Construct the event.&#xD;&#xA;Player_UpdatePlayerContractStatusEvent event = new Player_UpdatePlayerContractStatusEvent;&#xD;&#xA;event.Player = player;&#xD;&#xA;event.OldTeam = oldTeam;&#xD;&#xA;event.NewTeam = newTeam;&#xD;&#xA;event.PlayerPrevTeam = playerPrevTeam;&#xD;&#xA;event.OldContractStatus = oldContractStatus;&#xD;&#xA;event.NewContractStatus = newContractStatus;&#xD;&#xA;event.WasFranchiseTagged = wasFranchiseTagged;&#xD;&#xA;&#xD;&#xA;// Log the event.&#xD;&#xA;LogUpdatePlayerContractStatus(event);&#xD;&#xA;&#xD;&#xA;// Send the event.&#xD;&#xA;event.Send();" />
			<attribute name="UserPlayerRetirementEvent" idx="47" type="UserPlayerRetirementEvent" />
			<attribute name="WRPortalRatingBoost" idx="48" type="int" minValue="0" maxValue="10" default="0" />
		</schema>
