			<attribute name="LogLeaguePlayerInfo" idx="23" type="none()" guid="6498478-1925230" final="true" />
			<attribute name="LogUpdatePlayerContractStatus" idx="24" type="PlayerManager_LogUpdatePlayerContractStatus" guid="6498478-1925225" final="true" />
			<attribute name="MapEnumToPlayerPosition" idx="25" type="PlayerManager_MapEnumToPlayerPosition" guid="6498478-1925209" final="true" default="FilterPlayerPosFromEnumView = new FilterPlayerPosFromEnum ;&#xD;&#xA;FilterPlayerPosFromEnumView.PositionEnum = Position ;&#xD;&#xA;FilterPlayerPosFromEnumView.Subjects = Franchise.League.PlayerPositions ;&#xD;&#xA;FilterPlayerPosFromEnumView.Update() ;&#xD;&#xA;&#xD;&#xA;PlayerPosition position = FilterPlayerPosFromEnumView.Results[0] ;&#xD;&#xA;FilterPlayerPosFromEnumView = null ;&#xD;&#xA;position;" />
