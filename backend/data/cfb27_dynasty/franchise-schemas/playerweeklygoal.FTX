			<attribute name="LegacyScoreTitle" idx="33" type="string" maxLen="31" />
			<attribute name="MarketplaceRepeatableReward" idx="34" type="int" minValue="0" maxValue="60000" default="0" />
			<attribute name="MarketplaceRepeatableRewardType" idx="35" type="MarketplaceRewardType" default="MarketplaceRewardType:Invalid" />
			<attribute name="MarketplaceReward" idx="36" type="MarketplaceReward" />
			<attribute name="MaxCompletionValue" idx="37" type="int" minValue="0" maxValue="2000" default="500" />
			<attribute name="MaxConfidenceAward" idx="38" type="int" minValue="-50" maxValue="50" default="10" />
			<attribute name="MaxExperienceAward" idx="39" type="int" minValue="0" maxValue="5000" default="500" />
			<attribute name="MinCompletionValue" idx="40" type="int" minValue="0" maxValue="2000" default="0" />
			<attribute name="MinConfidenceAward" idx="41" type="int" minValue="-50" maxValue="50" default="0" />
			<attribute name="MinExperienceAward" idx="42" type="int" minValue="0" maxValue="5000" default="0" />
			<attribute name="NextWeeklyGoal" idx="43" type="PlayerWeeklyGoal" />
			<attribute name="PartialMarketplaceRepeatableReward" idx="44" type="int" minValue="0" maxValue="60000" default="0" />
			<attribute name="PercentageSpline" idx="45" type="Spline" />
			<attribute name="PositionCategory" idx="46" type="PositionCategory" default="PositionCategory:All" />
			<attribute name="PrimaryStat" idx="47" type="StatType" default="StatType:Invalid_" />
			<attribute name="PrimaryTeamStat" idx="48" type="TeamStatType" default="TeamStatType:Invalid" />
			<attribute name="QuestlineIdentifier" idx="49" type="QuestlineIdentifier" default="QuestlineIdentifier:NullQuest" />
