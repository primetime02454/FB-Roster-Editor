	<!--SCHEMAS-->
	<schemas>
		<schema name="PlayerWeeklyGoal" numMembers="55" base="PlayerGoal" defaultStoreCapacity="6" assetId="6536970" defaultStoreGroupId="2" isRecordPersistent="true" defaultStoreGroupName="Tuning" defaultStoreOptimizationId="1" defaultStoreOptimizationName="Default_" defaultStoreStringCapacity="393" majorVersionCRC="-1633995777" minorVersionCRC="607364783">
			<attribute name="AchievementWeight" idx="0" type="int" minValue="0" maxValue="100" default="0" />
			<attribute name="AgeSpline" idx="1" type="Spline" />
			<attribute name="BaseCompletionValue" idx="2" type="int" minValue="-1" maxValue="20000" default="0" />
			<attribute name="BaseConfidenceAward" idx="3" type="int" minValue="-50" maxValue="50" default="0" />
