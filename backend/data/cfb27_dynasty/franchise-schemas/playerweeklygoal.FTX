			<attribute name="IconLibraryId" idx="25" type="LegacyScoreMomentIconLibraryId" default="LegacyScoreMomentIconLibraryId:INVALID" />
			<attribute name="InvertedGoalDownsPlayedThreshold" idx="26" type="int" minValue="0" maxValue="100" default="10" />
