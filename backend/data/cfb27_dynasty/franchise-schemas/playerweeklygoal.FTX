			<attribute name="DevelopmentSpline" idx="14" type="Spline" />
			<attribute name="FromStats" idx="15" type="bool" default="False" />
			<attribute name="GetCompletionValue" idx="16" type="PlayerWeeklyGoal_GetCompletionValue" guid="6536970-1935075" final="true" default="int value = BaseCompletionValue;&#xD;&#xA;if (value &lt; MinCompletionValue)&#xD;&#xA;{&#xD;&#xA;    value = MinCompletionValue;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;if (value &gt; MaxCompletionValue)&#xD;&#xA;{ &#xD;&#xA;    value = MaxCompletionValue;&#xD;&#xA;}&#xD;&#xA;value;" />
			<attribute name="GetConfidenceAward" idx="17" type="PlayerWeeklyGoal_GetConfidenceAward" guid="6536970-1935096" final="true" default="int confidence = 0;&#xD;&#xA;&#xD;&#xA;if (isComplete)&#xD;&#xA;{&#xD;&#xA;    confidence = (confidence + BaseConfidenceAward);&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;if (BasePartialConfidenceAward &gt; 0)&#xD;&#xA;{&#xD;&#xA;    confidence = (confidence + BasePartialConfidenceAward);&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;if (player != null &amp;&amp; evalInfo != null)&#xD;&#xA;{&#xD;&#xA;    int ageMod = AgeSpline.CalculateY(player.Age);&#xD;&#xA;    PositionE position = player.Position;&#xD;&#xA;&#xD;&#xA;    confidence = (confidence * ageMod) / 100;&#xD;&#xA;&#xD;&#xA;    if (player.TraitDevelopment == TraitDevelopment.XFactor)&#xD;&#xA;    {&#xD;&#xA;        confidence = (confidence * 175) / 100;&#xD;&#xA;    }&#xD;&#xA;&#xD;&#xA;    if (player.TraitDevelopment == TraitDevelopment.Superstar)&#xD;&#xA;    {&#xD;&#xA;        confidence = (confidence * 125) / 100;&#xD;&#xA;    }&#xD;&#xA;&#xD;&#xA;   if (player.TraitDevelopment == TraitDevelopment.Normal)&#xD;&#xA;    {&#xD;&#xA;        confidence = (confidence * 75) / 100;&#xD;&#xA;    }&#xD;&#xA;   &#xD;&#xA;    if (evalInfo.IsPlayerStarter)&#xD;&#xA;    {&#xD;&#xA;        if (player.PLYR_DRAFTROUND == 1)&#xD;&#xA;        {&#xD;&#xA;            confidence = confidence;&#xD;&#xA;        }&#xD;&#xA;        &#xD;&#xA; if (player.InjuryRating &gt; 75)&#xD;&#xA;        {&#xD;&#xA;            confidence = (confidence * 115) / 100;&#xD;&#xA;        }&#xD;&#xA;    }&#xD;&#xA;    else if (PrimaryTeamStat != TeamStatType.Invalid)&#xD;&#xA;    {&#xD;&#xA;   if ((position &gt;= PositionE.FirstOffenseLine_ &amp;&amp; position &lt;= PositionE.LastOffenseLine_) || (position &gt;= PositionE.FirstDefenseLine_ &amp;&amp; position &lt;= PositionE.LastDefenseLine_))&#xD;&#xA;   {&#xD;&#xA;         confidence = 0;&#xD;&#xA;   }&#xD;&#xA; else&#xD;&#xA; {&#xD;&#xA;  confidence = MinConfidenceAward;&#xD;&#xA; }&#xD;&#xA;      }&#xD;&#xA;&#xD;&#xA; if (player.ConfidenceRating &gt; 85)&#xD;&#xA; {&#xD;&#xA; confidence = MinConfidenceAward;&#xD;&#xA; if (MaxConfidenceAward &lt; 0)&#xD;&#xA; {&#xD;&#xA;  confidence = MaxConfidenceAward;&#xD;&#xA; }&#xD;&#xA;  &#xD;&#xA; }&#xD;&#xA; else if (player.ConfidenceRating &lt; 30)&#xD;&#xA; {&#xD;&#xA; confidence = (confidence * 250) / 100;&#xD;&#xA; if (MaxConfidenceAward &lt; 0)&#xD;&#xA; {&#xD;&#xA;  confidence = MinConfidenceAward;&#xD;&#xA; }&#xD;&#xA; }&#xD;&#xA;   &#xD;&#xA;    if (player.IsUserControlled)&#xD;&#xA;    {&#xD;&#xA;        confidence = (confidence * 75) / 100;&#xD;&#xA;    }&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;if (confidence &lt; MinConfidenceAward)&#xD;&#xA;{&#xD;&#xA;    confidence = MinConfidenceAward;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;if (confidence &gt; MaxConfidenceAward)&#xD;&#xA;{ &#xD;&#xA;    confidence = MaxConfidenceAward;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;confidence;" />
			<attribute name="GetExperienceAward" idx="18" type="PlayerWeeklyGoal_GetExperienceAward" guid="6536970-1935066" final="true" default="//Returns ExperienceAward as Int&#xD;&#xA;int award = 0;&#xD;&#xA;&#xD;&#xA;if (isComplete)&#xD;&#xA;{&#xD;&#xA;    award = (award + BaseExperienceAward);&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;if (BasePartialExperienceAward &gt; 0)&#xD;&#xA;{&#xD;&#xA;    award = (award + BasePartialExperienceAward);&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;int ageMod = AgeSpline.CalculateY(player.Age);&#xD;&#xA;&#xD;&#xA;PositionE position = player.Position;&#xD;&#xA;&#xD;&#xA;int devTrait = 0;&#xD;&#xA;&#xD;&#xA;if (player.TraitDevelopment == TraitDevelopment.XFactor)&#xD;&#xA;{&#xD;&#xA;    devTrait = 3;&#xD;&#xA;}&#xD;&#xA;else if (player.TraitDevelopment == TraitDevelopment.Superstar)&#xD;&#xA;{&#xD;&#xA;    devTrait = 2;&#xD;&#xA;}&#xD;&#xA;else if (player.TraitDevelopment == TraitDevelopment.Normal)&#xD;&#xA;{&#xD;&#xA;    devTrait = 0;&#xD;&#xA;}&#xD;&#xA;else &#xD;&#xA;{&#xD;&#xA; devTrait = 1;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;int developmentMod = DevelopmentSpline.CalculateY(devTrait);&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;award = (award * ageMod) / 100;&#xD;&#xA;&#xD;&#xA;award = (award * developmentMod) / 100;&#xD;&#xA;&#xD;&#xA;// CoachTrait level impact is applied in C code.  Use PlayerGoalsEval.CoachTraitInfluenceSpline to tune it.&#xD;&#xA;&#xD;&#xA;if ((position &gt;= PositionE.FirstOffenseLine_ &amp;&amp; position &lt;= PositionE.LastOffenseLine_) || (position &gt;= PositionE.FirstDefenseLine_ &amp;&amp; position &lt;= PositionE.LastDefenseLine_))&#xD;&#xA;{&#xD;&#xA; if (evalInfo.IsPlayerStarter)&#xD;&#xA; {&#xD;&#xA;  award = award;&#xD;&#xA; }&#xD;&#xA; else&#xD;&#xA; {&#xD;&#xA;  award = (award * 0) / 100;&#xD;&#xA; }&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;if (!evalInfo.IsPlayerStarter &amp;&amp; PrimaryTeamStat != TeamStatType.Invalid)&#xD;&#xA;{&#xD;&#xA; award = 0;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;if (player.IsUserControlled == true)&#xD;&#xA;{&#xD;&#xA;    award = (award * 0) / 100;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;if (award &lt; MinExperienceAward)&#xD;&#xA;{&#xD;&#xA;    award = MinExperienceAward;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;if (award &gt; MaxExperienceAward)&#xD;&#xA;{ &#xD;&#xA;    award = MaxExperienceAward;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;award;" />
			<attribute name="GetPartialCompletionValue" idx="19" type="PlayerWeeklyGoal_GetPartialCompletionValue" guid="6536970-1935119" final="true" default="int value = BasePartialCompletionValue;&#xD;&#xA;&#xD;&#xA;if(IsInvertedGoal)&#xD;&#xA;{&#xD;&#xA; if (value &lt; MinCompletionValue)&#xD;&#xA; { &#xD;&#xA;      value = MinCompletionValue;&#xD;&#xA; }&#xD;&#xA;}&#xD;&#xA;else&#xD;&#xA;{&#xD;&#xA; if (value &gt; MaxCompletionValue)&#xD;&#xA; { &#xD;&#xA;      value = MaxCompletionValue;&#xD;&#xA; }&#xD;&#xA;}&#xD;&#xA;value;" />
			<attribute name="GetProgress" idx="20" type="PlayerWeeklyGoal_GetProgress" guid="6536970-1935048" default="int progress = 0;&#xD;&#xA;progress;" />
