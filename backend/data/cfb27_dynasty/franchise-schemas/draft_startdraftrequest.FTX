			<attribute name="HandleResponse" idx="13" type="none()" guid="6499000-1931512" final="true" default="// If a valid response was provided and the draft has not yet been started, start it. Note that in&#xD;&#xA;// an offline multi-user league, all users will respond. Only the first response should be handled.&#xD;&#xA;if ((Response != null) &amp;&amp; (DraftTransaction.CurrentStage == null))&#xD;&#xA;{&#xD;&#xA;    // If the &quot;Start&quot; response was selected, start the draft.&#xD;&#xA;    if (Response == StartResponse)&#xD;&#xA;    {&#xD;&#xA;        DraftTransaction.SetSimState(DraftSimState.Live);&#xD;&#xA;        DraftTransaction.Start();&#xD;&#xA;    }&#xD;&#xA;    // If the &quot;Sim&quot; response was selected, sim the draft.&#xD;&#xA;    else if (Response == SimResponse)&#xD;&#xA;    {&#xD;&#xA;        DraftTransaction.SetSimState(DraftSimState.SimToEnd);&#xD;&#xA;        DraftTransaction.Start();&#xD;&#xA;    }&#xD;&#xA;}&#xD;&#xA;" />
