	<schemas>
		<schema name="Draft_StartDraftRequest" numMembers="42" base="UIRequestForm" defaultStoreCapacity="32" assetId="6499000" defaultStoreGroupId="64" isRecordPersistent="true" defaultStoreGroupName="Franchise" defaultStoreOptimizationId="1" defaultStoreOptimizationName="Default_" majorVersionCRC="1079437824" minorVersionCRC="-1831395477">
			<attribute name="CanSubmitResponse" idx="0" type="bool" default="True" />
