			<attribute name="RemoveSignatureAbilities" idx="25" type="SignatureAbilitiesEval_RemoveSignatureAbilities" guid="6495139-1921206" final="true" />
			<attribute name="RequestServer" idx="26" type="RequestServer" />
			<attribute name="RookieStatTrackers" idx="27" type="RookieStatTracker[]" />
