			<attribute name="CalculateDevTraitDecreaseChance" idx="3" type="PlayerProgressionEval_CalculateDevTraitDecreaseChance" guid="6498681-1926197" final="true" default="float decreaseChance = 0.0;&#xD;&#xA;&#xD;&#xA;if (score == -1)&#xD;&#xA;{&#xD;&#xA;  decreaseChance = 1.0;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;decreaseChance;" />
			<attribute name="CalculateDevTraitIncreaseChance" idx="4" type="PlayerProgressionEval_CalculateDevTraitIncreaseChance" guid="6498681-1926205" final="true" default="int increaseChance = 0;&#xD;&#xA;int minIncreaseChance = 0;&#xD;&#xA;&#xD;&#xA;TraitDevelopment playerDevTrait = player.TraitDevelopment;&#xD;&#xA;if (playerDevTrait  == TraitDevelopment.College_Star)&#xD;&#xA;{&#xD;&#xA;  minIncreaseChance = 75;&#xD;&#xA;}&#xD;&#xA;if (playerDevTrait  == TraitDevelopment.College_Impact)&#xD;&#xA;{&#xD;&#xA;  minIncreaseChance = 50;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;if (playerDevTrait  == TraitDevelopment.Normal)&#xD;&#xA;{&#xD;&#xA;  minIncreaseChance = 25;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;increaseChance = score - minIncreaseChance;&#xD;&#xA;// There's no way to cast float to int right now. Hence, multiplying everything by 100 and then dividing by 100 in the end.&#xD;&#xA;int chanceBoost = 100; // which is 1*100&#xD;&#xA;if(coachTalentEffects != null)&#xD;&#xA;{&#xD;&#xA;  int boostValue= coachTalentEffects.Training_ChanceBoost_DevTrait;&#xD;&#xA;  chanceBoost = chanceBoost + boostValue; // E.x this will be 100 + 20 (120). Which would mean 1.20 after dividing in the end&#xD;&#xA;}&#xD;&#xA;increaseChance = increaseChance * chanceBoost / 100;&#xD;&#xA;increaseChance;" />
