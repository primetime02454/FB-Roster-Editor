			<attribute name="IssueUnlockNotificationRequest" idx="16" type="PlayerProgressionEval_IssueUnlockNotificationRequest" guid="6498681-2233008" final="true" default="UnlockNotificationRequest request = new UnlockNotificationRequest;&#xD;&#xA;&#xD;&#xA;// Set the request settings.&#xD;&#xA;request.Priority = 4;&#xD;&#xA;request.IsResponseRequired = false;&#xD;&#xA;request.IsConnectionRequired = false;&#xD;&#xA;request.IsBlocking = false;&#xD;&#xA;request.IsPersistent = false;&#xD;&#xA;request.RequestData = PositionSignatureAbility;&#xD;&#xA;&#xD;&#xA;if (PositionSignatureAbility == null)&#xD;&#xA;{&#xD;&#xA;  request.ShowRoosterOnHubButton = HUBMenuType.CoachAbilities;&#xD;&#xA;  request.ShowRoosterOnHubTab = HUBTabType.Coach;&#xD;&#xA;}&#xD;&#xA;else&#xD;&#xA;{&#xD;&#xA;  request.ShowRoosterOnHubButton = HUBMenuType.PlayerAbilities;&#xD;&#xA;  request.ShowRoosterOnHubTab = HUBTabType.Player;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;request.UIDisplayStyle = UIDisplayStyle.FullScreen;&#xD;&#xA;&#xD;&#xA;// Issue the request&#xD;&#xA;request.Issue(UserCharacter);" />
