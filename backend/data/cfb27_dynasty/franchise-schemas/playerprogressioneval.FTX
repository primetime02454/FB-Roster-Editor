			<attribute name="Franchise" idx="9" type="record" />
			<attribute name="GetPlayerSeasonScore" idx="10" type="PlayerProgressionEval_GetPlayerSeasonScore" guid="6498681-1926201" final="true" default="int seasonScore = 0;&#xD;&#xA;PositionE position = player.Position;&#xD;&#xA;int GamesStarted = 0;&#xD;&#xA;&#xD;&#xA;TraitDevelopment playerDevTrait = player.TraitDevelopment;&#xD;&#xA;&#xD;&#xA;if (player.SeasonStats != null &amp;&amp; player.SeasonStats.Population() - 1 &gt;= 0)&#xD;&#xA;{&#xD;&#xA; GamesStarted = player.SeasonStats[player.SeasonStats.Population() - 1].GAMESSTARTED;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;if (position == PositionE.QB)&#xD;&#xA;  {&#xD;&#xA;  int maxScore = 250;&#xD;&#xA;    seasonScore = (StatManager.GetPlayerSeasonStatForCurrentYear(player, StatType.PassTds) * 2) +&#xD;&#xA;    ((StatManager.GetPlayerSeasonStatForCurrentYear(player, StatType.RushTds) *18)/ 4) +&#xD;&#xA;    (StatManager.GetPlayerSeasonStatForCurrentYear(player, StatType.ReceiveTDs) * 4) +&#xD;&#xA;    (StatManager.GetPlayerSeasonStatForCurrentYear(player, StatType.PassYards) / 40) +&#xD;&#xA;    (StatManager.GetPlayerSeasonStatForCurrentYear(player, StatType.RushYards) / 25) +&#xD;&#xA;    (StatManager.GetPlayerSeasonStatForCurrentYear(player, StatType.ReceiveYards) / 25) +&#xD;&#xA;    (StatManager.GetPlayerSeasonStatForCurrentYear(player, StatType.PassInts) * -4) +&#xD;&#xA;    (StatManager.GetPlayerSeasonStatForCurrentYear(player, StatType.RushFumbles) * -4);&#xD;&#xA;  seasonScore = (seasonScore *100)/maxScore;&#xD;&#xA;  }&#xD;&#xA;  &#xD;&#xA;else if (position == PositionE.HB)&#xD;&#xA;{&#xD;&#xA;  int maxScore = 200;&#xD;&#xA;    seasonScore = ((StatManager.GetPlayerSeasonStatForCurrentYear(player, StatType.RushTds) *18)/ 4) +&#xD;&#xA;    (StatManager.GetPlayerSeasonStatForCurrentYear(player, StatType.ReceiveTDs) * 4) +&#xD;&#xA;    (StatManager.GetPlayerSeasonStatForCurrentYear(player, StatType.RushYards) / 25) +&#xD;&#xA;    (StatManager.GetPlayerSeasonStatForCurrentYear(player, StatType.ReceiveYards) / 55) +&#xD;&#xA;    (StatManager.GetPlayerSeasonStatForCurrentYear(player, StatType.RushFumbles) * -4);&#xD;&#xA;  seasonScore = (seasonScore *100)/maxScore;&#xD;&#xA;  &#xD;&#xA;}&#xD;&#xA;else if (position == PositionE.WR)&#xD;&#xA;{&#xD;&#xA;  int maxScore = 200;&#xD;&#xA;    seasonScore = ((StatManager.GetPlayerSeasonStatForCurrentYear(player, StatType.RushTds) *18)/ 4) +&#xD;&#xA;    (StatManager.GetPlayerSeasonStatForCurrentYear(player, StatType.ReceiveTDs) * 5) +&#xD;&#xA;    (StatManager.GetPlayerSeasonStatForCurrentYear(player, StatType.RushYards) / 30) +&#xD;&#xA;    (StatManager.GetPlayerSeasonStatForCurrentYear(player, StatType.ReceiveYards) / 20) +&#xD;&#xA;    (StatManager.GetPlayerSeasonStatForCurrentYear(player, StatType.ReceiveCatches) / 2) +&#xD;&#xA;    (StatManager.GetPlayerSeasonStatForCurrentYear(player, StatType.RushFumbles) * -4);&#xD;&#xA;  seasonScore = (seasonScore *100)/maxScore;&#xD;&#xA;  &#xD;&#xA;}&#xD;&#xA;else if (position == PositionE.TE)&#xD;&#xA;{&#xD;&#xA;  int maxScore = 150;&#xD;&#xA;    seasonScore = ((StatManager.GetPlayerSeasonStatForCurrentYear(player, StatType.RushTds) *18)/ 4) +&#xD;&#xA;    (StatManager.GetPlayerSeasonStatForCurrentYear(player, StatType.ReceiveTDs) * 5) +&#xD;&#xA;    (StatManager.GetPlayerSeasonStatForCurrentYear(player, StatType.RushYards) / 30) +&#xD;&#xA;    (StatManager.GetPlayerSeasonStatForCurrentYear(player, StatType.ReceiveYards) / 20) +&#xD;&#xA;    (StatManager.GetPlayerSeasonStatForCurrentYear(player, StatType.ReceiveCatches) / 2) +&#xD;&#xA;    (StatManager.GetPlayerSeasonStatForCurrentYear(player, StatType.RushFumbles) * -4);&#xD;&#xA;  seasonScore = (seasonScore *100)/maxScore;&#xD;&#xA;}&#xD;&#xA;else if (position == PositionE.DT)&#xD;&#xA;{&#xD;&#xA;  int maxScore = 200;&#xD;&#xA;    seasonScore = (StatManager.GetPlayerSeasonStatForCurrentYear(player, StatType.DefensiveInts) *6) +&#xD;&#xA;    (StatManager.GetPlayerSeasonStatForCurrentYear(player, StatType.DLineFumbleRecoveries) * 3) +&#xD;&#xA;    (StatManager.GetPlayerSeasonStatForCurrentYear(player, StatType.DLineForcedFumbles) * 3) +&#xD;&#xA;    (StatManager.GetPlayerSeasonStatForCurrentYear(player, StatType.DefensiveTacklesForLoss) *3) +&#xD;&#xA;    (StatManager.GetPlayerSeasonStatForCurrentYear(player, StatType.DefensivePassDeflections) * 2) +&#xD;&#xA;    (StatManager.GetPlayerSeasonStatForCurrentYear(player, StatType.DefensiveTDS) * 6) +&#xD;&#xA;    ((StatManager.GetPlayerSeasonStatForCurrentYear(player, StatType.DefensiveTackles) * 2) /5) +&#xD;&#xA;    (StatManager.GetPlayerSeasonStatForCurrentYear(player, StatType.DefensiveSacks) * 5);&#xD;&#xA;  seasonScore = (seasonScore *100)/maxScore;&#xD;&#xA;}&#xD;&#xA;else if (position == PositionE.LE)&#xD;&#xA;{&#xD;&#xA;  int maxScore = 200;&#xD;&#xA;   seasonScore = (StatManager.GetPlayerSeasonStatForCurrentYear(player, StatType.DefensiveInts) *6) +&#xD;&#xA;    (StatManager.GetPlayerSeasonStatForCurrentYear(player, StatType.DLineFumbleRecoveries) * 3) +&#xD;&#xA;    (StatManager.GetPlayerSeasonStatForCurrentYear(player, StatType.DLineForcedFumbles) * 3) +&#xD;&#xA;    (StatManager.GetPlayerSeasonStatForCurrentYear(player, StatType.DefensiveTacklesForLoss) *3) +&#xD;&#xA;    (StatManager.GetPlayerSeasonStatForCurrentYear(player, StatType.DefensivePassDeflections) * 2) +&#xD;&#xA;    (StatManager.GetPlayerSeasonStatForCurrentYear(player, StatType.DefensiveTDS) * 6) +&#xD;&#xA;    ((StatManager.GetPlayerSeasonStatForCurrentYear(player, StatType.DefensiveTackles) * 2) /5) +&#xD;&#xA;    (StatManager.GetPlayerSeasonStatForCurrentYear(player, StatType.DefensiveSacks) * 5);&#xD;&#xA;  seasonScore = (seasonScore *100)/maxScore;&#xD;&#xA;}&#xD;&#xA;else if (position == PositionE.RE)&#xD;&#xA;{&#xD;&#xA;  int maxScore = 200;&#xD;&#xA;  seasonScore = (StatManager.GetPlayerSeasonStatForCurrentYear(player, StatType.DefensiveInts) *6) +&#xD;&#xA;    (StatManager.GetPlayerSeasonStatForCurrentYear(player, StatType.DLineFumbleRecoveries) * 3) +&#xD;&#xA;    (StatManager.GetPlayerSeasonStatForCurrentYear(player, StatType.DLineForcedFumbles) * 3) +&#xD;&#xA;    (StatManager.GetPlayerSeasonStatForCurrentYear(player, StatType.DefensiveTacklesForLoss) *3) +&#xD;&#xA;    (StatManager.GetPlayerSeasonStatForCurrentYear(player, StatType.DefensivePassDeflections) * 2) +&#xD;&#xA;    (StatManager.GetPlayerSeasonStatForCurrentYear(player, StatType.DefensiveTDS) * 6) +&#xD;&#xA;    ((StatManager.GetPlayerSeasonStatForCurrentYear(player, StatType.DefensiveTackles) * 2) /5) +&#xD;&#xA;    (StatManager.GetPlayerSeasonStatForCurrentYear(player, StatType.DefensiveSacks) * 5);&#xD;&#xA;  seasonScore = (seasonScore *100)/maxScore;&#xD;&#xA;}&#xD;&#xA;else if (position == PositionE.LOLB)&#xD;&#xA;{&#xD;&#xA;  int maxScore = 150;&#xD;&#xA;  seasonScore = (StatManager.GetPlayerSeasonStatForCurrentYear(player, StatType.DefensiveInts) *6) +&#xD;&#xA;    (StatManager.GetPlayerSeasonStatForCurrentYear(player, StatType.DLineFumbleRecoveries) * 3) +&#xD;&#xA;    (StatManager.GetPlayerSeasonStatForCurrentYear(player, StatType.DLineForcedFumbles) * 3) +&#xD;&#xA;    (StatManager.GetPlayerSeasonStatForCurrentYear(player, StatType.DefensiveTacklesForLoss) *3) +&#xD;&#xA;    (StatManager.GetPlayerSeasonStatForCurrentYear(player, StatType.DefensivePassDeflections) * 2) +&#xD;&#xA;    (StatManager.GetPlayerSeasonStatForCurrentYear(player, StatType.DefensiveTDS) * 6) +&#xD;&#xA;    ((StatManager.GetPlayerSeasonStatForCurrentYear(player, StatType.DefensiveTackles) * 2) /5) +&#xD;&#xA;    (StatManager.GetPlayerSeasonStatForCurrentYear(player, StatType.DefensiveSacks) * 5);&#xD;&#xA;  seasonScore = (seasonScore *100)/maxScore;&#xD;&#xA;}&#xD;&#xA;else if (position == PositionE.ROLB)&#xD;&#xA;{&#xD;&#xA;  int maxScore = 150;&#xD;&#xA;  seasonScore = (StatManager.GetPlayerSeasonStatForCurrentYear(player, StatType.DefensiveInts) *6) +&#xD;&#xA;    (StatManager.GetPlayerSeasonStatForCurrentYear(player, StatType.DLineFumbleRecoveries) * 3) +&#xD;&#xA;    (StatManager.GetPlayerSeasonStatForCurrentYear(player, StatType.DLineForcedFumbles) * 3) +&#xD;&#xA;    (StatManager.GetPlayerSeasonStatForCurrentYear(player, StatType.DefensiveTacklesForLoss) *3) +&#xD;&#xA;    (StatManager.GetPlayerSeasonStatForCurrentYear(player, StatType.DefensivePassDeflections) * 2) +&#xD;&#xA;    (StatManager.GetPlayerSeasonStatForCurrentYear(player, StatType.DefensiveTDS) * 6) +&#xD;&#xA;    ((StatManager.GetPlayerSeasonStatForCurrentYear(player, StatType.DefensiveTackles) * 2) /5) +&#xD;&#xA;    (StatManager.GetPlayerSeasonStatForCurrentYear(player, StatType.DefensiveSacks) * 5);&#xD;&#xA;  seasonScore = (seasonScore *100)/maxScore;&#xD;&#xA;}&#xD;&#xA;else if (position == PositionE.MLB)&#xD;&#xA;{&#xD;&#xA;  int maxScore = 150;&#xD;&#xA;  seasonScore = (StatManager.GetPlayerSeasonStatForCurrentYear(player, StatType.DefensiveInts) *6) +&#xD;&#xA;    (StatManager.GetPlayerSeasonStatForCurrentYear(player, StatType.DLineFumbleRecoveries) * 3) +&#xD;&#xA;    (StatManager.GetPlayerSeasonStatForCurrentYear(player, StatType.DLineForcedFumbles) * 3) +&#xD;&#xA;    (StatManager.GetPlayerSeasonStatForCurrentYear(player, StatType.DefensiveTacklesForLoss) *3) +&#xD;&#xA;    (StatManager.GetPlayerSeasonStatForCurrentYear(player, StatType.DefensivePassDeflections) * 2) +&#xD;&#xA;    (StatManager.GetPlayerSeasonStatForCurrentYear(player, StatType.DefensiveTDS) * 6) +&#xD;&#xA;    ((StatManager.GetPlayerSeasonStatForCurrentYear(player, StatType.DefensiveTackles) * 2) /5) +&#xD;&#xA;    (StatManager.GetPlayerSeasonStatForCurrentYear(player, StatType.DefensiveSacks) * 5);&#xD;&#xA;  seasonScore = (seasonScore *100)/maxScore;&#xD;&#xA;}&#xD;&#xA;else if (position == PositionE.CB)&#xD;&#xA;{&#xD;&#xA;  int maxScore = 100;&#xD;&#xA;  seasonScore = (StatManager.GetPlayerSeasonStatForCurrentYear(player, StatType.DefensiveInts) *6) +&#xD;&#xA;    (StatManager.GetPlayerSeasonStatForCurrentYear(player, StatType.DLineFumbleRecoveries) * 3) +&#xD;&#xA;    (StatManager.GetPlayerSeasonStatForCurrentYear(player, StatType.DLineForcedFumbles) * 3) +&#xD;&#xA;    (StatManager.GetPlayerSeasonStatForCurrentYear(player, StatType.DefensiveTacklesForLoss) *3) +&#xD;&#xA;    (StatManager.GetPlayerSeasonStatForCurrentYear(player, StatType.DefensivePassDeflections) * 2) +&#xD;&#xA;    (StatManager.GetPlayerSeasonStatForCurrentYear(player, StatType.DefensiveTDS) * 6) +&#xD;&#xA;    ((StatManager.GetPlayerSeasonStatForCurrentYear(player, StatType.DefensiveTackles) * 2) /5) +&#xD;&#xA;    (StatManager.GetPlayerSeasonStatForCurrentYear(player, StatType.DefensiveSacks) * 5);&#xD;&#xA;  seasonScore = (seasonScore *100)/maxScore;&#xD;&#xA;}&#xD;&#xA;else if (position == PositionE.FS)&#xD;&#xA;{&#xD;&#xA;  int maxScore = 100;&#xD;&#xA;  seasonScore = (StatManager.GetPlayerSeasonStatForCurrentYear(player, StatType.DefensiveInts) *6) +&#xD;&#xA;    (StatManager.GetPlayerSeasonStatForCurrentYear(player, StatType.DLineFumbleRecoveries) * 3) +&#xD;&#xA;    (StatManager.GetPlayerSeasonStatForCurrentYear(player, StatType.DLineForcedFumbles) * 3) +&#xD;&#xA;    (StatManager.GetPlayerSeasonStatForCurrentYear(player, StatType.DefensiveTacklesForLoss) *3) +&#xD;&#xA;    (StatManager.GetPlayerSeasonStatForCurrentYear(player, StatType.DefensivePassDeflections) * 2) +&#xD;&#xA;    (StatManager.GetPlayerSeasonStatForCurrentYear(player, StatType.DefensiveTDS) * 6) +&#xD;&#xA;    ((StatManager.GetPlayerSeasonStatForCurrentYear(player, StatType.DefensiveTackles) * 2) /5) +&#xD;&#xA;    (StatManager.GetPlayerSeasonStatForCurrentYear(player, StatType.DefensiveSacks) * 5);&#xD;&#xA;  seasonScore = (seasonScore *100)/maxScore;&#xD;&#xA;}&#xD;&#xA;else if (position == PositionE.SS)&#xD;&#xA;{&#xD;&#xA;  int maxScore = 100;&#xD;&#xA;  seasonScore = (StatManager.GetPlayerSeasonStatForCurrentYear(player, StatType.DefensiveInts) *6) +&#xD;&#xA;    (StatManager.GetPlayerSeasonStatForCurrentYear(player, StatType.DLineFumbleRecoveries) * 3) +&#xD;&#xA;    (StatManager.GetPlayerSeasonStatForCurrentYear(player, StatType.DLineForcedFumbles) * 3) +&#xD;&#xA;    (StatManager.GetPlayerSeasonStatForCurrentYear(player, StatType.DefensiveTacklesForLoss) *3) +&#xD;&#xA;    (StatManager.GetPlayerSeasonStatForCurrentYear(player, StatType.DefensivePassDeflections) * 2) +&#xD;&#xA;    (StatManager.GetPlayerSeasonStatForCurrentYear(player, StatType.DefensiveTDS) * 6) +&#xD;&#xA;    ((StatManager.GetPlayerSeasonStatForCurrentYear(player, StatType.DefensiveTackles) * 2) /5) +&#xD;&#xA;    (StatManager.GetPlayerSeasonStatForCurrentYear(player, StatType.DefensiveSacks) * 5);&#xD;&#xA;seasonScore = (seasonScore *100)/maxScore;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;seasonScore;" />
