			<attribute name="GetCoachRating" idx="40" type="StaffHiringTuning_GetCoachRating" guid="6494903-1912863" final="true" default="int rating = -1;&#xD;&#xA;&#xD;&#xA;if(desiredCoachPosition == CoachPosition.HeadCoach)&#xD;&#xA;{&#xD;&#xA;  rating = HCHiringRatingData.GetRating(coach, numTalents);&#xD;&#xA;}&#xD;&#xA;else if(desiredCoachPosition == CoachPosition.OffensiveCoordinator)&#xD;&#xA;{&#xD;&#xA;  rating = OCHiringRatingData.GetRating(coach, numTalents);&#xD;&#xA;}&#xD;&#xA;else if(desiredCoachPosition == CoachPosition.DefensiveCoordinator)&#xD;&#xA;{&#xD;&#xA;  rating = DCHiringRatingData.GetRating(coach, numTalents);&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;rating;" />
