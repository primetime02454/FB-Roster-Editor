			<attribute name="ShouldFireStaff" idx="108" type="StaffHiringTuning_ShouldFireStaff" guid="6494903-1912847" final="true" default="//Expression determining whether each staff person should be fired. Runs after SeasonsWithTeam is updated.&#xD;&#xA;&#xD;&#xA;bool shouldFire = false;&#xD;&#xA;&#xD;&#xA;TeamStats teamStats0 = GetTeamStats(currentTeam, currentYear, currentYear);&#xD;&#xA;TeamStats teamStats1 = GetTeamStats(currentTeam, currentYear, currentYear - 1);&#xD;&#xA;TeamStats teamStats2 = GetTeamStats(currentTeam, currentYear, currentYear - 2);&#xD;&#xA;int teamWins0 = 0;&#xD;&#xA;int teamWins1 = 0;&#xD;&#xA;int teamWins2 = 0;&#xD;&#xA;int teamTotalOffYardsPerGame0 = 0;&#xD;&#xA;int teamTotalOffYardsPerGame1 = 0;&#xD;&#xA;int teamTotalOffYardsPerGame2 = 0;&#xD;&#xA;int teamTotalDefYardsPerGame0 = 0;&#xD;&#xA;int teamTotalDefYardsPerGame1 = 0;&#xD;&#xA;int teamTotalDefYardsPerGame2 = 0;&#xD;&#xA;int seasonsWithTeam = coach.SeasonsWithTeam;&#xD;&#xA;TeamContentionPhase contentionPhase = currentTeam.ContentionPhase;&#xD;&#xA;CoachPosition position = coach.Position;&#xD;&#xA;&#xD;&#xA;if(teamStats0 != null &amp;&amp; teamStats1 != null &amp;&amp; teamStats2 != null)&#xD;&#xA;{&#xD;&#xA;teamWins0 = teamStats0.WINS;&#xD;&#xA;teamWins1 = teamStats1.WINS;&#xD;&#xA;teamWins2 = teamStats2.WINS;&#xD;&#xA;&#xD;&#xA;//Get Totals first&#xD;&#xA;teamTotalOffYardsPerGame0 = teamStats0.OFFYARDS;&#xD;&#xA;teamTotalOffYardsPerGame1 = teamStats1.OFFYARDS;&#xD;&#xA;teamTotalOffYardsPerGame2 = teamStats2.OFFYARDS;&#xD;&#xA;teamTotalDefYardsPerGame0 = teamStats0.DEFPASSYARDS + teamStats0.DEFRUSHYARDS;&#xD;&#xA;teamTotalDefYardsPerGame1 = teamStats1.DEFPASSYARDS + teamStats1.DEFRUSHYARDS;&#xD;&#xA;teamTotalDefYardsPerGame2 = teamStats2.DEFPASSYARDS + teamStats2.DEFRUSHYARDS;&#xD;&#xA;&#xD;&#xA;//Average over number of games based on year. 2021 is the first year of 17 gamee seasons&#xD;&#xA;if(currentYear &lt;= 2021)&#xD;&#xA;{&#xD;&#xA;  teamTotalOffYardsPerGame0 = (teamTotalOffYardsPerGame0 * 100) / 17;&#xD;&#xA;  teamTotalOffYardsPerGame1 = (teamTotalOffYardsPerGame1 * 100) / 16;&#xD;&#xA;  teamTotalOffYardsPerGame2 = (teamTotalOffYardsPerGame2 * 100) / 16;&#xD;&#xA;  teamTotalDefYardsPerGame0 = (teamTotalDefYardsPerGame0 * 100) / 17;&#xD;&#xA;  teamTotalDefYardsPerGame1 = (teamTotalDefYardsPerGame1 * 100) / 16;&#xD;&#xA;  teamTotalDefYardsPerGame2 = (teamTotalDefYardsPerGame2 * 100) / 16;&#xD;&#xA;}&#xD;&#xA;else if (currentYear == 2022)&#xD;&#xA;{&#xD;&#xA;  teamTotalOffYardsPerGame0 = (teamTotalOffYardsPerGame0 * 100) / 17;&#xD;&#xA;  teamTotalOffYardsPerGame1 = (teamTotalOffYardsPerGame1 * 100) / 17;&#xD;&#xA;  teamTotalOffYardsPerGame2 = (teamTotalOffYardsPerGame2 * 100) / 16;&#xD;&#xA;  teamTotalDefYardsPerGame0 = (teamTotalDefYardsPerGame0 * 100) / 17;&#xD;&#xA;  teamTotalDefYardsPerGame1 = (teamTotalDefYardsPerGame1 * 100) / 17;&#xD;&#xA;  teamTotalDefYardsPerGame2 = (teamTotalDefYardsPerGame2 * 100) / 16;&#xD;&#xA;}&#xD;&#xA;else&#xD;&#xA;{&#xD;&#xA;  teamTotalOffYardsPerGame0 = (teamTotalOffYardsPerGame0 * 100) / 17;&#xD;&#xA;  teamTotalOffYardsPerGame1 = (teamTotalOffYardsPerGame1 * 100) / 17;&#xD;&#xA;  teamTotalOffYardsPerGame2 = (teamTotalOffYardsPerGame2 * 100) / 17;&#xD;&#xA;  teamTotalDefYardsPerGame0 = (teamTotalDefYardsPerGame0 * 100) / 17;&#xD;&#xA;  teamTotalDefYardsPerGame1 = (teamTotalDefYardsPerGame1 * 100) / 17;&#xD;&#xA;  teamTotalDefYardsPerGame2 = (teamTotalDefYardsPerGame2 * 100) / 17;  &#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;if(teamWins0 == 0)&#xD;&#xA;{&#xD;&#xA;  shouldFire = true;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;if (contentionPhase == TeamContentionPhase.Losing)&#xD;&#xA;{&#xD;&#xA;  if(teamWins0 &lt; teamWins1 &amp;&amp; teamWins0 &lt; teamWins2 &amp;&amp; teamWins0 &lt; 5 &amp;&amp; seasonsWithTeam &gt;= 3)&#xD;&#xA;  {&#xD;&#xA;    shouldFire = true;&#xD;&#xA;  }&#xD;&#xA;  else if(teamWins0 &lt; 7 &amp;&amp; teamWins1 &lt; 7 &amp;&amp; teamWins2 &lt; 7 &amp;&amp; seasonsWithTeam &gt;= 3)&#xD;&#xA;  {&#xD;&#xA;    shouldFire = true;&#xD;&#xA;  }&#xD;&#xA;  else if(teamWins0  &lt; teamWins1 &amp;&amp; teamWins0 &lt; 5 &amp;&amp; seasonsWithTeam &gt;= 2)&#xD;&#xA;  {&#xD;&#xA;    shouldFire = true;&#xD;&#xA;  }&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;  if (position == CoachPosition.HeadCoach)&#xD;&#xA;  {&#xD;&#xA;    //TODO: Add any special logic for Head Coach Firing&#xD;&#xA;  }&#xD;&#xA;  else if(position == CoachPosition.OffensiveCoordinator)&#xD;&#xA;  {&#xD;&#xA;    if(teamStats0.PASSINTS &gt; teamStats0.PASSTDS)&#xD;&#xA;    {&#xD;&#xA;      shouldFire = true;&#xD;&#xA;    }&#xD;&#xA;  else if(teamTotalOffYardsPerGame0 &lt; teamTotalOffYardsPerGame1 &amp;&amp; teamTotalOffYardsPerGame1 &lt; teamTotalOffYardsPerGame2 &amp;&amp; seasonsWithTeam &gt;= 3)&#xD;&#xA;  {&#xD;&#xA;    shouldFire = true;&#xD;&#xA;  }&#xD;&#xA;    else if(teamStats0.PASSTDS + teamStats0.RUSHTDS &lt; teamStats1.PASSTDS + teamStats1.RUSHTDS &amp;&amp; teamStats1.PASSTDS + teamStats1.RUSHTDS &lt; teamStats2.PASSTDS + teamStats2.RUSHTDS &amp;&amp; seasonsWithTeam &gt;= 3)&#xD;&#xA;    {&#xD;&#xA;      shouldFire = true;&#xD;&#xA;    }&#xD;&#xA;  }&#xD;&#xA;  else if(position == CoachPosition.DefensiveCoordinator)&#xD;&#xA;  {&#xD;&#xA;    if(teamTotalDefYardsPerGame0 &gt; teamTotalDefYardsPerGame1 &amp;&amp; teamTotalDefYardsPerGame1 &gt; teamTotalDefYardsPerGame2 &amp;&amp; seasonsWithTeam &gt;= 3)&#xD;&#xA;    {&#xD;&#xA;      shouldFire = true;&#xD;&#xA;    }&#xD;&#xA;  }&#xD;&#xA;}&#xD;&#xA;else if (contentionPhase == TeamContentionPhase.Playoff)&#xD;&#xA;{&#xD;&#xA;  if(teamWins0 &lt; teamWins1 &amp;&amp; teamWins0 &lt; teamWins2 &amp;&amp; teamWins0 &lt; 6 &amp;&amp; seasonsWithTeam &gt;= 2)&#xD;&#xA;  {&#xD;&#xA;    shouldFire = true;&#xD;&#xA;  }&#xD;&#xA;  else if(teamWins0 &lt; 9 &amp;&amp; teamWins1 &lt; 9 &amp;&amp; teamWins2 &lt; 9 &amp;&amp; seasonsWithTeam &gt;= 2)&#xD;&#xA;  {&#xD;&#xA;    shouldFire = true;&#xD;&#xA;  }&#xD;&#xA;  else if(teamWins0  &lt; teamWins1 &amp;&amp; teamStats0.WINS &lt; 6 &amp;&amp; seasonsWithTeam &gt;= 1)&#xD;&#xA;  {&#xD;&#xA;    shouldFire = true;&#xD;&#xA;  }&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;  if (position == CoachPosition.HeadCoach)&#xD;&#xA;  {&#xD;&#xA;    //TODO: Add any special logic for Head Coach Firing&#xD;&#xA;  }&#xD;&#xA;  else if(position == CoachPosition.OffensiveCoordinator)&#xD;&#xA;  {&#xD;&#xA;    if(teamStats0.PASSINTS &gt; teamStats0.PASSTDS)&#xD;&#xA;    {&#xD;&#xA;      shouldFire = true;&#xD;&#xA;    }&#xD;&#xA;  else if(teamTotalOffYardsPerGame0 &lt; teamTotalOffYardsPerGame1 &amp;&amp; teamTotalOffYardsPerGame1 &lt; teamTotalOffYardsPerGame2 &amp;&amp; seasonsWithTeam &gt;= 3)&#xD;&#xA;  {&#xD;&#xA;    shouldFire = true;&#xD;&#xA;  }&#xD;&#xA;    else if(teamStats0.PASSTDS + teamStats0.RUSHTDS &lt; teamStats1.PASSTDS + teamStats1.RUSHTDS &amp;&amp; teamStats1.PASSTDS + teamStats1.RUSHTDS &lt; teamStats2.PASSTDS + teamStats2.RUSHTDS &amp;&amp; seasonsWithTeam &gt;= 3)&#xD;&#xA;    {&#xD;&#xA;      shouldFire = true;&#xD;&#xA;    }&#xD;&#xA;  }&#xD;&#xA;  else if(position == CoachPosition.DefensiveCoordinator)&#xD;&#xA;  {&#xD;&#xA;    if(teamTotalDefYardsPerGame0 &gt; teamTotalDefYardsPerGame1 &amp;&amp; teamTotalDefYardsPerGame1 &gt; teamTotalDefYardsPerGame2 &amp;&amp; seasonsWithTeam &gt;= 3)&#xD;&#xA;    {&#xD;&#xA;      shouldFire = true;&#xD;&#xA;    }&#xD;&#xA;  }&#xD;&#xA;}&#xD;&#xA;else if (contentionPhase == TeamContentionPhase.Championship)&#xD;&#xA;{&#xD;&#xA;  if (position == CoachPosition.HeadCoach)&#xD;&#xA;  {&#xD;&#xA;    if(teamWins0 &lt; teamWins1 &amp;&amp; teamWins0 &lt; teamWins2 &amp;&amp; teamWins0 &lt; 8 &amp;&amp; seasonsWithTeam &gt;= 3)&#xD;&#xA;    {&#xD;&#xA;      shouldFire = true;&#xD;&#xA;    }&#xD;&#xA;    else if(teamWins0  &lt; teamWins1 &amp;&amp; teamStats0.WINS &lt; 6 &amp;&amp; seasonsWithTeam &gt;= 2)&#xD;&#xA;    {&#xD;&#xA;      shouldFire = true;&#xD;&#xA;    }&#xD;&#xA;  }&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;shouldFire;" />
