			<attribute name="CanHireStaff" idx="3" type="StaffHiringTuning_CanHireStaff" guid="6494903-1912841" final="true" default="bool canHireStaff = false;&#xD;&#xA;&#xD;&#xA;if(coach.SeasonStats != null &amp;&amp; coach.SeasonStats.Wins &gt; 10 &amp;&amp; coach.OffensiveScheme.Value == hiringTeam.DefaultOffensiveScheme &amp;&amp; coach.DefensiveScheme.Value == hiringTeam.DefaultDefensiveScheme)&#xD;&#xA;{&#xD;&#xA;  canHireStaff = true;&#xD;&#xA;}&#xD;&#xA;else if(numTalents &gt; 5)&#xD;&#xA;{&#xD;&#xA;  canHireStaff = true;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;canHireStaff;" />
