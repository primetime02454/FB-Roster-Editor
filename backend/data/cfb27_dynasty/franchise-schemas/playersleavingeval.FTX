			<attribute name="IssueEnterTrophyRoomRequest" idx="34" type="PlayersLeavingEval_IssueEnterTrophyRoomRequest" guid="6498461-2426046" final="true" default="EnterTrophyRoomRequest request = new EnterTrophyRoomRequest;&#xD;&#xA;request.IsResponseRequired = false;&#xD;&#xA;request.IsConnectionRequired = false;&#xD;&#xA;request.IsBlocking = false;&#xD;&#xA;request.IsPersistent = true;&#xD;&#xA;request.Priority = 5;&#xD;&#xA;&#xD;&#xA;// Create the response forms.&#xD;&#xA;request.ResponseForms = new ResponseForm[1];&#xD;&#xA;{&#xD;&#xA;    request.ResponseForms.Append( EnterTrophyRoomResponse);&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;request.Issue(player);" />
