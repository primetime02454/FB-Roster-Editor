			<attribute name="HandleForceRetirement" idx="30" type="PlayersLeavingEval_HandleForceRetirement" guid="6498461-1925043" final="true" default="if(!player.IsCreated)&#xD;&#xA;{&#xD;&#xA;  Franchise.RetiredPlayers.FindAndErase(player);&#xD;&#xA;  PlayerManager.UnRetirePlayer(player);&#xD;&#xA;}" />
			<attribute name="HandleRegisterUser" idx="31" type="PlayersLeavingEval_HandleRegisterUser" guid="6498461-2238213" final="true" default="int offSeasonStagType = OffseasonStageType.PlayersLeaving;&#xD;&#xA;if(SeasonInfo.CurrentOffseasonStage == offSeasonStagType)&#xD;&#xA;{&#xD;&#xA;  IssuePlayersLeavingRequestToUser(EventRecord.User.UserEntity);&#xD;&#xA;}" />
