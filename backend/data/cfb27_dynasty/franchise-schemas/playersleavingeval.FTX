			<attribute name="IssuePlayersLeavingRequestToUser" idx="36" type="PlayersLeavingEval_IssuePlayersLeavingRequestToUser" guid="6498461-2083001" final="true" default="PlayersLeavingEnterRequest request = new PlayersLeavingEnterRequest;&#xD;&#xA;&#xD;&#xA;request.IsResponseRequired = false;&#xD;&#xA;request.IsConnectionRequired = false;&#xD;&#xA;request.IsBlocking = false;&#xD;&#xA;request.IsPersistent = true;&#xD;&#xA;request.Priority = 5;&#xD;&#xA;request.RequestData = PlayersLeavingTunables;&#xD;&#xA;&#xD;&#xA;request.ResponseForms = new ResponseForm[1];&#xD;&#xA;{&#xD;&#xA;   request.ResponseForms.Append(PlayersLeavingForm);&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;request.Issue(userEntity);" />
			<attribute name="IssueRetirementRequest" idx="37" type="PlayersLeavingEval_IssueRetirementRequest" guid="6498461-1925023" final="true" default="Retirement_ForceRetirementRequest request = new Retirement_ForceRetirementRequest;&#xD;&#xA;request.IsResponseRequired = true;&#xD;&#xA;request.IsConnectionRequired = false;&#xD;&#xA;request.IsBlocking = true;&#xD;&#xA;request.RequestData = player;&#xD;&#xA;request.IsPersistent = true;&#xD;&#xA;request.doSetRetiredFlag = false;&#xD;&#xA;request.RequestStyle = RequestStyle.Blocker;&#xD;&#xA;&#xD;&#xA;// Create the response forms.&#xD;&#xA;request.ResponseForms = new ResponseForm[1];&#xD;&#xA;{&#xD;&#xA;    request.ResponseForms.Append( ForceRetirementResponse);&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;request.Issue(player);" />
