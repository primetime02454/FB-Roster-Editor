			<attribute name="PositionGroupLookupTable" idx="35" type="PlayerPositionGroupLookupTable" />
			<attribute name="PositionLookupTable" idx="36" type="PlayerPositionLookupTable" />
			<attribute name="PositionSubPhilosophy" idx="37" type="DepthChartSubPhilosophy" />
			<attribute name="PositionToKeyContextTable" idx="38" type="record" />
