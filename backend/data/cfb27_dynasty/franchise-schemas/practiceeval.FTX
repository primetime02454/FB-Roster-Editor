			<attribute name="ProcessPracticeRequest" idx="78" type="PracticeEval_ProcessPracticeRequest" guid="6708631-1948141" final="true" default="UserEntity userEntity = null;&#xD;&#xA;&#xD;&#xA;if (practiceRequest.TargetUser != null)&#xD;&#xA;{&#xD;&#xA; userEntity = practiceRequest.TargetUser.UserEntity;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;DelegatePracticeTime(practiceRequest.Team, userEntity, practiceRequest.SelectedMinigame );&#xD;&#xA;&#xD;&#xA;" />
