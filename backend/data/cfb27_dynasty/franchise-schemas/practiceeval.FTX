			<attribute name="IssueGameplanningRequest" idx="35" type="PracticeEval_IssueGameplanningRequest" guid="6708631-2590046" final="true" default="GameplanningRequest request = new GameplanningRequest;&#xD;&#xA;&#xD;&#xA;// Set the request settings.&#xD;&#xA;request.Priority = 4;&#xD;&#xA;request.IsResponseRequired = true;&#xD;&#xA;request.IsConnectionRequired = false;&#xD;&#xA;request.IsBlocking = false;&#xD;&#xA;request.PracticeEvalRef = this;&#xD;&#xA;request.IsPersistent = true;&#xD;&#xA;&#xD;&#xA;request.Team = team;&#xD;&#xA;&#xD;&#xA;request.ResponseForms = new ResponseForm[1];&#xD;&#xA;&#xD;&#xA;request.ResponseForms.Append(GameplanningRequestGameplanningResponse);&#xD;&#xA;&#xD;&#xA;request.DefaultResponse = GameplanningRequestDelegateResponse;&#xD;&#xA;request.CanUpdateResponse = true;&#xD;&#xA;&#xD;&#xA;request.Issue(userEntity);" />
			<attribute name="IssuePracticeGameRequest" idx="36" type="PracticeEval_IssuePracticeGameRequest" guid="6708631-1948146" final="true" default="// Get the season info needed&#xD;&#xA;SeasonWeekType weekType = SeasonInfo.CurrentWeekType;&#xD;&#xA;int week = SeasonInfo.CurrentWeek;&#xD;&#xA;&#xD;&#xA;if (inSeasonRequest)&#xD;&#xA;{  &#xD;&#xA;    // Get the info for the next game&#xD;&#xA;    SeasonGame seasonGame = SeasonManager.GetNextGame(team, weekType, week);&#xD;&#xA;  &#xD;&#xA;    bool hadPlayoffByeWeek = false;&#xD;&#xA;&#xD;&#xA;    // Handle Regular Season Bye Weeks&#xD;&#xA;    if (seasonGame == null)&#xD;&#xA;    {&#xD;&#xA;        // Likely a bye week, GetNextGame gets the game for a specific week type and week&#xD;&#xA;        // Pull in the next week, to use next relevant playbooks in practice&#xD;&#xA;&#xD;&#xA;        if(weekType == SeasonWeekType.RegularSeason)&#xD;&#xA;        {&#xD;&#xA;            seasonGame = SeasonManager.GetNextGame(team, weekType, week + 1);&#xD;&#xA;        }&#xD;&#xA;        else&#xD;&#xA;        {&#xD;&#xA;            SeasonWeekType nextWeekType = SeasonWeekType.OffSeason;&#xD;&#xA;            if (weekType == SeasonWeekType.BowlSeason1)&#xD;&#xA;            {&#xD;&#xA;                nextWeekType = SeasonWeekType.BowlSeason2;&#xD;&#xA;            }&#xD;&#xA;            else if (weekType == SeasonWeekType.BowlSeason2)&#xD;&#xA;            {&#xD;&#xA;                nextWeekType = SeasonWeekType.BowlSeason3;&#xD;&#xA;            }&#xD;&#xA;            else if (weekType == SeasonWeekType.BowlSeason3)&#xD;&#xA;            {&#xD;&#xA;                nextWeekType = SeasonWeekType.NationalChampionship;&#xD;&#xA;            }&#xD;&#xA;&#xD;&#xA;            if(nextWeekType != SeasonWeekType.OffSeason)&#xD;&#xA;            {&#xD;&#xA;                seasonGame = SeasonManager.GetNextGame(team, nextWeekType, week + 1);&#xD;&#xA;            }&#xD;&#xA;        }&#xD;&#xA;&#xD;&#xA;        if(weekType == SeasonWeekType.BowlSeason1)&#xD;&#xA;        {&#xD;&#xA;            hadPlayoffByeWeek = true;&#xD;&#xA;        }&#xD;&#xA;    }&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;    // If a game was found&#xD;&#xA;    if (seasonGame != null || weekType == SeasonWeekType.PreSeason)&#xD;&#xA;    {&#xD;&#xA;        // Create a practice game&#xD;&#xA;        SeasonGame practiceGame = PracticeGame;&#xD;&#xA;&#xD;&#xA;     if (practiceGame != null)&#xD;&#xA;     {&#xD;&#xA;          practiceGame.TimeOfDay = 975;&#xD;&#xA;          practiceGame.IsKickoffGame = false;&#xD;&#xA;          if(weekType == SeasonWeekType.PreSeason)&#xD;&#xA;          {&#xD;&#xA;            practiceGame.SeasonYear = SeasonInfo.CurrentYear;&#xD;&#xA;            practiceGame.SeasonWeekType = SeasonInfo.CurrentWeekType;&#xD;&#xA;          }&#xD;&#xA;          else&#xD;&#xA;          {&#xD;&#xA;            practiceGame.SeasonYear = seasonGame.SeasonYear ;&#xD;&#xA;            practiceGame.SeasonWeekType = seasonGame.SeasonWeekType;&#xD;&#xA;          }&#xD;&#xA;&#xD;&#xA;          practiceGame.SeasonGameNum = 0;&#xD;&#xA;          practiceGame.GameStatus = GameStatus.Unplayed;&#xD;&#xA;          practiceGame.IsPractice = true;&#xD;&#xA;          practiceGame.ThanksgivingFlag = false;&#xD;&#xA;&#xD;&#xA;          // Make sure the team is the home team, this is used so the practice session receives relevant playbooks&#xD;&#xA;          practiceGame.HomeTeam = team;&#xD;&#xA;          practiceGame.AwayTeam = PracticeTeam;&#xD;&#xA;&#xD;&#xA;          // Create the game request&#xD;&#xA;          PracticeRequest gameRequest = CreatePracticeRequest(isUserPlayer, team);&#xD;&#xA;          gameRequest.RequestData = practiceGame;&#xD;&#xA;          gameRequest.IsFreePractice = isFreePractice;&#xD;&#xA;&#xD;&#xA;          if(team.UserCharacter != null &amp;&amp; isUserPlayer)&#xD;&#xA;          {&#xD;&#xA;          bool debugMinigameSelectionEnabled = IsMinigameDebugSelectionEnabled();&#xD;&#xA;              gameRequest.ResponseForms = new ResponseForm[3];&#xD;&#xA;        if(!isFreePractice)&#xD;&#xA;        {&#xD;&#xA;               gameRequest.SelectedMinigame = GetMiniGameFromPool(team.UserCharacter, team);&#xD;&#xA;       if(gameRequest.SelectedMinigame != null)&#xD;&#xA;       {&#xD;&#xA;      gameRequest.ResponseForms.Append(PracticePlayerResponse);&#xD;&#xA;       }&#xD;&#xA;        }&#xD;&#xA;              &#xD;&#xA;              gameRequest.ResponseForms.Append(PracticeRequestDelegateResponse);&#xD;&#xA;              if (debugMinigameSelectionEnabled )&#xD;&#xA;              {&#xD;&#xA;                  gameRequest.ResponseForms.Append(PracticeSelectionResponse);&#xD;&#xA;              }&#xD;&#xA;&#xD;&#xA;              gameRequest.DefaultResponse = PracticePlayerResponse;&#xD;&#xA;          }&#xD;&#xA;&#xD;&#xA;         // Set team on request&#xD;&#xA;         gameRequest.Team = team;&#xD;&#xA;         gameRequest.UserEntity = team.UserCharacter;&#xD;&#xA;&#xD;&#xA;         // Issue the request&#xD;&#xA;         gameRequest.Issue(team.UserCharacter);&#xD;&#xA;&#xD;&#xA;         practiceGame.HomeRequestId = gameRequest.RequestId;&#xD;&#xA;     }&#xD;&#xA;   }&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;" />
