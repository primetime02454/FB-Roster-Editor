			<attribute name="HandleFocusTraining" idx="23" type="PracticeEval_HandleFocusTraining" guid="6708631-1948165" default="if(player != null &amp;&amp; team != null)&#xD;&#xA;{&#xD;&#xA;  int xpAward = RandomRef.GetRandomIntRange(MinFocusTrainingXpAward, MaxFocusTrainingXpAward);&#xD;&#xA;  player.ExperiencePoints = player.ExperiencePoints + xpAward;&#xD;&#xA;&#xD;&#xA;  PersonHistoryTrackerNotificationEvent event = PlayerHistoryEventRef;&#xD;&#xA;  event.Person = player;&#xD;&#xA;  event.SourceRecord = FocusTraining;&#xD;&#xA;  event.ExperienceValue = xpAward;&#xD;&#xA;  event.Team = team;&#xD;&#xA;&#xD;&#xA;  event.Send();&#xD;&#xA;}" />
