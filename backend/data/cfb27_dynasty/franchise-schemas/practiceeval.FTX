			<attribute name="CreatePracticeRequest" idx="6" type="PracticeEval_CreatePracticeRequest" guid="6708631-1948154" final="true" default="PracticeRequest request = new PracticeRequest;&#xD;&#xA;&#xD;&#xA;// Set the request settings.&#xD;&#xA;request.Priority = 4;&#xD;&#xA;request.IsResponseRequired = true;&#xD;&#xA;request.IsConnectionRequired = false;&#xD;&#xA;request.IsBlocking = false;&#xD;&#xA;request.PracticeEvalRef = this;&#xD;&#xA;request.RequestData = PracticeGame;&#xD;&#xA;request.IsPersistent = true;&#xD;&#xA;&#xD;&#xA;request.ResponseForms = new ResponseForm[2];&#xD;&#xA;&#xD;&#xA;request.ResponseForms.Append(PracticeRequestPlayResponse);&#xD;&#xA;&#xD;&#xA;if (IsDelegateResponseAvailable)&#xD;&#xA;{&#xD;&#xA;    request.ResponseForms.Append(PracticeRequestDelegateResponse);&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;request.DefaultResponse = PracticeRequestDelegateResponse;&#xD;&#xA;request.CanUpdateResponse = true;&#xD;&#xA;&#xD;&#xA;request;" />
